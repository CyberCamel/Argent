@page
@model Argent.Web.Pages.LoginModel

<div class="flex justify-center py-8">
    <div class="w-full max-w-sm">
        <div class="card">
            <div class="p-6">
                <div class="text-center mb-6">
                    <i class="bi bi-diamond-fill text-2xl text-indigo-600 dark:text-indigo-400"></i>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mt-2 mb-1">Sign in</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mb-0">Welcome back to Argent</p>
                </div>
                <form method="post">
                    <div asp-validation-summary="All" class="text-sm text-red-600 dark:text-red-400 mb-3"></div>
                    <div class="space-y-3">
                        <div>
                            <label asp-for="Input.UserName" class="form-label">Username</label>
                            <input asp-for="Input.UserName" class="form-input" placeholder="Enter your username" autocomplete="username" />
                        </div>
                        <div>
                            <label asp-for="Input.Password" class="form-label">Password</label>
                            <input asp-for="Input.Password" class="form-input" placeholder="Enter your password" autocomplete="current-password" />
                        </div>
                        <div class="flex items-center gap-2">
                            <input asp-for="Input.RememberMe" class="rounded border-gray-300 dark:border-gray-700 text-indigo-600 focus:ring-indigo-500" id="rememberMeCheck" />
                            <label class="text-sm text-gray-600 dark:text-gray-400" for="rememberMeCheck">Remember me</label>
                        </div>
                    </div>
                    <button type="submit" class="w-full mt-6 px-4 py-2.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors shadow-sm">Log In</button>
                </form>
            </div>
        </div>
    </div>
</div>
