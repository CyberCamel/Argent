@using Argent.Web.Models.ViewModels
@model IEnumerable<UserViewModel>

@foreach (var user in Model)
{
    <tr>
        <td>
            <a href="/Users/View/@user.Id" class="font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
                @user.FirstName @user.LastName
            </a>
        </td>
        <td class="text-gray-500 dark:text-gray-400">@user.Email</td>
        <td>
            <div class="flex flex-wrap gap-1">
                @foreach (var role in user.Roles)
                {
                    <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@role</span>
                }
            </div>
        </td>
        <td class="text-right">
            <div class="flex items-center justify-end gap-1">
                <a class="btn-action btn-action-primary" href="/Users/View/@user.Id" title="View">
                    <i class="bi bi-eye-fill"></i>
                </a>
                <button class="btn-action btn-action-secondary" title="Edit"
                        hx-get="/UserAdministration/Edit/@user.UserName"
                        hx-target="#modalBody"
                        hx-trigger="click"
                        hx-on="htmx:afterSwap: Alpine.$data(document.getElementById('userModal')).open = true">
                    <i class="bi bi-pencil-fill"></i>
                </button>
                <form hx-post="/UserAdministration/Delete/@user.UserName" method="post"
                      class="inline"
                      hx-confirm="Are you sure?"
                      hx-target="closest tr"
                      hx-swap="outerHTML">
                    <button type="submit" class="btn-action btn-action-danger" title="Delete">
                        <i class="bi bi-trash-fill"></i>
                    </button>
                </form>
            </div>
        </td>
    </tr>
}
