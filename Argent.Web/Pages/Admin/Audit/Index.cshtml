@page "/Admin/Audit"
@model Argent.Web.Pages.Admin.Audit.IndexModel
@{
    ViewData["Title"] = "Audit Log";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "Audit Log",
    Subtitle = "Workflow execution audit trail"
}' />

@* Filters *@
<div class="card mb-4">
    <div class="p-4">
        <form method="get" class="flex flex-wrap items-end gap-3">
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Category</label>
                <select name="category" class="form-input" onchange="this.form.submit()">
                    <option value="">All</option>
                    @foreach (var cat in (List<string>)ViewData["Categories"]!)
                    {
                        <option value="@cat" selected="@(Model.CategoryFilter == cat)">@cat</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Event Type</label>
                <select name="eventType" class="form-input" onchange="this.form.submit()">
                    <option value="">All</option>
                    @foreach (var et in (List<string>)ViewData["EventTypes"]!)
                    {
                        <option value="@et" selected="@(Model.EventTypeFilter == et)">@et</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Instance Id</label>
                <input type="text" name="instanceId" class="form-input" placeholder="Guid…" value="@Model.InstanceFilter?.ToString()" style="width: 280px;" />
            </div>
            <div>
                <button type="submit" class="px-3 py-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors">
                    <i class="bi bi-funnel-fill me-1"></i> Filter
                </button>
            </div>
            @if (!string.IsNullOrEmpty(Model.CategoryFilter) || !string.IsNullOrEmpty(Model.EventTypeFilter) || Model.InstanceFilter.HasValue)
            {
                <div>
                    <a class="px-3 py-2 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors" asp-page="/Admin/Audit/Index">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
            }
        </form>
    </div>
</div>

@if (Model.Entries.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-journal-text",
        Message = "No audit entries match your criteria."
    }' />
}
else
{
    <div class="table-wrap">
        <table class="text-xs">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Category</th>
                    <th>Event</th>
                    <th>Instance</th>
                    <th>Token</th>
                    <th>Actor</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.Entries)
                {
                    <tr>
                        <td class="text-gray-500 dark:text-gray-400 whitespace-nowrap">@entry.TimeStamp.ToString("g")</td>
                        <td><span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@entry.Category</span></td>
                        <td class="font-medium">@entry.EventType</td>
                        <td>
                            <a class="text-indigo-600 dark:text-indigo-400 hover:underline font-mono text-xs"
                               asp-page="/Admin/WorkflowInstances/Detail"
                               asp-route-id="@entry.InstanceId">
                                @entry.InstanceId.ToString()[..8]…
                            </a>
                        </td>
                        <td class="text-gray-500 dark:text-gray-400 font-mono text-xs">
                            @(entry.TokenId?.ToString()[..8] ?? "—")
                        </td>
                        <td class="text-gray-500 dark:text-gray-400">@(entry.Actor ?? "—")</td>
                        <td><code class="text-xs bg-gray-100 dark:bg-gray-800 px-1 rounded">@(entry.Details ?? "—")</code></td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400 border-t border-gray-100 dark:border-gray-800">
            @Model.Entries.Count entries
        </div>
    </div>
}
