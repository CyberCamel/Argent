@page "/Admin/Groups"
@model Argent.Web.Pages.Admin.Groups.IndexModel
@{
    ViewData["Title"] = "Groups";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "User Groups",
    Subtitle = "Group users so policies can target them directly",
    ActionLink = new Argent.Web.Pages.Shared.LinkModel("New Group", "/Admin/Groups/Create", "bi-plus-lg")
}' />

@if (Model.Groups.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-people",
        Message = "No groups yet. Create one to group users."
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Members</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model.Groups)
                {
                    <tr>
                        <td class="font-medium">
                            @g.Name
                            @if (g.IsSystem)
                            {
                                <span class="badge bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200 border border-indigo-200 dark:border-indigo-800 ms-1">System</span>
                            }
                        </td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@g.Description</td>
                        <td>
                            @if (g.IsSystem)
                            {
                                <span class="text-gray-400 text-sm">—</span>
                            }
                            else
                            {
                                <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@g.MemberCount</span>
                            }
                        </td>
                        <td class="text-right">
                            @if (!g.IsSystem)
                            {
                                <a class="btn-action btn-action-secondary" href="/Admin/Groups/Edit/@g.Id" title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
