@page "/Admin/Groups"
@model Argent.Web.Pages.Admin.Groups.IndexModel
@{
    ViewData["Title"] = "Groups";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">User Groups</h4>
        <p class="text-muted small mb-0">Group users so policies can target them directly</p>
    </div>
    <a class="btn btn-primary" href="/Admin/Groups/Create">
        <i class="bi bi-plus-lg"></i> New Group
    </a>
</div>

@if (Model.Groups.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-people fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted mb-0">No groups yet. Create one to group users.</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Members</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in Model.Groups)
                    {
                        <tr>
                            <td class="fw-medium">@g.Name</td>
                            <td class="small text-muted">@g.Description</td>
                            <td><span class="badge bg-secondary">@g.MemberCount</span></td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm" href="/Admin/Groups/Edit/@g.Id">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
