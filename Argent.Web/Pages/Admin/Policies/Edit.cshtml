@page "/Admin/Policies/Edit/{id:guid}"
@using Argent.WebComponents.Authorization
@model Argent.Web.Pages.Admin.Policies.EditModel
@{
    ViewData["Title"] = "Edit Policy";
}

<div class="container py-4" style="max-width: 720px;">
    <a href="/Admin/Policies" class="btn btn-outline-secondary btn-sm mb-3">&larr; Back to Policies</a>
    <component type="typeof(PolicyEditor)" render-mode="ServerPrerendered"
               param-Policy="@Model.Policy" />
</div>
