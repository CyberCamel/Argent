@page "/UserAdministration"
@model Argent.Web.Pages.UserAdministration.IndexModel
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">User Management</h4>
        <p class="text-muted small mb-0">Manage users and their roles</p>
    </div>
    <button class="btn btn-primary"
            hx-get="/UserAdministration/Create"
            hx-target="#modalBody"
            hx-trigger="click"
            hx-on="htmx:afterSwap: bootstrap.Modal.getOrCreateInstance(document.getElementById('userModal')).show()">
        <i class="bi bi-plus-lg"></i> Add User
    </button>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="userTable"
                   hx-get="/UserAdministration/List"
                   hx-trigger="load, userActionCompleted from:body, userDeleted from:body"
                   hx-swap="innerHTML">
                <partial name="~/Pages/UserAdministration/_UserTablePartial.cshtml" model="Model.Users" />
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold"><i class="bi bi-person me-2 text-primary"></i>Manage User</h5>
            </div>
            <div class="modal-body" id="modalBody"></div>
        </div>
    </div>
</div>

<partial name="~/Pages/Shared/_ValidationScriptsPartial.cshtml" />

<script>
    document.body.addEventListener('htmx:afterSwap', function (e) {
        if (e.target.id === "modalBody") {
            const form = e.target.querySelector("form");
            if (form) {
                $.validator.unobtrusive.parse(form);
            }
            bootstrap.Modal.getOrCreateInstance(document.getElementById('userModal')).show();
        }
    });

    document.body.addEventListener('userActionCompleted', function () {
        bootstrap.Modal.getInstance(document.getElementById('userModal')).hide();
    });
</script>
