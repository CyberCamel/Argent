@page "/Admin/WorkflowInstances/{id:guid}"
@model Argent.Web.Pages.Admin.WorkflowInstances.DetailModel
@using Argent.Models.Workflows
@using Argent.Models.Workflows.Execution
@using Argent.WebComponents.Core.Workflows.Modeler
@{
    ViewData["Title"] = $"Instance: {Model.Instance.WorkflowName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">@Model.Instance.WorkflowName</h4>
        <p class="text-muted small mb-0">
            Instance <code>@Model.Instance.InstanceId</code>
        </p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-secondary btn-sm" asp-page="/Admin/WorkflowInstances/Index">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        @if (Model.Instance.State == InstanceState.Running)
        {
            <form method="post" asp-page-handler="Suspend" asp-route-id="@Model.Instance.InstanceId" class="d-inline">
                <button type="submit" class="btn btn-warning btn-sm">
                    <i class="bi bi-pause-fill"></i> Suspend
                </button>
            </form>
            <form method="post" asp-page-handler="Cancel" asp-route-id="@Model.Instance.InstanceId" class="d-inline"
                  onsubmit="return confirm('Cancel this instance? Active tokens will be consumed.');">
                <button type="submit" class="btn btn-danger btn-sm">
                    <i class="bi bi-x-circle-fill"></i> Cancel
                </button>
            </form>
        }
        @if (Model.Instance.State == InstanceState.Suspended)
        {
            <form method="post" asp-page-handler="Resume" asp-route-id="@Model.Instance.InstanceId" class="d-inline">
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="bi bi-play-fill"></i> Resume
                </button>
            </form>
        }
    </div>
</div>

@* Instance Metadata *@
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="small text-muted mb-1">State</div>
                @{
                    var stateBadge = Model.Instance.State switch
                    {
                        InstanceState.Running => "bg-primary",
                        InstanceState.Suspended => "bg-warning text-dark",
                        InstanceState.Completed => "bg-success",
                        InstanceState.Failed => "bg-danger",
                        InstanceState.Cancelled => "bg-secondary",
                        _ => "bg-secondary"
                    };
                }
                <span class="badge @stateBadge rounded-pill fs-6">@Model.Instance.State</span>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="small text-muted mb-1">Active Tokens</div>
                <div class="fw-bold fs-5">@Model.Instance.ActiveTokenCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="small text-muted mb-1">Started</div>
                <div class="fw-semibold">@Model.Instance.StartTime.ToString("g")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <div class="small text-muted mb-1">Ended</div>
                <div class="fw-semibold">@(Model.Instance.EndTime?.ToString("g") ?? "—")</div>
            </div>
        </div>
    </div>
</div>

@* Tabs *@
<ul class="nav nav-tabs mb-3" id="instanceTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="diagram-tab" data-bs-toggle="tab" data-bs-target="#diagram" type="button" role="tab">
            <i class="bi bi-diagram-3 me-1"></i> Diagram
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tokens-tab" data-bs-toggle="tab" data-bs-target="#tokens" type="button" role="tab">
            <i class="bi bi-circle-fill me-1"></i> Tokens (@Model.Tokens.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="workitems-tab" data-bs-toggle="tab" data-bs-target="#workitems" type="button" role="tab">
            <i class="bi bi-list-task me-1"></i> Work Items (@Model.WorkItems.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="tasks-tab" data-bs-toggle="tab" data-bs-target="#tasks" type="button" role="tab">
            <i class="bi bi-person-check me-1"></i> User Tasks (@Model.UserTasks.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="variables-tab" data-bs-toggle="tab" data-bs-target="#variables" type="button" role="tab">
            <i class="bi bi-braces me-1"></i> Variables (@Model.Variables.Count)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="audit-tab" data-bs-toggle="tab" data-bs-target="#audit" type="button" role="tab">
            <i class="bi bi-journal-text me-1"></i> Audit (@Model.AuditEntries.Count)
        </button>
    </li>
</ul>

<div class="tab-content" id="instanceTabsContent">
    @* Diagram *@
    <div class="tab-pane fade show active" id="diagram" role="tabpanel" style="height: 480px;">
        <component type="typeof(InstanceModeler)" render-mode="ServerPrerendered"
                   param-InstanceId="@Model.Instance.InstanceId" />
    </div>

    @* Tokens *@
    <div class="tab-pane fade" id="tokens" role="tabpanel">
        @if (Model.Tokens.Count == 0)
        {
            <div class="card"><div class="card-body text-center py-4 text-muted">No tokens.</div></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Node</th>
                                <th>State</th>
                                <th>Group</th>
                                <th>Created</th>
                                <th>Consumed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Tokens)
                            {
                                <tr>
                                    <td><code>@t.Id.ToString()[..8]…</code></td>
                                    <td><code>@t.NodeId.ToString()[..8]…</code></td>
                                    <td>
                                        @{
                                            var tBadge = t.State switch
                                            {
                                                TokenState.Ready => "bg-primary",
                                                TokenState.Waiting => "bg-warning text-dark",
                                                TokenState.Consumed => "bg-secondary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @tBadge rounded-pill">@t.State</span>
                                    </td>
                                    <td class="text-muted">@(t.GroupId?.ToString()[..8] ?? "—")</td>
                                    <td class="text-muted">@t.CreatedAt.ToString("g")</td>
                                    <td class="text-muted">@(t.ConsumedAt?.ToString("g") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @* Work Items *@
    <div class="tab-pane fade" id="workitems" role="tabpanel">
        @if (Model.WorkItems.Count == 0)
        {
            <div class="card"><div class="card-body text-center py-4 text-muted">No work items.</div></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Node Type</th>
                                <th>State</th>
                                <th>Priority</th>
                                <th>Retries</th>
                                <th>Locked By</th>
                                <th>Created</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in Model.WorkItems)
                            {
                                <tr>
                                    <td>
                                        <a asp-page="/Admin/WorkItems/Detail" asp-route-id="@w.Id"
                                           class="font-monospace text-decoration-none small">
                                            @w.Id.ToString()[..8]…
                                        </a>
                                    </td>
                                    <td>@w.NodeType</td>
                                    <td>
                                        @{
                                            var wiBadge = w.State switch
                                            {
                                                WorkItemState.Pending => "bg-secondary",
                                                WorkItemState.Running => "bg-primary",
                                                WorkItemState.Completed => "bg-success",
                                                WorkItemState.Failed => "bg-danger",
                                                WorkItemState.Waiting => "bg-warning text-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @wiBadge rounded-pill">@w.State</span>
                                    </td>
                                    <td>@w.Priority</td>
                                    <td>@w.RetryCount/@w.MaxRetries</td>
                                    <td class="text-muted">@(w.LockedBy ?? "—")</td>
                                    <td class="text-muted">@w.CreatedAt.ToString("g")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @* User Tasks *@
    <div class="tab-pane fade" id="tasks" role="tabpanel">
        @if (Model.UserTasks.Count == 0)
        {
            <div class="card"><div class="card-body text-center py-4 text-muted">No user tasks.</div></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>State</th>
                                <th>Assigned To</th>
                                <th>Priority</th>
                                <th>Created</th>
                                <th>Completed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.UserTasks)
                            {
                                <tr>
                                    <td class="fw-medium">@(t.Title ?? "—")</td>
                                    <td>
                                        @{
                                            var utBadge = t.State switch
                                            {
                                                UserTaskState.Pending => "bg-primary",
                                                UserTaskState.Completed => "bg-success",
                                                UserTaskState.Cancelled => "bg-secondary",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @utBadge rounded-pill">@t.State</span>
                                    </td>
                                    <td class="text-muted">@(t.AssignedTo ?? "—")</td>
                                    <td>@t.Priority</td>
                                    <td class="text-muted">@t.CreatedAt.ToString("g")</td>
                                    <td class="text-muted">@(t.CompletedAt?.ToString("g") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @* Variables *@
    <div class="tab-pane fade" id="variables" role="tabpanel">
        @if (Model.Variables.Count == 0)
        {
            <div class="card"><div class="card-body text-center py-4 text-muted">No variables.</div></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th style="width: 100px">Source</th>
                                <th>Key</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model.Variables.OrderBy(v => v.Source).ThenBy(v => v.Key))
                            {
                                <tr>
                                    <td>
                                        @{
                                            var srcBadge = v.Source switch
                                            {
                                                "Instance" => "bg-primary",
                                                "Record"   => "bg-success",
                                                "Custom"   => "bg-warning text-dark",
                                                _          => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @srcBadge rounded-pill">@v.Source</span>
                                    </td>
                                    <td class="fw-medium font-monospace">@v.Key</td>
                                    <td>@v.DisplayValue</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @* Audit *@
    <div class="tab-pane fade" id="audit" role="tabpanel">
        @if (Model.AuditEntries.Count == 0)
        {
            <div class="card"><div class="card-body text-center py-4 text-muted">No audit entries.</div></div>
        }
        else
        {
            <div class="card">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 small">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Category</th>
                                <th>Event</th>
                                <th>Token</th>
                                <th>Actor</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in Model.AuditEntries)
                            {
                                <tr>
                                    <td class="text-muted">@e.TimeStamp.ToString("g")</td>
                                    <td><span class="badge bg-secondary rounded-pill">@e.Category</span></td>
                                    <td class="fw-medium">@e.EventType</td>
                                    <td class="text-muted">@(e.TokenId?.ToString()[..8] ?? "—")</td>
                                    <td class="text-muted">@(e.Actor ?? "—")</td>
                                    <td><code class="small">@(e.Details ?? "—")</code></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>
