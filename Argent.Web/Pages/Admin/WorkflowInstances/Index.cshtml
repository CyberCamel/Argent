@page "/Admin/WorkflowInstances"
@model Argent.Web.Pages.Admin.WorkflowInstances.IndexModel
@using Argent.Models.Workflows.Execution
@{
    ViewData["Title"] = "Workflow Instances";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "Workflow Instances",
    Subtitle = "Monitor running and completed workflow executions"
}' />

@if (Model.Instances.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-diagram-3",
        Message = "No workflow instances yet."
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Workflow</th>
                    <th>State</th>
                    <th>Active Tokens</th>
                    <th>Started</th>
                    <th>Ended</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inst in Model.Instances)
                {
                    <tr>
                        <td class="font-medium">@inst.WorkflowName</td>
                        <td>
                            @{
                                var stateStyles = inst.State switch
                                {
                                    InstanceState.Running => "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 border-blue-200 dark:border-blue-800",
                                    InstanceState.Suspended => "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 border-yellow-200 dark:border-yellow-800",
                                    InstanceState.Completed => "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 border-green-200 dark:border-green-800",
                                    InstanceState.Failed => "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-200 border-red-200 dark:border-red-800",
                                    InstanceState.Cancelled => "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border-gray-200 dark:border-gray-700",
                                    _ => "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border-gray-200 dark:border-gray-700"
                                };
                            }
                            <span class="badge @stateStyles">@inst.State</span>
                        </td>
                        <td>@inst.TokenCount</td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@inst.StartTime.ToString("g")</td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@(inst.EndTime?.ToString("g") ?? "—")</td>
                        <td class="text-right">
                            <a class="btn-action btn-action-primary" asp-page="/Admin/WorkflowInstances/Detail" asp-route-id="@inst.InstanceId" title="View">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
