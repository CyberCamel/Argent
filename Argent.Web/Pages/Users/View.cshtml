@page "/Users/View/{id:guid}"
@model Argent.Web.Pages.Users.ViewModel
@{
    ViewData["Title"] = "User Details";
}

<div class="max-w-2xl mx-auto">
    <a href="javascript:history.back()" class="btn-action btn-action-secondary text-sm inline-flex items-center gap-1 px-3 py-1.5 rounded-lg mb-3">
        <i class="bi bi-arrow-left"></i> Back
    </a>

    <div class="card">
        <div class="p-6">
            <div class="flex items-center gap-4 mb-6">
                <div class="bg-indigo-600 text-white rounded-full flex items-center justify-center flex-shrink-0"
                     style="width: 56px; height: 56px; font-size: 1.25rem; font-weight: 600;">
                    @Model.Detail.FirstName[0]@Model.Detail.LastName[0]
                </div>
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-0">@Model.Detail.FirstName @Model.Detail.LastName</h2>
                    <span class="text-sm text-gray-500 dark:text-gray-400">@@@Model.Detail.UserName</span>
                </div>
            </div>

            <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
                @if (!string.IsNullOrEmpty(Model.Detail.Email))
                {
                    <div>
                        <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Email</dt>
                        <dd class="text-gray-900 dark:text-gray-100 mt-0.5">@Model.Detail.Email</dd>
                    </div>
                }
                <div>
                    <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Department</dt>
                    <dd class="text-gray-900 dark:text-gray-100 mt-0.5">@(Model.Detail.Department ?? "—")</dd>
                </div>
                <div>
                    <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Manager</dt>
                    <dd class="text-gray-900 dark:text-gray-100 mt-0.5">@(Model.Detail.IsManager ? "Yes" : "No")</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Roles</dt>
                    <dd class="mt-0.5">
                        @if (Model.Detail.Roles.Count == 0)
                        {
                            <span class="text-gray-400 text-sm">None</span>
                        }
                        else
                        {
                            <div class="flex flex-wrap gap-1">
                                @foreach (var role in Model.Detail.Roles)
                                {
                                    <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@role</span>
                                }
                            </div>
                        }
                    </dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Groups</dt>
                    <dd class="mt-0.5">
                        @if (Model.Detail.Groups.Count == 0)
                        {
                            <span class="text-gray-400 text-sm">Not a member of any group</span>
                        }
                        else
                        {
                            <div class="flex flex-wrap gap-1">
                                @foreach (var group in Model.Detail.Groups)
                                {
                                    <span class="badge bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 border border-blue-200 dark:border-blue-800">@group</span>
                                }
                            </div>
                        }
                    </dd>
                </div>
            </dl>
        </div>
    </div>
</div>
