@page "/Forms"
@model Argent.Web.Pages.Forms.IndexModel
@{
    ViewData["Title"] = "Forms";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "Forms",
    Subtitle = "Manage your form definitions",
    ActionLink = new Argent.Web.Pages.Shared.LinkModel("New Form", "/Forms/Create", "bi-plus-lg")
}' />

@if (Model.Forms.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-ui-checks",
        Message = "No forms yet. Create your first one!",
        LinkText = "Create your first one",
        LinkUrl = "/Forms/Create"
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Updated</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var form in Model.Forms)
                {
                    <tr>
                        <td class="font-medium">@form.Name</td>
                        <td class="text-gray-500 dark:text-gray-400">@form.Description</td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@form.UpdatedAt.ToString("g")</td>
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-1">
                                <a class="btn-action btn-action-secondary" href="/Forms/Edit/@form.Id" title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@form.Id" style="display:inline"
                                      onsubmit="return confirm('Delete this form?')">
                                    <button class="btn-action btn-action-danger" title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
