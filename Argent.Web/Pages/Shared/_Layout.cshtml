<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)" render-mode="ServerPrerendered" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Argent</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark border-bottom border-white border-opacity-10">
            <div class="container">
                <a class="navbar-brand fw-semibold tracking-tight"  asp-page="/Index">
                    <i class="bi bi-diamond-fill me-2"></i>Argent
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Workflows/Index">Workflows</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Forms/Index">Forms</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-sm-center gap-1">
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="avatar avatar-sm">@((User.FindFirst("FirstName")?.Value ?? User.Identity.Name)?[0])</span>
                                    <span class="d-none d-sm-inline">@(User.FindFirst("FirstName")?.Value ?? User.Identity.Name)</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                    <li><a class="dropdown-item" asp-page="/Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-page="/Account/Logout" method="post">
                                            <button type="submit" class="dropdown-item text-danger"><i class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="loginDropdown"
                                   role="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                    <i class="bi bi-person me-1"></i>Login
                                </a>
                                <div class="dropdown-menu dropdown-menu-end p-4 shadow-sm border-0 mt-2 @(TempData["LoginError"] != null ? "show" : "")"
                                     style="min-width: 300px;"
                                     @(TempData["LoginError"] != null ? "data-bs-popper=static" : "")>
                                    <h6 class="fw-semibold mb-3">Sign in</h6>
                                    <form asp-page="/Account/QuickLogin" method="post">
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                        <div class="mb-3">
                                            <label class="form-label small fw-medium">Username</label>
                                            <input name="username" type="text" class="form-control" required autocomplete="username">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label small fw-medium">Password</label>
                                            <input name="password" type="password" class="form-control" required autocomplete="current-password">
                                        </div>
                                        <div class="mb-3 form-check">
                                            <input type="checkbox" name="rememberMe" class="form-check-input" id="rememberMeCheck" value="true">
                                            <label class="form-check-label small" for="rememberMeCheck">Remember me</label>
                                        </div>
                                        @if (TempData["LoginError"] != null)
                                        {
                                            <div class="alert alert-danger py-2 small mb-3">
                                                <i class="bi bi-exclamation-triangle me-1"></i>@TempData["LoginError"]
                                            </div>
                                        }
                                        <button type="submit" class="btn btn-primary w-100">Sign in</button>
                                    </form>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["IsFullWidth"] is bool fullWidth && fullWidth == true)
    {
        @RenderBody()
    }
    else
    {
        <div class="container flex-grow-1 d-flex flex-column py-4">
            <main role="main" class="flex-grow-1">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-top py-4 mt-auto">
        <div class="container d-flex justify-content-between align-items-center">
            <span class="text-muted small">&copy; 2026 Argent</span>
            <a asp-area="" asp-page="/Privacy" class="text-muted small text-decoration-none">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/monaco.js" asp-append-version="true"></script>
    <script src="~/js/modeler2.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/htmx.min.js" asp-append-version="true"></script>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
