<!DOCTYPE html>
<html lang="en" x-data="theme()" x-init="init" :class="dark ? 'dark' : ''">
<head>
    <base href="/" />
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)" render-mode="ServerPrerendered" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Argent</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modeler.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 min-h-screen flex flex-col font-sans antialiased">
    <header>
        <nav class="bg-gray-900 border-b border-white/10"
             x-data="{ mobileOpen: false }">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-14">
                    <div class="flex items-center gap-6">
                        <a asp-page="/Index" class="flex items-center gap-2 text-white font-semibold tracking-tight text-lg">
                            <i class="bi bi-diamond-fill text-indigo-500"></i>
                            Argent
                        </a>
                        <div class="hidden md:flex items-center gap-1">
                            <a asp-page="/Index" class="nav-link">Home</a>
                            <a asp-page="/Tasks/Index" class="nav-link">My Tasks</a>
                            <a asp-page="/Workflows/Index" class="nav-link">Workflows</a>
                            <a asp-page="/Forms/Index" class="nav-link">Forms</a>
                            <a asp-page="/DomainObjects/Index" class="nav-link">Domain Objects</a>
                            @if (User.IsInRole("SuperAdmin"))
                            {
                                <div class="relative" x-data="{ open: false }" @@click.outside="open = false">
                                    <button @@click="open = !open" class="nav-link flex items-center gap-1">
                                        Admin <i class="bi bi-chevron-down text-xs"></i>
                                    </button>
                                    <div x-show="open" x-cloak
                                         class="absolute top-full left-0 mt-1 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50">
                                        <a asp-page="/DataSources/Index" class="nav-dropdown-item">
                                            <i class="bi bi-hdd-network w-5 text-gray-400"></i>Data Sources
                                        </a>
                                        <a asp-page="/Admin/WorkflowInstances/Index" class="nav-dropdown-item">
                                            <i class="bi bi-diagram-3 w-5 text-gray-400"></i>Instances
                                        </a>
                                        <a asp-page="/Admin/Audit/Index" class="nav-dropdown-item">
                                            <i class="bi bi-journal-text w-5 text-gray-400"></i>Audit
                                        </a>
                                        <a asp-page="/Admin/Capabilities" class="nav-dropdown-item">
                                            <i class="bi bi-shield-check w-5 text-gray-400"></i>Capabilities
                                        </a>
                                        <a asp-page="/Admin/Groups/Index" class="nav-dropdown-item">
                                            <i class="bi bi-people w-5 text-gray-400"></i>Groups
                                        </a>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <button @@click="toggle()" class="nav-icon-btn" title="Toggle dark mode">
                            <template x-if="!dark">
                                <i class="bi bi-moon-stars"></i>
                            </template>
                            <template x-if="dark">
                                <i class="bi bi-sun"></i>
                            </template>
                        </button>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <div class="relative" x-data="{ open: false }" @@click.outside="open = false">
                                <button @@click="open = !open"
                                        class="flex items-center gap-2 text-white/70 hover:text-white transition-colors px-2 py-1 rounded-lg hover:bg-white/10">
                                    <span class="avatar avatar-sm">@((User.FindFirst("FirstName")?.Value ?? User.Identity.Name)?[0])</span>
                                    <span class="hidden sm:inline text-sm font-medium">@(User.FindFirst("FirstName")?.Value ?? User.Identity.Name)</span>
                                    <i class="bi bi-chevron-down text-xs"></i>
                                </button>
                                <div x-show="open" x-cloak
                                     class="absolute right-0 top-full mt-1 w-48 bg-white dark:bg-gray-800 rounded-lg shadow-lg border border-gray-200 dark:border-gray-700 py-1 z-50">
                                    <a asp-page="/Profile" class="nav-dropdown-item">
                                        <i class="bi bi-person w-5 text-gray-400"></i>My Profile
                                    </a>
                                    <hr class="my-1 border-gray-200 dark:border-gray-700">
                                    <form asp-page="/Account/Logout" method="post">
                                        <button type="submit" class="nav-dropdown-item text-red-600 dark:text-red-400 w-full text-left">
                                            <i class="bi bi-box-arrow-right w-5 text-gray-400"></i>Logout
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                        else
                        {
                            <a asp-page="/Login" class="text-sm font-medium text-white/70 hover:text-white transition-colors px-3 py-1.5 rounded-lg hover:bg-white/10">
                                <i class="bi bi-person me-1"></i>Login
                            </a>
                        }
                        <button @@click="mobileOpen = !mobileOpen" class="md:hidden nav-icon-btn" aria-label="Toggle navigation">
                            <i class="bi bi-list text-xl"></i>
                        </button>
                    </div>
                </div>
                <div x-show="mobileOpen" x-cloak class="md:hidden pb-3 border-t border-white/10 mt-2 pt-3 space-y-1">
                    <a asp-page="/Index" class="nav-link-mobile">Home</a>
                    <a asp-page="/Tasks/Index" class="nav-link-mobile">My Tasks</a>
                    <a asp-page="/Workflows/Index" class="nav-link-mobile">Workflows</a>
                    <a asp-page="/Forms/Index" class="nav-link-mobile">Forms</a>
                    <a asp-page="/DomainObjects/Index" class="nav-link-mobile">Domain Objects</a>
                    @if (User.IsInRole("SuperAdmin"))
                    {
                        <div class="pt-2 border-t border-white/10">
                            <div class="text-xs font-semibold text-white/50 uppercase tracking-wider px-3 pb-1">Admin</div>
                            <a asp-page="/DataSources/Index" class="nav-link-mobile">Data Sources</a>
                            <a asp-page="/Admin/WorkflowInstances/Index" class="nav-link-mobile">Instances</a>
                            <a asp-page="/Admin/Audit/Index" class="nav-link-mobile">Audit</a>
                            <a asp-page="/Admin/Capabilities" class="nav-link-mobile">Capabilities</a>
                            <a asp-page="/Admin/Groups/Index" class="nav-link-mobile">Groups</a>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>

    @if (ViewData["IsFullWidth"] is bool fullWidth && fullWidth == true)
    {
        <div class="flex-1 flex flex-col">
            @RenderBody()
        </div>
    }
    else
    {
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex-1 flex flex-col py-6">
            <main class="flex-1">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-t border-gray-200 dark:border-gray-800 py-4 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
            <span class="text-gray-400 text-sm">&copy; 2026 Argent</span>
            <a asp-area="" asp-page="/Privacy" class="text-gray-400 text-sm hover:text-gray-600 dark:hover:text-gray-300 transition-colors">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/js/monaco.js" asp-append-version="true"></script>
    <script src="~/js/modeler.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/htmx.min.js" asp-append-version="true"></script>
    <script src="~/lib/alpine/alpine.min.js" defer></script>
    <script src="_framework/blazor.server.js"></script>
    <script>
        function theme() {
            return {
                dark: false,
                init() {
                    const stored = localStorage.getItem('argent-theme');
                    if (stored) {
                        this.dark = stored === 'dark';
                    } else {
                        this.dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                    }
                },
                toggle() {
                    this.dark = !this.dark;
                    localStorage.setItem('argent-theme', this.dark ? 'dark' : 'light');
                }
            }
        }
    </script>
</body>
</html>
