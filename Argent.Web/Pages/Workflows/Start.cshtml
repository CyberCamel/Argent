@page "/Workflows/Start"
@using System.Security.Claims
@using Argent.WebComponents.Workflows
@model Argent.Web.Pages.Workflows.StartModel
@{
    ViewData["Title"] = Model.WorkflowId.HasValue ? $"Start — {Model.WorkflowName}" : "Start a Workflow";
}

@if (Model.WorkflowId.HasValue)
{
    <div class="max-w-2xl mx-auto">
        <a href="/Workflows/Start" class="btn-action btn-action-secondary text-sm inline-flex items-center gap-1 px-3 py-1.5 rounded-lg mb-3">
            <i class="bi bi-arrow-left"></i> All Workflows
        </a>
        <div class="card">
            <div class="px-5 py-3 border-b border-gray-200 dark:border-gray-800">
                <h2 class="text-base font-bold text-gray-900 dark:text-gray-100 mb-0">@Model.WorkflowName</h2>
            </div>
            <div class="p-5">
                <component type="typeof(WorkflowStarter)" render-mode="ServerPrerendered"
                           param-WorkflowId="@Model.WorkflowId.Value"
                           param-UserId="@User.FindFirstValue(ClaimTypes.NameIdentifier)" />
            </div>
        </div>
    </div>
}
else
{
    <partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
        Title = "Start a Workflow",
        Subtitle = "Choose a workflow to launch"
    }' />

    @if (Model.Workflows.Count == 0)
    {
        <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
            Icon = "bi-rocket-takeoff",
            Message = "No workflows available to start."
        }' />
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wf in Model.Workflows)
                    {
                        <tr>
                            <td class="font-medium">@wf.Name</td>
                            <td class="text-sm text-gray-500 dark:text-gray-400">@wf.Description</td>
                            <td class="text-right">
                                <a class="px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors shadow-sm inline-flex items-center gap-1" href="/Workflows/Start?workflowId=@wf.Id">
                                    <i class="bi bi-play-fill"></i> Start
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
