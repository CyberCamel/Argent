@page "/Workflows/Start"
@using System.Security.Claims
@using Argent.WebComponents.Workflows
@model Argent.Web.Pages.Workflows.StartModel
@{
    ViewData["Title"] = Model.WorkflowId.HasValue ? $"Start — {Model.WorkflowName}" : "Start a Workflow";
}

@if (Model.WorkflowId.HasValue)
{
    <div class="container py-4" style="max-width: 720px;">
        <a href="/Workflows/Start" class="btn btn-outline-secondary btn-sm mb-3">&larr; All Workflows</a>
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="fw-bold mb-0">@Model.WorkflowName</h5>
            </div>
            <div class="card-body">
                <component type="typeof(WorkflowStarter)" render-mode="ServerPrerendered"
                           param-WorkflowId="@Model.WorkflowId.Value"
                           param-UserId="@User.FindFirstValue(ClaimTypes.NameIdentifier)" />
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">Start a Workflow</h4>
            <p class="text-muted small mb-0">Choose a workflow to launch</p>
        </div>
    </div>

    @if (Model.Workflows.Count == 0)
    {
        <div class="card">
            <div class="card-body text-center py-5">
                <i class="bi bi-rocket-takeoff fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted mb-0">No workflows available to start.</p>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Description</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var wf in Model.Workflows)
                        {
                            <tr>
                                <td class="fw-medium">@wf.Name</td>
                                <td class="text-muted small">@wf.Description</td>
                                <td class="text-end">
                                    <a class="btn btn-primary btn-sm" href="/Workflows/Start?workflowId=@wf.Id">
                                        <i class="bi bi-play-fill"></i> Start
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
