@page "/Workflows"
@model Argent.Web.Pages.Workflows.IndexModel
@{
    ViewData["Title"] = "Workflows";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Workflows</h4>
        <p class="text-muted small mb-0">Manage your workflow definitions</p>
    </div>
    <a class="btn btn-primary" href="/Workflows/Create">
        <i class="bi bi-plus-lg"></i> New Workflow
    </a>
</div>

@if (Model.Defs.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-diagram-3 fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted mb-0">No workflows yet. <a href="/Workflows/Create">Create your first one</a>!</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var wf in Model.Defs)
                    {
                        <tr>
                            <td class="fw-medium">@wf.Name</td>
                            <td class="text-muted">@wf.Description</td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm" href="/Workflows/View/@wf.Id">
                                    <i class="bi bi-eye-fill"></i> View
                                </a>
                                <a class="btn btn-outline-secondary btn-sm" href="/Workflows/Edit/@wf.Id">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
