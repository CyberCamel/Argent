@page
@model Argent.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body text-center py-5">
                <span class="avatar avatar-lg mb-3">@(Model._user?.FirstName?[0])</span>
                <h5 class="fw-bold mb-1">@Model._user?.FirstName @Model._user?.LastName</h5>
                <p class="text-muted small mb-3">@@@Model._user?.UserName</p>

                @if (Model.UserRoles.Count > 0)
                {
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        @foreach (var role in Model.UserRoles)
                        {
                            <span class="badge bg-primary bg-opacity-10 text-primary">@role</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
