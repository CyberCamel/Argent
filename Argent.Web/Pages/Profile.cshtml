@page
@model Argent.Web.Pages.ProfileModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="flex justify-center">
    <div class="w-full max-w-md">
        <div class="card">
            <div class="p-6 text-center">
                <span class="avatar avatar-lg mx-auto mb-3">@(Model._user?.FirstName?[0])</span>
                <h2 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-1">@Model._user?.FirstName @Model._user?.LastName</h2>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-3">@@@Model._user?.UserName</p>

                @if (Model.UserRoles.Count > 0)
                {
                    <div class="flex justify-center gap-2 flex-wrap">
                        @foreach (var role in Model.UserRoles)
                        {
                            <span class="badge bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200 border border-indigo-200 dark:border-indigo-800">@role</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
