@page
@model ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle fs-1 text-danger mb-3 d-block"></i>
    <h4 class="fw-bold text-danger">Error</h4>
    <p class="text-muted mb-0">An error occurred while processing your request.</p>

    @if (Model.ShowRequestId)
    {
        <p class="mt-3 mb-0 small text-muted">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
</div>
