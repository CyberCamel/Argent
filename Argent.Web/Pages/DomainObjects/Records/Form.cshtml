@page "/DomainObjects/{Key}/Records/Form"
@model Argent.Web.Pages.DomainObjects.Records.FormModel
@using Argent.Models.DomainObjects
@{
    ViewData["Title"] = Model.IsEdit
        ? $"Edit Record — {Model.Definition.DisplayName}"
        : $"New Record — {Model.Definition.DisplayName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb" class="mb-1">
            <ol class="breadcrumb mb-0 small">
                <li class="breadcrumb-item"><a href="/DomainObjects">Domain Objects</a></li>
                <li class="breadcrumb-item"><a href="/DomainObjects/@Model.Key/Records">@Model.Definition.DisplayName</a></li>
                <li class="breadcrumb-item active">@(Model.IsEdit ? "Edit" : "New")</li>
            </ol>
        </nav>
        <h4 class="fw-bold mb-0">@(Model.IsEdit ? "Edit Record" : "New Record")</h4>
        <p class="text-muted small mb-0">@Model.Definition.DisplayName</p>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            @if (Model.Id.HasValue)
            {
                <input type="hidden" name="Id" value="@Model.Id" />
            }

            @foreach (var prop in Model.Definition.Properties)
            {
                Model.FormValues.TryGetValue(prop.Key, out var currentVal);
                <div class="mb-3">
                    <label class="form-label fw-medium">
                        @prop.DisplayName
                        @if (prop.Required)
                        {
                            <span class="text-danger">*</span>
                        }
                    </label>

                    @switch (prop.Type)
                    {
                        case DomainPropertyType.MultiLineText:
                        case DomainPropertyType.Json:
                            <textarea class="form-control font-monospace"
                                      name="FormValues[@prop.Key]"
                                      rows="4"
                                      placeholder="@prop.Description">@currentVal</textarea>
                            break;

                        case DomainPropertyType.Number:
                            <input type="number" class="form-control"
                                   name="FormValues[@prop.Key]"
                                   value="@currentVal"
                                   step="1"
                                   placeholder="@prop.Description" />
                            break;

                        case DomainPropertyType.Boolean:
                            <div class="form-check">
                                <input type="checkbox" class="form-check-input"
                                       name="FormValues[@prop.Key]"
                                       value="true"
                                       checked="@(currentVal == "true")" />
                                <label class="form-check-label small text-muted">@(prop.Description ?? prop.DisplayName)</label>
                            </div>
                            break;

                        case DomainPropertyType.Date:
                            <input type="date" class="form-control"
                                   name="FormValues[@prop.Key]"
                                   value="@currentVal" />
                            break;

                        case DomainPropertyType.DateTime:
                            <input type="datetime-local" class="form-control"
                                   name="FormValues[@prop.Key]"
                                   value="@currentVal" />
                            break;

                        case DomainPropertyType.Choice:
                            <select class="form-select" name="FormValues[@prop.Key]">
                                <option value="">— select —</option>
                                @foreach (var choice in prop.Choices)
                                {
                                    var choiceVal = choice.Value?.ToString();
                                    <option value="@choiceVal" selected="@(currentVal == choiceVal)">@choice.Label</option>
                                }
                            </select>
                            break;

                        case DomainPropertyType.Reference:
                            <select class="form-select" name="FormValues[@prop.Key]">
                                <option value="">— select —</option>
                                @if (Model.ReferenceOptions.TryGetValue(prop.Key, out var refOptions))
                                {
                                    @foreach (var opt in refOptions)
                                    {
                                        var optVal = opt.Value?.ToString();
                                        <option value="@optVal" selected="@(currentVal == optVal)">@opt.Label</option>
                                    }
                                }
                            </select>
                            break;

                        default:
                            <input type="text" class="form-control"
                                   name="FormValues[@prop.Key]"
                                   value="@currentVal"
                                   placeholder="@prop.Description" />
                            break;
                    }

                    @if (!string.IsNullOrEmpty(prop.Description) && prop.Type is not (DomainPropertyType.MultiLineText or DomainPropertyType.Json or DomainPropertyType.Boolean))
                    {
                        <div class="form-text">@prop.Description</div>
                    }
                </div>
            }

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>@(Model.IsEdit ? "Save changes" : "Create record")
                </button>
                <a class="btn btn-outline-secondary" href="/DomainObjects/@Model.Key/Records">Cancel</a>
            </div>
        </form>
    </div>
</div>
