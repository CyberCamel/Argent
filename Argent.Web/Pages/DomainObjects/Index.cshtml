@page "/DomainObjects"
@model Argent.Web.Pages.DomainObjects.IndexModel
@{
    ViewData["Title"] = "Domain Objects";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "Domain Objects",
    Subtitle = "Model the data entities your forms and workflows operate on",
    ActionLink = new Argent.Web.Pages.Shared.LinkModel("New Domain Object", "/DomainObjects/Create", "bi-plus-lg")
}' />

@if (Model.Objects.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-diagram-3",
        Message = "No domain objects yet. Create your first one!",
        LinkText = "Create your first one",
        LinkUrl = "/DomainObjects/Create"
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Status</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model.Objects)
                {
                    <tr>
                        <td class="font-medium">@obj.Name</td>
                        <td><code class="text-xs font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">@obj.Key</code></td>
                        <td>
                            <div class="flex items-center gap-1.5">
                                @if (obj.PublishedVersion != null)
                                {
                                    <span class="badge bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 border border-green-200 dark:border-green-800">Published v@(obj.PublishedVersion)</span>
                                }
                                else
                                {
                                    <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">Unpublished</span>
                                }
                                @if (obj.HasDraft)
                                {
                                    <span class="badge bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 border border-yellow-200 dark:border-yellow-800">Draft</span>
                                }
                            </div>
                        </td>
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-1">
                                @if (obj.PublishedVersion != null)
                                {
                                    <a class="btn-action btn-action-primary" href="/DomainObjects/@obj.Key/Records" title="Records">
                                        <i class="bi bi-table"></i>
                                    </a>
                                }
                                <a class="btn-action btn-action-secondary" href="/DomainObjects/Edit/@obj.Id" title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@obj.Id" style="display:inline"
                                      onsubmit="return confirm('Delete this domain object and all its records?')">
                                    <button class="btn-action btn-action-danger" title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
