@page "/DataSources"
@model Argent.Web.Pages.DataSources.IndexModel
@{
    ViewData["Title"] = "Data Sources";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Data Sources</h4>
        <p class="text-muted small mb-0">Reusable SQL, REST, and SOAP connections for forms and workflows</p>
    </div>
    <a class="btn btn-primary" href="/DataSources/Create">
        <i class="bi bi-plus-lg"></i> New Data Source
    </a>
</div>

@if (Model.DataSources.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-hdd-network fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted mb-0">No data sources yet. <a href="/DataSources/Create">Create your first one</a>!</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Key</th>
                        <th>Kind</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ds in Model.DataSources)
                    {
                        <tr>
                            <td class="fw-medium">@ds.Name</td>
                            <td><code>@ds.Key</code></td>
                            <td><span class="badge text-bg-light border">@ds.Kind</span></td>
                            <td class="text-end">
                                <a class="btn btn-outline-secondary btn-sm" href="/DataSources/Edit/@ds.Id">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@ds.Id" style="display:inline"
                                      onsubmit="return confirm('Delete this data source?')">
                                    <button class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
