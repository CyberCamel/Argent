@page "/DataSources"
@model Argent.Web.Pages.DataSources.IndexModel
@{
    ViewData["Title"] = "Data Sources";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "Data Sources",
    Subtitle = "Reusable SQL, REST, and SOAP connections for forms and workflows",
    ActionLink = new Argent.Web.Pages.Shared.LinkModel("New Data Source", "/DataSources/Create", "bi-plus-lg")
}' />

@if (Model.DataSources.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-hdd-network",
        Message = "No data sources yet. Create your first one!",
        LinkText = "Create your first one",
        LinkUrl = "/DataSources/Create"
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Key</th>
                    <th>Kind</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ds in Model.DataSources)
                {
                    <tr>
                        <td class="font-medium">@ds.Name</td>
                        <td><code class="text-xs font-mono bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">@ds.Key</code></td>
                        <td>
                            <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@ds.Kind</span>
                        </td>
                        <td class="text-right">
                            <div class="flex items-center justify-end gap-1">
                                <a class="btn-action btn-action-secondary" href="/DataSources/Edit/@ds.Id" title="Edit">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@ds.Id" style="display:inline"
                                      onsubmit="return confirm('Delete this data source?')">
                                    <button class="btn-action btn-action-danger" title="Delete">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
