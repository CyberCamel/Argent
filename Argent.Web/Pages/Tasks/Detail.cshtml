@page "/Tasks/Detail/{id:guid}"
@using System.Security.Claims
@using Argent.WebComponents.Workflows
@model Argent.Web.Pages.Tasks.DetailModel
@{
    ViewData["Title"] = "Task";
}

<div class="max-w-2xl mx-auto">
    <a href="/Tasks" class="btn-action btn-action-secondary text-sm inline-flex items-center gap-1 px-3 py-1.5 rounded-lg mb-3">
        <i class="bi bi-arrow-left"></i> Back to Inbox
    </a>
    <component type="typeof(TaskDetail)" render-mode="ServerPrerendered"
               param-TaskId="@Model.Id"
               param-UserId="@Model.CurrentUserId"
               param-Roles="@Model.CurrentRoles" />
</div>
