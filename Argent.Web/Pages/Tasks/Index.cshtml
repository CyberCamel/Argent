@page "/Tasks"
@model Argent.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "My Tasks";
}

<partial name="~/Pages/Shared/_PageHeader.cshtml" model='new Argent.Web.Pages.Shared.PageHeaderModel {
    Title = "My Tasks",
    Subtitle = "Workflow tasks assigned to you or your roles"
}' />

@if (Model.Tasks.Count == 0)
{
    <partial name="~/Pages/Shared/_EmptyState.cshtml" model='new Argent.Web.Pages.Shared.EmptyStateModel {
        Icon = "bi-check2-circle",
        Message = "No pending tasks. All caught up!"
    }' />
}
else
{
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Description</th>
                    <th>Priority</th>
                    <th>Due</th>
                    <th>State</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in Model.Tasks)
                {
                    <tr>
                        <td class="font-medium">@(task.Title ?? "Untitled")</td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@(task.Description ?? "")</td>
                        <td>@task.Priority</td>
                        <td class="text-sm text-gray-500 dark:text-gray-400">@(task.DueDate?.ToLocalTime().ToString("g") ?? "")</td>
                        <td>
                            @if (task.State == Argent.Models.Workflows.Execution.UserTaskState.Pending)
                            {
                                <span class="badge bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200 border border-yellow-200 dark:border-yellow-800">Pending</span>
                            }
                            else
                            {
                                <span class="badge bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@task.State</span>
                            }
                        </td>
                        <td class="text-right">
                            <a class="btn-action btn-action-primary" href="/Tasks/Detail/@task.Id" title="View">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
