@page "/Tasks"
@model Argent.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "My Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">My Tasks</h4>
        <p class="text-muted small mb-0">Workflow tasks assigned to you or your roles</p>
    </div>
</div>

@if (Model.Tasks.Count == 0)
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-check2-circle fs-1 text-muted mb-3 d-block"></i>
            <p class="text-muted mb-0">No pending tasks. All caught up!</p>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Priority</th>
                        <th>Due</th>
                        <th>State</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.Tasks)
                    {
                        <tr>
                            <td class="fw-medium">@(task.Title ?? "Untitled")</td>
                            <td class="text-muted small">@(task.Description ?? "")</td>
                            <td>@task.Priority</td>
                            <td class="small">@(task.DueDate?.ToLocalTime().ToString("g") ?? "")</td>
                            <td>
                                @if (task.State == Argent.Models.Workflows.Execution.UserTaskState.Pending)
                                {
                                    <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@task.State</span>
                                }
                            </td>
                            <td class="text-end">
                                <a class="btn btn-outline-primary btn-sm" href="/Tasks/Detail/@task.Id">
                                    <i class="bi bi-eye-fill"></i> View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
