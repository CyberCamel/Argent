@using Argent.Contracts.Workflows.Execution
@using Argent.Infrastructure.Data
@using Argent.Models.DomainObjects
@using Argent.Models.Workflows
@using Argent.WebComponents.Core.Forms
@using Microsoft.EntityFrameworkCore
@inject IUserTaskManager TaskManager
@inject IWorkflowInstanceManager InstanceManager
@inject IDbContextFactory<ArgentDbContext> DbFactory

@if (_task == null)
{
    <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-3 text-sm text-yellow-800 dark:text-yellow-200">Task not found.</div>
}
else
{
    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 mb-4">
        <div class="p-4">
            <h5 class="font-bold mb-3">@(_task.Title ?? "Task")</h5>
            @if (!string.IsNullOrEmpty(_task.Description))
            {
                <p class="text-gray-500 dark:text-gray-400">@_task.Description</p>
            }
            <div class="text-sm text-gray-500 dark:text-gray-400 mb-3">
                <div>Priority: @_task.Priority</div>
                @if (_task.DueDate.HasValue)
                {
                    <div>Due: @_task.DueDate.Value.ToLocalTime().ToString("g")</div>
                }
                <div>State: @_task.State</div>
            </div>
        </div>
    </div>

    @if (_completed)
    {
        <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3 text-sm text-green-800 dark:text-green-200">Task completed successfully.</div>
        <a href="/Tasks" class="px-3 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors">Back to Inbox</a>
    }
    else if (_task.State == Argent.Models.Workflows.Execution.UserTaskState.Pending)
    {
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3 text-sm text-red-800 dark:text-red-200">@_error</div>
        }

        @* Show the form when present. When action buttons also exist, hide the form's
           built-in submit button — the action buttons call TrySaveAsync() themselves
           so the form data is still persisted before completion. *@
        @if (_task.FormId.HasValue)
        {
            <FormHost @ref="_formHost"
                      FormId="@_task.FormId"
                      RecordId="@_instanceRecordId"
                      UserId="@UserId"
                      HideSubmit="@(_actions.Count > 0)"
                      OnSubmit="HandleFormSubmit" />
        }

        @* Action buttons — shown when the outgoing connections are named *@
        @if (_actions.Count > 0)
        {
            <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700 mt-3">
                <div class="p-4">
                    <p class="text-gray-500 dark:text-gray-400 text-sm mb-2">Select an action to complete this task:</p>
                    <div class="flex gap-2 flex-wrap">
                        @foreach (var action in _actions)
                        {
                            <button class="px-3 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" @onclick="() => CompleteWithAction(action)">
                                @action
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
        else if (!_task.FormId.HasValue)
        {
            @* No form and no named actions — show a generic complete button *@
            <button class="px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors" @onclick="() => CompleteWithAction(null)">
                <i class="bi bi-check-lg mr-1"></i>Complete Task
            </button>
        }
    }
}

@code {
    [Parameter] public Guid TaskId { get; set; }
    [Parameter] public string? UserId { get; set; }
    [Parameter] public List<string>? Roles { get; set; }

    private Argent.Models.Workflows.Execution.UserTask? _task;
    private Guid? _instanceRecordId;
    private bool _completed;
    private string? _error;
    private List<string> _actions = [];
    private FormHost? _formHost;

    protected override async Task OnInitializedAsync()
    {
        _task = await TaskManager.GetAsync(TaskId, default);
        if (_task != null)
        {
            var snapshot = await InstanceManager.GetStateAsync(_task.InstanceId, default);
            if (snapshot.RecordId != Guid.Empty)
                _instanceRecordId = snapshot.RecordId;

            _actions = await LoadActionsAsync(_task);
        }
    }

    private async Task<List<string>> LoadActionsAsync(Argent.Models.Workflows.Execution.UserTask task)
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var instance = await db.WorkflowInstances
            .AsNoTracking()
            .FirstOrDefaultAsync(i => i.InstanceId == task.InstanceId);
        if (instance == null) return [];

        var version = await db.WorkflowVersions
            .AsNoTracking()
            .FirstOrDefaultAsync(v => v.Id == instance.VersionId);
        if (version?.Definition == null) return [];

        return version.Definition.Connections
            .Where(c => c.From.Id == task.NodeId && !string.IsNullOrEmpty(c.Label))
            .Select(c => c.Label!)
            .ToList();
    }

    private async Task HandleFormSubmit(DomainRecord record)
    {
        // Only reached when HideSubmit=false (no action buttons), so the form's own
        // Submit button drove validation+save. Just complete the task with no routing.
        await FinishTaskAsync(null);
    }

    private async Task CompleteWithAction(string? action)
    {
        if (_task == null) return;
        _error = null;

        // When a form is present, save it first. Action buttons replace the form's
        // submit button, so we drive save here before completing the task.
        if (_task.FormId.HasValue && _formHost != null)
        {
            var saved = await _formHost.TrySaveAsync();
            if (!saved) return;
        }

        await FinishTaskAsync(action);
    }

    private async Task FinishTaskAsync(string? action)
    {
        if (_task == null) return;
        try
        {
            await TaskManager.CompleteTaskAsync(TaskId, UserId ?? "unknown", Roles ?? [], action, default);
            _completed = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
