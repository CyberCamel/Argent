@using Argent.Contracts.DataSources
@using Argent.Models.DataSources
@inject IDataSourceCatalog Catalog
@inject IDataSourceRunner Runner
@inject NavigationManager Navigation

<div class="mx-auto px-4" style="max-width: 760px;">
    <div class="flex items-center mb-3">
        <a href="/DataSources" class="px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors mr-2"><i class="bi bi-arrow-left"></i></a>
        <h4 class="text-base font-semibold text-gray-900 dark:text-gray-100">@(Id is null ? "New Data Source" : "Edit Data Source")</h4>
    </div>

    <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-700">
        <div class="p-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">System key</label>
                    <input class="form-input font-mono" @bind="_model.Key" disabled="@(Id != null)" placeholder="crm-api" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Kind</label>
                    <select class="form-input" disabled="@(Id != null)"
                            @onchange="(e) => ChangeKind(e.Value?.ToString())">
                        @foreach (var kind in Enum.GetValues<DataSourceKind>())
                        {
                            <option value="@kind" selected="@(_model.Kind == kind)">@kind</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name</label>
                    <input class="form-input" @bind="_model.Name" placeholder="CRM API" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                    <input class="form-input" @bind="_model.Description" />
                </div>
            </div>

            <hr class="my-3 border-gray-200 dark:border-gray-700" />

            @if (_model is SqlDataSource sql)
            {
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Connection string <span class="text-red-600 dark:text-red-400">(secret)</span></label>
                <textarea class="form-input font-mono" rows="2" @bind="sql.ConnectionString"
                          placeholder="Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True"></textarea>
            }
            else if (_model is RestDataSource rest)
            {
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Base URL</label>
                    <input class="form-input" @bind="rest.BaseUrl" placeholder="https://api.example.com/v1" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Auth</label>
                        <select class="form-input" @bind="rest.AuthType">
                            @foreach (var a in Enum.GetValues<DataSourceAuthType>())
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Timeout (s)</label>
                        <input type="number" class="form-input" min="1" @bind="rest.TimeoutSeconds" />
                    </div>
                </div>
                @switch (rest.AuthType)
                {
                    case DataSourceAuthType.ApiKey:
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-1">
                            <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Header name</label>
                                <input class="form-input" @bind="rest.ApiKeyHeader" placeholder="X-Api-Key" /></div>
                            <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Key <span class="text-red-600 dark:text-red-400">(secret)</span></label>
                                <input type="password" class="form-input" @bind="rest.ApiKeyValue" /></div>
                        </div>
                        break;
                    case DataSourceAuthType.Basic:
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-1">
                            <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
                                <input class="form-input" @bind="rest.Username" /></div>
                            <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password <span class="text-red-600 dark:text-red-400">(secret)</span></label>
                                <input type="password" class="form-input" @bind="rest.Password" /></div>
                        </div>
                        break;
                    case DataSourceAuthType.Bearer:
                        <div class="mt-1"><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Bearer token <span class="text-red-600 dark:text-red-400">(secret)</span></label>
                            <input type="password" class="form-input" @bind="rest.BearerToken" /></div>
                        break;
                }
            }
            else if (_model is SoapDataSource soap)
            {
                <div class="mb-3">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Endpoint URL</label>
                    <input class="form-input" @bind="soap.EndpointUrl" placeholder="https://service.example.com/Service.svc" />
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Auth</label>
                        <select class="form-input" @bind="soap.AuthType">
                            <option value="@DataSourceAuthType.None">None</option>
                            <option value="@DataSourceAuthType.Basic">Basic</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Timeout (s)</label>
                        <input type="number" class="form-input" min="1" @bind="soap.TimeoutSeconds" />
                    </div>
                </div>
                @if (soap.AuthType == DataSourceAuthType.Basic)
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-1">
                        <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
                            <input class="form-input" @bind="soap.Username" /></div>
                        <div><label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password <span class="text-red-600 dark:text-red-400">(secret)</span></label>
                            <input type="password" class="form-input" @bind="soap.Password" /></div>
                    </div>
                }
            }

            @if (_testResult is { } test)
            {
                <div class="@(test.Success ? "bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800" : "bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800") rounded-lg p-3 mt-3 mb-0 py-2 text-sm @(test.Success ? "text-green-800 dark:text-green-200" : "text-red-800 dark:text-red-200")">
                    <i class="bi @(test.Success ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                    @test.Message <span class="text-gray-500 dark:text-gray-400">(@test.ElapsedMilliseconds ms)</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3 text-sm text-red-800 dark:text-red-200 mt-3 mb-0"><i class="bi bi-exclamation-triangle-fill"></i> @_error</div>
            }
        </div>
        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 flex gap-2">
            <button class="px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors" @onclick="Save" disabled="@_busy"><i class="bi bi-save-fill"></i> Save</button>
            <button class="px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors" @onclick="Test" disabled="@_busy">
                @if (_busy) { <span class="inline-block w-4 h-4 border-2 border-gray-300 dark:border-gray-600 border-t-indigo-600 dark:border-t-indigo-400 rounded-full animate-spin mr-1"></span> }
                <i class="bi bi-plug-fill"></i> Test connection
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private DataSource _model = new SqlDataSource();
    private DataSourceTestResult? _testResult;
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (Id is { } id)
            _model = await Catalog.GetAsync(id) ?? new SqlDataSource();
    }

    private void ChangeKind(string? value)
    {
        if (!Enum.TryParse<DataSourceKind>(value, out var kind) || kind == _model.Kind) return;
        // Preserve shared metadata when switching connection type.
        DataSource next = kind switch
        {
            DataSourceKind.Rest => new RestDataSource(),
            DataSourceKind.Soap => new SoapDataSource(),
            _ => new SqlDataSource()
        };
        next.Key = _model.Key;
        next.Name = _model.Name;
        next.Description = _model.Description;
        _model = next;
        _testResult = null;
    }

    private async Task Save()
    {
        _busy = true; _error = null;
        try
        {
            await Catalog.SaveAsync(_model, Id);
            Navigation.NavigateTo("/DataSources", forceLoad: true);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Test()
    {
        _busy = true; _error = null; _testResult = null;
        try { _testResult = await Runner.TestAsync(_model); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
