@using Argent.Contracts.DataSources
@using Argent.Models.DataSources
@inject IDataSourceCatalog Catalog
@inject IDataSourceRunner Runner
@inject NavigationManager Navigation

<div class="container" style="max-width: 760px;">
    <div class="d-flex align-items-center mb-3">
        <a href="/DataSources" class="btn btn-outline-secondary btn-sm me-2"><i class="bi bi-arrow-left"></i></a>
        <h4 class="mb-0">@(Id is null ? "New Data Source" : "Edit Data Source")</h4>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label small text-muted">System key</label>
                    <input class="form-control font-monospace" @bind="_model.Key" disabled="@(Id != null)" placeholder="crm-api" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Kind</label>
                    <select class="form-select" disabled="@(Id != null)"
                            @onchange="(e) => ChangeKind(e.Value?.ToString())">
                        @foreach (var kind in Enum.GetValues<DataSourceKind>())
                        {
                            <option value="@kind" selected="@(_model.Kind == kind)">@kind</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Name</label>
                    <input class="form-control" @bind="_model.Name" placeholder="CRM API" />
                </div>
                <div class="col-md-6">
                    <label class="form-label small text-muted">Description</label>
                    <input class="form-control" @bind="_model.Description" />
                </div>
            </div>

            <hr />

            @if (_model is SqlDataSource sql)
            {
                <label class="form-label small text-muted">Connection string <span class="text-danger">(secret)</span></label>
                <textarea class="form-control font-monospace" rows="2" @bind="sql.ConnectionString"
                          placeholder="Server=...;Database=...;User Id=...;Password=...;TrustServerCertificate=True"></textarea>
            }
            else if (_model is RestDataSource rest)
            {
                <div class="mb-3">
                    <label class="form-label small text-muted">Base URL</label>
                    <input class="form-control" @bind="rest.BaseUrl" placeholder="https://api.example.com/v1" />
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted">Auth</label>
                        <select class="form-select" @bind="rest.AuthType">
                            @foreach (var a in Enum.GetValues<DataSourceAuthType>())
                            {
                                <option value="@a">@a</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted">Timeout (s)</label>
                        <input type="number" class="form-control" min="1" @bind="rest.TimeoutSeconds" />
                    </div>
                </div>
                @switch (rest.AuthType)
                {
                    case DataSourceAuthType.ApiKey:
                        <div class="row g-3 mt-1">
                            <div class="col-md-6"><label class="form-label small text-muted">Header name</label>
                                <input class="form-control" @bind="rest.ApiKeyHeader" placeholder="X-Api-Key" /></div>
                            <div class="col-md-6"><label class="form-label small text-muted">Key <span class="text-danger">(secret)</span></label>
                                <input type="password" class="form-control" @bind="rest.ApiKeyValue" /></div>
                        </div>
                        break;
                    case DataSourceAuthType.Basic:
                        <div class="row g-3 mt-1">
                            <div class="col-md-6"><label class="form-label small text-muted">Username</label>
                                <input class="form-control" @bind="rest.Username" /></div>
                            <div class="col-md-6"><label class="form-label small text-muted">Password <span class="text-danger">(secret)</span></label>
                                <input type="password" class="form-control" @bind="rest.Password" /></div>
                        </div>
                        break;
                    case DataSourceAuthType.Bearer:
                        <div class="mt-1"><label class="form-label small text-muted">Bearer token <span class="text-danger">(secret)</span></label>
                            <input type="password" class="form-control" @bind="rest.BearerToken" /></div>
                        break;
                }
            }
            else if (_model is SoapDataSource soap)
            {
                <div class="mb-3">
                    <label class="form-label small text-muted">Endpoint URL</label>
                    <input class="form-control" @bind="soap.EndpointUrl" placeholder="https://service.example.com/Service.svc" />
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small text-muted">Auth</label>
                        <select class="form-select" @bind="soap.AuthType">
                            <option value="@DataSourceAuthType.None">None</option>
                            <option value="@DataSourceAuthType.Basic">Basic</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small text-muted">Timeout (s)</label>
                        <input type="number" class="form-control" min="1" @bind="soap.TimeoutSeconds" />
                    </div>
                </div>
                @if (soap.AuthType == DataSourceAuthType.Basic)
                {
                    <div class="row g-3 mt-1">
                        <div class="col-md-6"><label class="form-label small text-muted">Username</label>
                            <input class="form-control" @bind="soap.Username" /></div>
                        <div class="col-md-6"><label class="form-label small text-muted">Password <span class="text-danger">(secret)</span></label>
                            <input type="password" class="form-control" @bind="soap.Password" /></div>
                    </div>
                }
            }

            @if (_testResult is { } test)
            {
                <div class="alert @(test.Success ? "alert-success" : "alert-danger") mt-3 mb-0 py-2 small">
                    <i class="bi @(test.Success ? "bi-check-circle-fill" : "bi-x-circle-fill")"></i>
                    @test.Message <span class="text-muted">(@test.ElapsedMilliseconds ms)</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger mt-3 mb-0 py-2 small"><i class="bi bi-exclamation-triangle-fill"></i> @_error</div>
            }
        </div>
        <div class="card-footer d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save" disabled="@_busy"><i class="bi bi-save-fill"></i> Save</button>
            <button class="btn btn-outline-secondary" @onclick="Test" disabled="@_busy">
                @if (_busy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="bi bi-plug-fill"></i> Test connection
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private DataSource _model = new SqlDataSource();
    private DataSourceTestResult? _testResult;
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        if (Id is { } id)
            _model = await Catalog.GetAsync(id) ?? new SqlDataSource();
    }

    private void ChangeKind(string? value)
    {
        if (!Enum.TryParse<DataSourceKind>(value, out var kind) || kind == _model.Kind) return;
        // Preserve shared metadata when switching connection type.
        DataSource next = kind switch
        {
            DataSourceKind.Rest => new RestDataSource(),
            DataSourceKind.Soap => new SoapDataSource(),
            _ => new SqlDataSource()
        };
        next.Key = _model.Key;
        next.Name = _model.Name;
        next.Description = _model.Description;
        _model = next;
        _testResult = null;
    }

    private async Task Save()
    {
        _busy = true; _error = null;
        try
        {
            await Catalog.SaveAsync(_model, Id);
            Navigation.NavigateTo("/DataSources", forceLoad: true);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Test()
    {
        _busy = true; _error = null; _testResult = null;
        try { _testResult = await Runner.TestAsync(_model); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }
}
