@using System.Text.Json
@using Argent.Core.Forms.Components
@using Argent.Contracts
@using Argent.Core.Forms.Components.Base
@using Argent.Logic
@inject IComponentRegistry Registry
@inject IFormContext Context

@if (_rootMetadata is not null)
{
    @* This is what was missing! Every child now sees the 'Context' *@
    <CascadingValue Value="Context">
        @{
            var componentType = Registry.Resolve(_rootMetadata.Type);
            <DynamicComponent Type="componentType" Parameters="_parameters" />
        }
    </CascadingValue>
}
else if (!string.IsNullOrEmpty(JsonConfig))
{
    <div class="alert alert-danger">Failed to parse JSON Config</div>
}

@code {
    [Parameter] public string? JsonConfig { get; set; }
    [Parameter] public FormComponent? Metadata { get; set; }

    private FormComponent? _rootMetadata;
    private Dictionary<string, object> _parameters = new();

    protected override void OnParametersSet()
    {
        _rootMetadata = Metadata ?? (string.IsNullOrEmpty(JsonConfig)
            ? null
            : JsonSerializer.Deserialize<FormComponent>(JsonConfig, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }));

        if (_rootMetadata != null)
        {
            _parameters = new Dictionary<string, object> { { "Metadata", _rootMetadata } };
        }
    }
}