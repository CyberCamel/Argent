@using Argent.WebComponents
@inherits FormLayoutComponentBase

<div class="divide-y divide-gray-200 dark:divide-gray-700 border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden @Metadata.CssClass" id="@($"accordion-{Metadata.Id}")">
    @for (int i = 0; i < Metadata.Items.Count; i++)
    {
        var child = Metadata.Items[i];
        var isOpen = Metadata.MultiExpand
            ? OpenItems.Contains(i)
            : i == ActiveIndex;
        var itemId = $"accordion-item-{Metadata.Id}-{i}";

        <div>
            <h2 class="mb-0">
                <button class="flex items-center justify-between w-full px-4 py-3 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors text-left @(isOpen ? "" : "")"
                        type="button"
                        @onclick="() => ToggleItem(i)">
                    @GetItemTitle(child)
                    <i class="bi bi-chevron-down text-xs text-gray-400 transition-transform @(isOpen ? "rotate-180" : "")"></i>
                </button>
            </h2>
            <div class="@(isOpen ? "block" : "hidden")">
                <div class="px-4 py-3">
                    @if (isOpen)
                    {
                        <ArgentRenderer Metadata="child" />
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private int _activeIndex;
    private HashSet<int> _openItems = [];

    private int ActiveIndex
    {
        get => Math.Max(0, Math.Min(_activeIndex, Metadata.Items.Count - 1));
        set => _activeIndex = value;
    }

    private HashSet<int> OpenItems
    {
        get => _openItems;
        set => _openItems = value;
    }

    protected override void OnInitialized()
    {
        _activeIndex = Metadata.ActiveItem;
        if (Metadata.MultiExpand && Metadata.DefaultOpen)
        {
            _openItems = [0];
        }
    }

    private void ToggleItem(int index)
    {
        if (Metadata.MultiExpand)
        {
            if (_openItems.Contains(index))
                _openItems.Remove(index);
            else
                _openItems.Add(index);
        }
        else
        {
            _activeIndex = _activeIndex == index ? -1 : index;
        }
        if (OnMetadataChanged.HasDelegate)
            OnMetadataChanged.InvokeAsync(Metadata);
    }

    private string GetItemTitle(Models.Forms.Components.Base.FormComponent child)
    {
        if (child is Models.Forms.Components.Base.FormLayout layout && !string.IsNullOrEmpty(layout.Title))
            return layout.Title;
        if (child is Models.Forms.Components.Base.FormField field && !string.IsNullOrEmpty(field.FieldLabel))
            return field.FieldLabel;
        return $"Section {Metadata.Items.IndexOf(child) + 1}";
    }
}