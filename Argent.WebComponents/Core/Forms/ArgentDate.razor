@inherits FormInputComponentBase

@if (IsVisible)
{
    <div class="mb-3 @Metadata.CssClass">
        @{var _errors = Errors.ToList();}
        <label class="form-label">
            @Metadata.FieldLabel
            @if (Context.IsRequired(Metadata))
            {
                <span class="text-danger">*</span>
            }
        </label>
        <input type="@(Metadata.ShowTime ? "datetime-local" : "date")"
               class="form-control @(_errors.Count > 0 ? "is-invalid" : "")"
               value="@CurrentValue"
               @onchange="(e) => OnValueChanged(e.Value)"
               min="@Metadata.MinDate"
               max="@Metadata.MaxDate"
               disabled="@Metadata.Disabled"
               readOnly="@Metadata.ReadOnly" />
        @if (Metadata.Description != null)
        {
            <div class="form-text">@Metadata.Description</div>
        }
        @if (_errors.Count > 0)
        {
            <div class="invalid-feedback d-block">
                @foreach (var err in _errors) { <div>@err</div> }
            </div>
        }
    </div>
}

@code {
    private bool IsVisible => Context.IsVisible(Metadata);
    private string? CurrentValue => Context.GetValue<string>(Metadata.Name ?? Metadata.Id);
    private IEnumerable<string> Errors => Context.GetErrors(Metadata);

    private void OnValueChanged(object? val)
        => Context.SetValue(Metadata.Name ?? Metadata.Id, val?.ToString());
}
