@inherits FormInputComponentBase

@if (IsVisible)
{
    <div class="mb-3 @Metadata.CssClass">
        @{var _errors = Errors.ToList();}
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            @Metadata.FieldLabel
            @if (Context.IsRequired(Metadata))
            {
                <span class="text-red-600 dark:text-red-400">*</span>
            }
        </label>
        <input type="number"
               class="form-input @(_errors.Count > 0 ? "border-red-500 ring-1 ring-red-500" : "")"
               value="@CurrentValue"
               @onchange="(e) => OnValueChanged(e.Value)"
               placeholder="@Metadata.Placeholder"
               step="@(Metadata.Step?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "any")"
               min="@Metadata.Min"
               max="@Metadata.Max"
               disabled="@Metadata.Disabled"
               readOnly="@Metadata.ReadOnly" />
        @if (Metadata.Description != null)
        {
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">@Metadata.Description</div>
        }
        @if (_errors.Count > 0)
        {
            <div class="text-red-600 dark:text-red-400 text-sm mt-1">
                @foreach (var err in _errors) { <div>@err</div> }
            </div>
        }
    </div>
}

@code {
    private bool IsVisible => Context.IsVisible(Metadata);
    private IEnumerable<string> Errors => Context.GetErrors(Metadata);

    private string? CurrentValue
    {
        get
        {
            var raw = Context.GetValue(Metadata.Name ?? Metadata.Id);
            if (raw == null) return null;
            if (Metadata.Precision.HasValue && double.TryParse(raw.ToString(), out var d))
                return d.ToString("F" + Metadata.Precision.Value, System.Globalization.CultureInfo.InvariantCulture);
            return raw.ToString();
        }
    }

    private void OnValueChanged(object? val)
    {
        if (double.TryParse(val?.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out var result))
            Context.SetValue(Metadata.Name ?? Metadata.Id, result);
        else
            Context.SetValue(Metadata.Name ?? Metadata.Id, null);
    }
}
