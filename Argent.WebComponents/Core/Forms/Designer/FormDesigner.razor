@using Argent.Models.Forms.Components.Base
@using Argent.Models.DomainObjects
@using Argent.Contracts.DomainObjects
@using Argent.Runtime.Forms
@using Argent.Runtime.Forms.Modeling
@using Argent.WebComponents.Core.Forms
@using Argent.WebComponents.Authorization
@implements IDisposable
@inject FormDesignerService State
@inject NavigationManager Navigation
@inject IDomainObjectDefinitionService DomainObjectDefinitions

<style>
    .fd-dropzone { height: 0; overflow: hidden; border-radius: 4px; transition: height 0.1s, background 0.1s; }
    .fd-dropzone.visible { height: 10px; margin: 2px 0; background: #e9ecef; }
    .fd-dropzone.visible.active { background: #0d6efd; }
    .fd-dropzone-inside.visible { height: 34px; border: 2px dashed #adb5bd; background: #f8f9fa; display: flex; align-items: center; justify-content: center; color: #6c757d; font-size: 0.75rem; }
    .fd-dropzone-inside.visible.active { border-color: #0d6efd; background: #e7f1ff; color: #0d6efd; }

    .fd-node { position: relative; border: 1px solid #dee2e6; border-radius: 6px; background: #fff; margin: 2px 0; }
    .fd-node.selected { border-color: #0d6efd; box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.15); }
    .fd-node-container { background: #fbfcfe; }

    .fd-node-header { display: flex; align-items: center; gap: 6px; padding: 2px 8px; font-size: 0.72rem; color: #6c757d; border-bottom: 1px dashed #e9ecef; cursor: grab; user-select: none; }
    .fd-node-header:active { cursor: grabbing; }
    .fd-grip { color: #adb5bd; }
    .fd-node-title { font-weight: 600; color: #495057; }
    .fd-node-meta { font-family: var(--bs-font-monospace); font-size: 0.65rem; color: #adb5bd; }
    .fd-node-actions { margin-left: auto; display: none; gap: 2px; }
    .fd-node:hover > .fd-node-header > .fd-node-actions,
    .fd-node.selected > .fd-node-header > .fd-node-actions { display: inline-flex; }
    .fd-action { border: none; background: none; padding: 0 3px; font-size: 0.72rem; color: #6c757d; line-height: 1.4; border-radius: 3px; }
    .fd-action:hover { background: #e9ecef; color: #0d6efd; }
    .fd-action-danger:hover { color: #dc3545; }

    .fd-node-preview { padding: 6px 10px 2px; pointer-events: none; }
    .fd-container-body { padding: 6px 10px; }
    .fd-container-hint { padding: 1px 10px; font-size: 0.65rem; color: #adb5bd; font-style: italic; }
    .fd-columns { display: flex; gap: 8px; padding: 6px 10px; }
    .fd-column { flex: 1; min-width: 0; border: 1px dashed #e9ecef; border-radius: 4px; padding: 4px; }
    .fd-column-label { font-size: 0.65rem; color: #adb5bd; text-transform: uppercase; margin-bottom: 2px; }

    .fd-toolbox-item { cursor: grab; }
    .fd-toolbox-item:active { cursor: grabbing; }
    .fd-toolbox-category { font-size: 0.68rem; font-weight: 600; text-transform: uppercase; color: #adb5bd; margin: 8px 0 4px; }

    .property-section { border-bottom: 1px solid #dee2e6; padding-bottom: 0.75rem; margin-bottom: 0.75rem; }
    .property-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; color: #6c757d; margin-bottom: 0.5rem; }
</style>

<div class="d-flex flex-column h-100">
    @* ── Toolbar ─────────────────────────────────────────────── *@
    <div class="d-flex align-items-center gap-2 p-2 border-bottom bg-white" style="min-height: 42px;">
        <a href="/Forms" class="btn btn-outline-secondary btn-sm me-1" title="Back to forms">
            <i class="bi bi-arrow-left"></i>
        </a>
        <select class="form-select form-select-sm @(string.IsNullOrEmpty(State.Definition.ObjectKey) ? "border-warning" : "")"
                style="max-width: 200px;"
                @onchange="OnObjectKeyChanged"
                title="Domain object this form is bound to (required)">
            <option value="">— domain object —</option>
            @foreach (var obj in _objectCatalog)
            {
                <option value="@obj.Key" selected="@(State.Definition.ObjectKey == obj.Key)">@obj.Name</option>
            }
        </select>
        <input type="text" class="form-control form-control-sm" style="max-width: 200px;"
               value="@State.Name"
               @onchange="(e) => { State.Name = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }"
               placeholder="Form name" />
        <input type="text" class="form-control form-control-sm" style="max-width: 300px;"
               value="@State.Description"
               @onchange="(e) => { State.Description = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }"
               placeholder="Description (optional)" />
        <button class="btn btn-outline-primary btn-sm" @onclick="HandleSave" disabled="@_isSaving">
            @if (_isSaving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            <i class="bi bi-save-fill"></i> Save
        </button>
        <span title="@(State.HasUnsavedChanges ? "Unsaved changes" : "Saved")"
              class="@(State.HasUnsavedChanges ? "text-warning" : "text-success")">
            <i class="bi @(State.HasUnsavedChanges ? "bi-circle-fill" : "bi-check-circle-fill")"></i>
        </span>
        <button class="btn btn-outline-success btn-sm" @onclick="() => _showPreview = true">
            <i class="bi bi-eye-fill"></i> Preview
        </button>
        @if (!string.IsNullOrEmpty(_saveError))
        {
            <span class="text-danger small ms-2"><i class="bi bi-exclamation-triangle-fill"></i> @_saveError</span>
        }
    </div>

    <div class="d-flex flex-grow-1 overflow-hidden">
        @* ── Toolbox ─────────────────────────────────────────── *@
        <div class="border-end bg-light p-2" style="width: 200px; min-width: 200px; overflow-y: auto;">
            @foreach (var category in FormDesignerService.ToolboxItems.GroupBy(t => t.Category))
            {
                <div class="fd-toolbox-category">@category.Key</div>
                @foreach (var item in category)
                {
                    <div draggable="true"
                         @ondragstart="() => State.BeginDragAdd(item.TypeName)"
                         @ondragend="() => State.EndDrag()"
                         @onclick="() => State.AddFromToolbox(item.TypeName)"
                         class="fd-toolbox-item btn btn-outline-secondary btn-sm w-100 text-start mb-1"
                         style="font-size: 0.85rem;"
                         title="Drag to the canvas, or click to append">
                        <i class="bi @item.Icon me-2"></i> @item.DisplayName
                    </div>
                }
            }
        </div>

        @* ── Canvas ──────────────────────────────────────────── *@
        <div class="flex-grow-1 overflow-auto p-3" tabindex="0"
             @onkeydown="HandleKeyDown"
             @onclick="() => State.SelectComponent(null)">
            <CascadingValue Value="_designContext">
                @if (State.Definition.Components.Count == 0)
                {
                    <div class="d-flex align-items-center justify-content-center text-muted border rounded"
                         style="min-height: 300px; border-style: dashed !important;"
                         @ondragenter="() => State.SetHover(RootEnd)"
                         @ondragleave="() => State.ClearHover(RootEnd)"
                         @ondrop="() => State.Drop(RootEnd)"
                         @ondragover:preventDefault>
                        <div class="text-center">
                            <i class="bi bi-hand-index" style="font-size: 2rem;"></i>
                            <p class="mt-2 mb-0">Drag a component from the toolbox</p>
                        </div>
                    </div>
                }
                else
                {
                    @for (int i = 0; i < State.Definition.Components.Count; i++)
                    {
                        var index = i;
                        <DropZone State="@State" Target="@(new DropTarget(null, index))" />
                        <DesignerNode State="@State" Component="@State.Definition.Components[index]" />
                    }
                    <DropZone State="@State" Inside="true" Target="@RootEnd" />
                }
            </CascadingValue>
        </div>

        @* ── Property panel ──────────────────────────────────── *@
        <div class="border-start bg-light p-3" style="width: 360px; min-width: 360px; overflow-y: auto;">
            <h6 class="text-muted mb-3"><i class="bi bi-sliders"></i> Properties</h6>
            <FormPropertyPanel State="@State" />

            @if (State.StoredFormId.HasValue)
            {
                <hr />
                <ResourceSharingPanel ResourceType="Form" ResourceId="@State.StoredFormId.Value" />
            }
        </div>
    </div>
</div>

@* ── Preview modal ───────────────────────────────────────────── *@
@if (_showPreview)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);"
         @onclick="() => _showPreview = false">
        <div class="modal-dialog modal-lg modal-dialog-scrollable" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Preview: @State.Name</h5>
                    <button type="button" class="btn-close" @onclick="() => _showPreview = false"></button>
                </div>
                <div class="modal-body">
                    <ArgentForm Definition="@State.Definition" SuccessMessage="Validation passed." />
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? FormId { get; set; }

    private bool _showPreview;
    private bool _isSaving;
    private string? _saveError;
    private readonly DesignerFormContext _designContext = new(new ConditionEvaluator());
    private IReadOnlyList<DomainObjectSummary> _objectCatalog = [];

    private static DropTarget RootEnd => new(null, int.MaxValue);

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        _objectCatalog = await DomainObjectDefinitions.GetSummariesAsync();
        if (FormId.HasValue)
            await State.LoadAsync(FormId.Value);
    }

    private void OnObjectKeyChanged(ChangeEventArgs e)
    {
        State.Definition.ObjectKey = e.Value?.ToString() ?? string.Empty;
        State.MarkDirty();
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }

    private async Task HandleSave()
    {
        _isSaving = true;
        _saveError = null;
        try
        {
            var isNew = !State.StoredFormId.HasValue;
            await State.SaveAsync();
            if (isNew && State.StoredFormId.HasValue)
                Navigation.NavigateTo($"/Forms/Edit/{State.StoredFormId}", forceLoad: true);
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        // Only fires from the canvas (it has focus there) — typing in the
        // property panel can no longer delete the selected component.
        if (e.Key == "Delete")
            State.RemoveSelected();
        else if (e.Key == "Escape")
            State.SelectComponent(null);
    }
}
