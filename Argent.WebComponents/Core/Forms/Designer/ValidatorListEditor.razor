@using Argent.Models.Forms.Components.Base
@using Argent.Models.Forms.Components.Configuration
@using Argent.Runtime.Forms.Modeling

@for (int i = 0; i < Field.Validators.Count; i++)
{
    var idx = i;
    var rule = Field.Validators[idx];

    <div class="border rounded p-2 mb-2" style="background: #f8f9fa;">
        <div class="d-flex align-items-center mb-1">
            <span class="badge bg-primary" style="font-size: 0.65rem;">@RuleLabel(rule)</span>
            <button class="btn btn-sm py-0 px-1 ms-auto" title="Remove rule"
                    @onclick="() => { Field.Validators.RemoveAt(idx); State.MarkDirty(); }">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>

        @switch (rule)
        {
            case LengthValidator len:
                <div class="row g-1 mb-1">
                    <div class="col-6">
                        <input type="number" class="form-control form-control-sm" placeholder="Min length"
                               value="@len.Min" @onchange="(e) => { len.Min = ParseInt(e.Value); State.MarkDirty(); }" />
                    </div>
                    <div class="col-6">
                        <input type="number" class="form-control form-control-sm" placeholder="Max length"
                               value="@len.Max" @onchange="(e) => { len.Max = ParseInt(e.Value); State.MarkDirty(); }" />
                    </div>
                </div>
                break;

            case RangeValidator range:
                <div class="row g-1 mb-1">
                    <div class="col-6">
                        <input type="number" class="form-control form-control-sm" placeholder="Min"
                               value="@range.Min" @onchange="(e) => { range.Min = ParseDouble(e.Value); State.MarkDirty(); }" />
                    </div>
                    <div class="col-6">
                        <input type="number" class="form-control form-control-sm" placeholder="Max"
                               value="@range.Max" @onchange="(e) => { range.Max = ParseDouble(e.Value); State.MarkDirty(); }" />
                    </div>
                </div>
                break;

            case RegexValidator regex:
                <input type="text" class="form-control form-control-sm mb-1 font-monospace" placeholder="^pattern$"
                       value="@regex.Pattern" @onchange="(e) => { regex.Pattern = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }" />
                break;

            case CompareFieldValidator cmp:
                <div class="row g-1 mb-1">
                    <div class="col-7">
                        <select class="form-select form-select-sm"
                                @onchange="(e) => { cmp.OtherField = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }">
                            <option value="">-- other field --</option>
                            @foreach (var name in State.FieldNames().Where(n => n != Field.Name))
                            {
                                <option value="@name" selected="@(cmp.OtherField == name)">@name</option>
                            }
                        </select>
                    </div>
                    <div class="col-5">
                        <select class="form-select form-select-sm"
                                @onchange='(e) => { cmp.Operator = e.Value?.ToString() ?? "=="; State.MarkDirty(); }'>
                            @foreach (var op in CompareOperators.All)
                            {
                                <option value="@op" selected="@(cmp.Operator == op)">@op</option>
                            }
                        </select>
                    </div>
                </div>
                break;

            case ExpressionValidator expr:
                <input type="text" class="form-control form-control-sm mb-1 font-monospace"
                       placeholder="e.g. value > other_field"
                       value="@expr.Expression" @onchange="(e) => { expr.Expression = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }" />
                <div class="form-text" style="font-size: 0.65rem;">NCalc expression; the field's value is bound to <code>value</code>, other fields by name.</div>
                break;
        }

        <input type="text" class="form-control form-control-sm" placeholder="Custom error message (optional)"
               value="@rule.Message" @onchange="(e) => { rule.Message = NullIfEmpty(e.Value); State.MarkDirty(); }" />
    </div>
}

<div class="d-flex gap-1">
    <select class="form-select form-select-sm" @bind="_newRuleType" style="font-size: 0.75rem;">
        <option value="length">Length</option>
        <option value="range">Numeric range</option>
        <option value="regex">Pattern (regex)</option>
        <option value="email">Email</option>
        <option value="url">URL</option>
        <option value="compareField">Compare to field</option>
        <option value="expression">Expression</option>
    </select>
    <button class="btn btn-sm btn-outline-primary" @onclick="AddRule" style="white-space: nowrap;">
        <i class="bi bi-plus"></i> Add rule
    </button>
</div>

@code {
    [Parameter] public required FormField Field { get; set; }
    [Parameter] public required FormDesignerService State { get; set; }

    private string _newRuleType = "length";

    private void AddRule()
    {
        FieldValidator rule = _newRuleType switch
        {
            "range" => new RangeValidator(),
            "regex" => new RegexValidator(),
            "email" => new EmailValidator(),
            "url" => new UrlValidator(),
            "compareField" => new CompareFieldValidator(),
            "expression" => new ExpressionValidator(),
            _ => new LengthValidator()
        };
        Field.Validators.Add(rule);
        State.MarkDirty();
    }

    private static string RuleLabel(FieldValidator rule) => rule switch
    {
        LengthValidator => "Length",
        RangeValidator => "Range",
        RegexValidator => "Pattern",
        EmailValidator => "Email",
        UrlValidator => "URL",
        CompareFieldValidator => "Compare",
        ExpressionValidator => "Expression",
        _ => "Rule"
    };

    private static int? ParseInt(object? value) =>
        int.TryParse(value?.ToString(), out var i) ? i : null;

    private static double? ParseDouble(object? value) =>
        double.TryParse(value?.ToString(), out var d) ? d : null;

    private static string? NullIfEmpty(object? value)
    {
        var s = value?.ToString();
        return string.IsNullOrWhiteSpace(s) ? null : s;
    }
}
