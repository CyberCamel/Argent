@using Argent.Models.Forms.Components.Configuration
@using Argent.Models.Forms.Components.Base

<div class="condition-builder border rounded p-2 mb-2" style="background: #f8f9fa;">
    @if (Condition == null)
    {
        <div class="d-flex gap-1 flex-wrap">
            <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="AddCompare" style="font-size: 0.7rem;">
                <i class="bi bi-plus"></i> Compare
            </button>
            <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="AddAnd" style="font-size: 0.7rem;">
                <i class="bi bi-plus"></i> And
            </button>
            <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="AddOr" style="font-size: 0.7rem;">
                <i class="bi bi-plus"></i> Or
            </button>
            <button class="btn btn-sm btn-outline-primary py-0 px-1" @onclick="AddExpression" style="font-size: 0.7rem;">
                <i class="bi bi-plus"></i> Expression
            </button>
        </div>
    }
    else if (Condition is CompareCondition compare)
    {
        <div class="d-flex gap-1 align-items-center flex-wrap">
            <select class="form-select form-select-sm" style="width: auto; font-size: 0.75rem;"
                    @onchange="@((e) => { compare.Field = e.Value?.ToString() ?? ""; NotifyChanged(); })">
                <option value="">-- field --</option>
                @if (Fields != null)
                {
                    @foreach (var f in Fields)
                    {
                        <option value="@f" selected="@(compare.Field == f)">@f</option>
                    }
                }
                <option value="" disabled>───</option>
                <option value="__custom__" selected="@(compare.Field != "" && (Fields == null || !Fields.Contains(compare.Field)))">Custom...</option>
            </select>
            @if (Fields == null || !Fields.Contains(compare.Field))
            {
                <input type="text" class="form-control form-control-sm" style="width: 100px; font-size: 0.75rem;"
                       value="@(compare.Field)"
                       @oninput="(e) => { compare.Field = e.Value?.ToString() ?? string.Empty; }"
                       @onchange="() => NotifyChanged()"
                       placeholder="field name" />
            }
            <select class="form-select form-select-sm" style="width: auto; font-size: 0.75rem;"
                    @onchange="@((e) => { compare.Operator = e.Value?.ToString() ?? "=="; NotifyChanged(); })">
                @foreach (var op in CompareOperators.All)
                {
                    <option value="@op" selected="@(compare.Operator == op)">@op</option>
                }
            </select>
            @if (compare.Operator is "isEmpty" or "isNotEmpty")
            {
                @* No value input needed for these operators *@
            }
            else if (compare.Operator is "in" or "notIn")
            {
                <input type="text" class="form-control form-control-sm" style="width: 150px; font-size: 0.75rem;"
                       value="@(compare.Value?.ToString() ?? "")"
                       @oninput="(e) => { compare.Value = e.Value?.ToString(); }"
                       @onchange="() => NotifyChanged()"
                       placeholder="comma,separated,values" />
            }
            else
            {
                <input type="text" class="form-control form-control-sm" style="width: 120px; font-size: 0.75rem;"
                       value="@(compare.Value?.ToString() ?? "")"
                       @oninput="(e) => { compare.Value = e.Value?.ToString(); }"
                       @onchange="() => NotifyChanged()"
                       placeholder="value" />
            }
            <button class="btn btn-sm py-0 px-1" @onclick="Remove" style="font-size: 0.65rem;">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>
    }
    else if (Condition is AndCondition and)
    {
        <div class="mb-1">
            <span class="badge bg-secondary" style="font-size: 0.65rem;">ALL of:</span>
            <button class="btn btn-sm py-0 px-1 float-end" @onclick="Remove" style="font-size: 0.65rem;">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>
        @for (int i = 0; i < and.All.Count; i++)
        {
            var sub = and.All[i];
            <div class="ms-3 mb-1 border-start ps-2" style="border-left: 2px solid #0d6efd !important;">
                <ConditionBuilder Condition="sub" Fields="@Fields" OnChanged="() => NotifyChanged()" />
            </div>
        }
        <button class="btn btn-sm btn-outline-primary py-0 px-1 mt-1" @onclick="() => { and.All.Add(new CompareCondition()); NotifyChanged(); }" style="font-size: 0.7rem;">
            <i class="bi bi-plus"></i> Add condition
        </button>
    }
    else if (Condition is OrCondition or)
    {
        <div class="mb-1">
            <span class="badge bg-secondary" style="font-size: 0.65rem;">ANY of:</span>
            <button class="btn btn-sm py-0 px-1 float-end" @onclick="Remove" style="font-size: 0.65rem;">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>
        @for (int i = 0; i < or.Any.Count; i++)
        {
            var sub = or.Any[i];
            <div class="ms-3 mb-1 border-start ps-2" style="border-left: 2px solid #198754 !important;">
                <ConditionBuilder Condition="sub" Fields="@Fields" OnChanged="() => NotifyChanged()" />
            </div>
        }
        <button class="btn btn-sm btn-outline-primary py-0 px-1 mt-1" @onclick="() => { or.Any.Add(new CompareCondition()); NotifyChanged(); }" style="font-size: 0.7rem;">
            <i class="bi bi-plus"></i> Add condition
        </button>
    }
    else if (Condition is NotCondition not)
    {
        <div class="mb-1">
            <span class="badge bg-danger" style="font-size: 0.65rem;">NOT:</span>
            <button class="btn btn-sm py-0 px-1 float-end" @onclick="Remove" style="font-size: 0.65rem;">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>
        <div class="ms-3 mb-1 border-start ps-2" style="border-left: 2px solid #dc3545 !important;">
            <ConditionBuilder Condition="not.Not" Fields="@Fields" OnChanged="() => NotifyChanged()" />
        </div>
    }
    else if (Condition is ExpressionCondition expr)
    {
        <div class="d-flex gap-1 align-items-center">
            <span class="badge bg-secondary" style="font-size: 0.65rem; white-space: nowrap;">Expression</span>
            <input type="text" class="form-control form-control-sm" style="font-size: 0.75rem; font-family: monospace; flex: 1;"
                   value="@expr.Expression"
                   @oninput="(e) => { expr.Expression = e.Value?.ToString() ?? string.Empty; }"
                   @onchange="() => NotifyChanged()"
                   placeholder="e.g. field_x == 'yes'" />
            <button class="btn btn-sm py-0 px-1" @onclick="Remove" style="font-size: 0.65rem;">
                <i class="bi bi-x text-danger"></i>
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Condition? Condition { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public List<string>? Fields { get; set; }

    private void NotifyChanged() => OnChanged.InvokeAsync();

    private void Remove()
    {
        Condition = null;
        NotifyChanged();
    }

    private void AddCompare()
    {
        Condition = new CompareCondition();
        NotifyChanged();
    }

    private void AddAnd()
    {
        Condition = new AndCondition();
        NotifyChanged();
    }

    private void AddOr()
    {
        Condition = new OrCondition();
        NotifyChanged();
    }

    private void AddExpression()
    {
        Condition = new ExpressionCondition();
        NotifyChanged();
    }
}
