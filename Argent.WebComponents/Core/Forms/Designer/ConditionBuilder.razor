@using Argent.Models.Forms.Components.Configuration

    <div class="condition-builder border border-gray-200 dark:border-gray-700 rounded-lg p-2 mb-2 bg-gray-50 dark:bg-gray-800/50">
        @if (Condition == null)
        {
            <div class="flex gap-1 flex-wrap">
                <button class="text-xs px-1 py-0.5 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => Replace(new CompareCondition())">
                    <i class="bi bi-plus"></i> Compare
                </button>
                <button class="text-xs px-1 py-0.5 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => Replace(new AndCondition())">
                    <i class="bi bi-plus"></i> And
                </button>
                <button class="text-xs px-1 py-0.5 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => Replace(new OrCondition())">
                    <i class="bi bi-plus"></i> Or
                </button>
                <button class="text-xs px-1 py-0.5 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => Replace(new NotCondition())">
                    <i class="bi bi-plus"></i> Not
                </button>
                <button class="text-xs px-1 py-0.5 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => Replace(new ExpressionCondition())">
                    <i class="bi bi-plus"></i> Expression
                </button>
            </div>
        }
        else if (Condition is CompareCondition compare)
        {
            <div class="flex gap-1 items-center flex-wrap">
                <select class="form-input text-sm"
                        @onchange="@((e) => { compare.Field = e.Value?.ToString() ?? ""; NotifyChanged(); })">
                    <option value="">-- field --</option>
                    @if (Fields != null)
                    {
                        @foreach (var f in Fields)
                        {
                            <option value="@f" selected="@(compare.Field == f)">@f</option>
                        }
                    }
                </select>
                <select class="form-input text-sm"
                        @onchange="@((e) => { compare.Operator = e.Value?.ToString() ?? "=="; NotifyChanged(); })">
                    @foreach (var op in CompareOperators.All)
                    {
                        <option value="@op" selected="@(compare.Operator == op)">@op</option>
                    }
                </select>
                @if (compare.Operator is "isEmpty" or "isNotEmpty")
                {
                    @* No value input needed for these operators *@
                }
                else
                {
                    <input type="text" class="form-input text-sm" style="width: 130px; font-size: 0.75rem;"
                           value="@(compare.Value?.ToString() ?? "")"
                           @oninput="(e) => { compare.Value = e.Value?.ToString(); }"
                           @onchange="() => NotifyChanged()"
                           placeholder="@(compare.Operator is "in" or "notIn" ? "comma,separated" : "value")" />
                }
                <button class="text-xs px-1 py-0.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors" @onclick="() => Replace(null)">
                    <i class="bi bi-x text-red-600 dark:text-red-400"></i>
                </button>
            </div>
        }
        else if (Condition is AndCondition and)
        {
            <div class="mb-1 flex items-center">
                <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded bg-gray-500 text-white">ALL of:</span>
                <button class="ml-auto text-xs px-1 py-0.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors" @onclick="() => Replace(null)">
                    <i class="bi bi-x text-red-600 dark:text-red-400"></i>
                </button>
            </div>
            @for (int i = 0; i < and.All.Count; i++)
            {
                var idx = i;
                <div class="ml-3 mb-1 border-s-2 pl-2 border-indigo-500">
                    <ConditionBuilder Condition="@and.All[idx]" Fields="@Fields"
                                      ConditionChanged="@((c) => ReplaceChild(and.All, idx, c))"
                                      OnChanged="() => NotifyChanged()" />
                </div>
            }
            <button class="text-xs px-1 py-0.5 mt-1 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => { and.All.Add(new CompareCondition()); NotifyChanged(); }">
                <i class="bi bi-plus"></i> Add condition
            </button>
        }
        else if (Condition is OrCondition or)
        {
            <div class="mb-1 flex items-center">
                <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded bg-gray-500 text-white">ANY of:</span>
                <button class="ml-auto text-xs px-1 py-0.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors" @onclick="() => Replace(null)">
                    <i class="bi bi-x text-red-600 dark:text-red-400"></i>
                </button>
            </div>
            @for (int i = 0; i < or.Any.Count; i++)
            {
                var idx = i;
                <div class="ml-3 mb-1 border-s-2 pl-2 border-green-500">
                    <ConditionBuilder Condition="@or.Any[idx]" Fields="@Fields"
                                      ConditionChanged="@((c) => ReplaceChild(or.Any, idx, c))"
                                      OnChanged="() => NotifyChanged()" />
                </div>
            }
            <button class="text-xs px-1 py-0.5 mt-1 font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded transition-colors" @onclick="() => { or.Any.Add(new CompareCondition()); NotifyChanged(); }">
                <i class="bi bi-plus"></i> Add condition
            </button>
        }
        else if (Condition is NotCondition not)
        {
            <div class="mb-1 flex items-center">
                <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded bg-red-500 text-white">NOT:</span>
                <button class="ml-auto text-xs px-1 py-0.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors" @onclick="() => Replace(null)">
                    <i class="bi bi-x text-red-600 dark:text-red-400"></i>
                </button>
            </div>
            <div class="ml-3 mb-1 border-s-2 pl-2 border-red-500">
                <ConditionBuilder Condition="@not.Not" Fields="@Fields"
                                  ConditionChanged="@(async (c) => { if (c == null) { await Replace(null); } else { not.Not = c; NotifyChanged(); } })"
                                  OnChanged="() => NotifyChanged()" />
            </div>
        }
        else if (Condition is ExpressionCondition expr)
        {
            <div class="flex gap-1 items-center">
                <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded bg-gray-500 text-white" style="white-space: nowrap;">Expression</span>
                <input type="text" class="form-input text-sm font-mono flex-1"
                       value="@expr.Expression"
                       @oninput="(e) => { expr.Expression = e.Value?.ToString() ?? string.Empty; }"
                       @onchange="() => NotifyChanged()"
                       placeholder="e.g. field_x == 'yes'" />
                <button class="text-xs px-1 py-0.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 rounded transition-colors" @onclick="() => Replace(null)">
                    <i class="bi bi-x text-red-600 dark:text-red-400"></i>
                </button>
            </div>
        }
    </div>

@code {
    [Parameter] public Condition? Condition { get; set; }

    /// <summary>
    /// Raised when this builder replaces or removes its condition instance. The owner
    /// must assign the new value to its own model — this component cannot reach the
    /// parent's reference itself (the old version silently dropped these changes).
    /// </summary>
    [Parameter] public EventCallback<Condition?> ConditionChanged { get; set; }

    /// <summary>Raised for in-place edits (field/operator/value changes).</summary>
    [Parameter] public EventCallback OnChanged { get; set; }

    [Parameter] public List<string>? Fields { get; set; }

    private void NotifyChanged() => OnChanged.InvokeAsync();

    private async Task Replace(Condition? condition)
    {
        Condition = condition;
        await ConditionChanged.InvokeAsync(condition);
        await OnChanged.InvokeAsync();
    }

    private void ReplaceChild(List<Condition> list, int index, Condition? child)
    {
        if (index < 0 || index >= list.Count) return;
        if (child == null)
            list.RemoveAt(index);
        else
            list[index] = child;
        NotifyChanged();
    }
}
