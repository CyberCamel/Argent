@using Argent.WebComponents
@inherits FormInputComponentBase

@if (IsVisible)
{
    <div class="form-check mb-3 @Metadata.CssClass">
        @{var _cbErrors = Errors.ToList();}
        <input class="form-check-input @(_cbErrors.Count > 0 ? "is-invalid" : "")"
               type="checkbox"
               id="@Metadata.Id"
               checked="@CurrentValue"
               @onchange="(e) => OnValueChanged(e.Value)"
               disabled="@Metadata.Disabled"
               readOnly="@Metadata.ReadOnly" />
        <label class="form-check-label" for="@Metadata.Id">
            @(Metadata.BoxLabel ?? Metadata.FieldLabel)
        </label>
        @if (Metadata.Description != null)
        {
            <div class="form-text">@Metadata.Description</div>
        }
        @if (_cbErrors.Count > 0)
        {
            <div class="invalid-feedback d-block">
                @foreach (var err in _cbErrors) { <div>@err</div> }
            </div>
        }
    </div>
}

@code {
    private bool IsVisible => Context.IsVisible(Metadata);
    private bool CurrentValue => Context.GetValue<bool>(Metadata.Name ?? Metadata.Id);
    private IEnumerable<string> Errors => Context.GetErrors(Metadata);

    private void OnValueChanged(object? val)
    {
        Context.SetValue(Metadata.Name ?? Metadata.Id, val is bool b && b);
    }
}