@using Argent.Contracts.Forms
@using Argent.Contracts.DomainObjects
@using Argent.Models.Forms.Components
@using Argent.Models.Forms
@using Argent.Models.DomainObjects
@using Argent.Runtime.Forms
@using Microsoft.EntityFrameworkCore
@implements IDisposable
@inject IFormContext Context
@inject IFormValidator Validator
@inject IDomainObjectStore DomainObjectStore
@inject IDomainObjectDefinitionService DomainObjectDefinitionService
@inject IDbContextFactory<Argent.Infrastructure.Data.ArgentDbContext> DbFactory

@if (_definition == null)
{
    <div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-lg p-3 text-sm text-yellow-800 dark:text-yellow-200">Form not found.</div>
}
else
{
    <div class="argent-form @CssClass">
        @if (!string.IsNullOrEmpty(_definition.Title))
        {
            <h4 class="mb-3">@_definition.Title</h4>
        }

        @foreach (var component in _definition.Components)
        {
            <ArgentRenderer Metadata="component" />
        }

        @if (!string.IsNullOrEmpty(_submitError))
        {
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3 text-sm text-red-800 dark:text-red-200 mt-3">@_submitError</div>
        }

        @if (_submitted)
        {
            <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-lg p-3 text-sm text-green-800 dark:text-green-200 mt-3">@(SuccessMessage ?? "Form submitted successfully.")</div>
        }
        else if (!HideSubmit)
        {
            <div class="flex justify-end gap-2 mt-4">
                <button type="button" class="px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors" @onclick="Submit">@(SubmitLabel ?? "Submit")</button>
            </div>
        }
    </div>
}

@code {
    /// <summary>Load the form blueprint from the database by design id.</summary>
    [Parameter] public Guid? FormId { get; set; }

    /// <summary>Pin to a specific published version (set by workflow publish). Null = latest published.</summary>
    [Parameter] public Guid? FormVersionId { get; set; }

    /// <summary>Supply a definition directly (e.g. designer preview).</summary>
    [Parameter] public FormDefinition? Definition { get; set; }

    /// <summary>
    /// The existing record to seed and update. When null the form creates a new record on submit.
    /// </summary>
    [Parameter] public Guid? RecordId { get; set; }

    [Parameter] public string? SubmitLabel { get; set; }
    [Parameter] public string? SuccessMessage { get; set; }
    [Parameter] public string? CssClass { get; set; }

    /// <summary>Hides the built-in submit button. The parent is responsible for triggering submission via <see cref="TrySaveAsync"/>.</summary>
    [Parameter] public bool HideSubmit { get; set; }

    /// <summary>Raised with the saved <see cref="DomainRecord"/> after a valid submission.</summary>
    [Parameter] public EventCallback<DomainRecord> OnValidSubmit { get; set; }

    private FormDefinition? _definition;
    private Dictionary<string, List<string>>? _errors;
    private string? _submitError;
    private bool _submitted;

    protected override async Task OnInitializedAsync()
    {
        Context.OnStateChanged += HandleContextChanged;
        Context.RecordId = RecordId;

        if (Definition != null)
        {
            _definition = Definition;
        }
        else if (FormVersionId.HasValue)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var ver = await db.FormDesignVersions.AsNoTracking()
                .FirstOrDefaultAsync(v => v.Id == FormVersionId.Value);
            _definition = ver?.Definition;
        }
        else if (FormId.HasValue)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            // Load latest published version; fall back to draft if none published yet
            var ver = await db.FormDesignVersions.AsNoTracking()
                .Where(v => v.FormDesignId == FormId.Value)
                .OrderByDescending(v => v.CreatedAt)
                .FirstOrDefaultAsync();
            if (ver != null)
            {
                _definition = ver.Definition;
            }
            else
            {
                var draft = await db.FormDesignDrafts.AsNoTracking()
                    .FirstOrDefaultAsync(d => d.FormDesignId == FormId.Value);
                _definition = draft?.Definition;
            }
        }

        if (_definition != null && !string.IsNullOrEmpty(_definition.ObjectKey)
            && Context is Argent.Runtime.Forms.ArgentFormContext argentCtx)
        {
            var domainDef = await DomainObjectDefinitionService.GetPublishedDefinitionAsync(_definition.ObjectKey);
            argentCtx.DomainDefinition = domainDef;
        }

        if (RecordId.HasValue && _definition != null)
        {
            try { await SeedFromRecordAsync(RecordId.Value); }
            catch (Exception ex) { _submitError = $"Could not load existing record: {ex.Message}"; }
        }
    }

    private async Task SeedFromRecordAsync(Guid recordId)
    {
        var record = await DomainObjectStore.GetAsync(_definition!.ObjectKey, recordId);
        if (record == null) return;

        var values = new Dictionary<string, object?>(record.Values);

        // Merge any custom (non-domain) field values saved alongside this record.
        if (FormId.HasValue)
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var custom = await db.FormCustomData
                .AsNoTracking()
                .FirstOrDefaultAsync(c => c.RecordId == recordId && c.FormId == FormId.Value);
            if (custom != null)
                foreach (var kvp in custom.Values)
                    values[kvp.Key] = kvp.Value;
        }

        Context.SetInitialValues(values);
    }

    private void HandleContextChanged()
    {
        _errors = null; // clear stale submit-time summary when the user makes any change
        StateHasChanged();
    }

    public void Dispose() => Context.OnStateChanged -= HandleContextChanged;

    // Called by the built-in submit button.
    private async Task Submit()
    {
        var record = await TrySaveAsync();
        if (record == null) return;
        _submitted = true;
        if (OnValidSubmit.HasDelegate)
            await OnValidSubmit.InvokeAsync(record);
    }

    // Called by a parent that wants to validate+save without triggering OnValidSubmit
    // (e.g. a TaskDetail that has its own action buttons for routing). Returns the saved
    // record on success, null on validation or save failure.
    public async Task<DomainRecord?> TrySaveAsync()
    {
        if (_definition == null) return null;

        _submitError = null;
        var ctx = Context as ArgentFormContext;
        ctx?.RevealAllErrors();
        _errors = Validator.ValidateForm(_definition, Context);
        if (_errors.Count > 0)
        {
            StateHasChanged();
            return null;
        }

        var allValues = Context.GetAllData();

        var domainDef = ctx?.DomainDefinition;
        var boundKeys = domainDef?.Properties
            .Select(p => p.Key)
            .ToHashSet(StringComparer.OrdinalIgnoreCase) ?? [];

        var boundValues = allValues
            .Where(kvp => boundKeys.Contains(kvp.Key))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

        var customValues = allValues
            .Where(kvp => !boundKeys.Contains(kvp.Key))
            .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);

        var user = Context.UserId;
        DomainRecord record;
        try
        {
            if (Context.RecordId.HasValue)
            {
                record = await DomainObjectStore.UpdateAsync(_definition.ObjectKey, Context.RecordId.Value, boundValues, user);
            }
            else
            {
                record = await DomainObjectStore.CreateAsync(_definition.ObjectKey, boundValues, user);
                Context.RecordId = record.Id;
            }

            if (customValues.Count > 0 && FormId.HasValue)
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                var existing = await db.FormCustomData
                    .FirstOrDefaultAsync(c => c.RecordId == record.Id && c.FormId == FormId.Value);
                if (existing != null)
                {
                    existing.Values = customValues;
                    existing.UpdatedAt = DateTime.UtcNow;
                }
                else
                {
                    db.FormCustomData.Add(new FormCustomData
                    {
                        RecordId = record.Id,
                        FormId = FormId.Value,
                        Values = customValues
                    });
                }
                await db.SaveChangesAsync();
            }
        }
        catch (DomainValidationException dvx)
        {
            var perField = dvx.Errors
                .GroupBy(e => e.Property)
                .ToDictionary(g => g.Key, g => g.Select(e => e.Message).ToList());
            ctx?.SetServerErrors(perField);
            StateHasChanged();
            return null;
        }
        catch (Exception ex)
        {
            _submitError = ex.Message;
            StateHasChanged();
            return null;
        }

        return record;
    }
}
