@using Argent.Contracts.Workflows
@using Argent.Models.Workflows
@using Argent.Runtime.Workflows.Modeling
@using Argent.WebComponents.Core.Workflows.Enum
@using System.Globalization

<g transform="translate(@(Node.X), @(Node.Y))" class="node @Node.CssClass @(Node.IsSelected ? "node-selected" : "")" @ondblclick="OnDoubleClick">
    @* The dynamic shape *@
    @switch (Node.Shape)
    {
        case NodeShape.Circle:
            <ellipse cx="@(Node.Width / 2)" cy="@(Node.Height / 2)"
                     rx="@(Node.Width / 2)" ry="@(Node.Height / 2)"
                     fill="#ffffff" stroke="@(Node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                     @onpointerdown="e => OnPointerDown.InvokeAsync((e, Node))" />
            break;
        case NodeShape.Diamond:
            var points = $"{Node.Width / 2},0 {Node.Width},{Node.Height / 2} {Node.Width / 2},{Node.Height} 0,{Node.Height / 2}";
            <polygon points="@points"
                     fill="#ffffff" stroke="@(Node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                     @onpointerdown="e => OnPointerDown.InvokeAsync((e, Node))" />
            break;
        default:
            <rect width="@(Node.Width)" height="@(Node.Height)" rx="6"
                  fill="#ffffff" stroke="@(Node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                  @onpointerdown="e => OnPointerDown.InvokeAsync((e, Node))" />
            if (Node.IsSelected)
            {
                <rect x="0" y="-4" width="@(Node.Width)" height="8" style="cursor:ns-resize" fill="transparent" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.Top))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="0" width="8" height="@(Node.Height)" style="cursor:ew-resize" fill="transparent" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.Right))" @onpointerdown:stopPropagation />
                <rect x="0" y="@(Node.Height - 4)" width="@(Node.Width)" height="8" style="cursor:ns-resize" fill="transparent" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.Bottom))" @onpointerdown:stopPropagation />
                <rect x="-4" y="0" width="8" height="@(Node.Height)" style="cursor:ew-resize" fill="transparent" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.Left))" @onpointerdown:stopPropagation />
                <rect x="-4" y="-4" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nwse-resize" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.TopLeft))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="-4" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nesw-resize" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.TopRight))" @onpointerdown:stopPropagation />
                <rect x="-4" y="@(Node.Height - 4)" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nesw-resize" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.BottomLeft))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="@(Node.Height - 4)" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nwse-resize" @onpointerdown="e => OnResize.InvokeAsync((e, Node, ResizeDirection.BottomRight))" @onpointerdown:stopPropagation />
            }
            break;
    }
    @if (Node.Shape == NodeShape.Rectangle && !string.IsNullOrEmpty(Node.Icon))
    {
        <svg:text x="10" y="24"
              fill="#FFF"
              style="font-family: 'Material Symbols Outlined'; pointer-events:none;">
            @Node.Icon
        </svg:text>
    }
    <text x="@(Node.Width / 2)" y="@(Node.Height / 2 + 5)"
          fill="white" text-anchor="middle" style="pointer-events:none; font-weight:bold">
        @Node.Title
    </text>
    @foreach (var direction in Enum.GetValues<AnchorDirection>())
    {
        var anchor = GetLocalAnchorPosition(Node, direction);
        <circle cx="@anchor.X" cy="@anchor.Y" r="6" fill="#0d6efd" style="cursor:crosshair"
                @onpointerdown="e => OnAnchorDown.InvokeAsync((e, Node, direction))"
                @onpointerdown:stopPropagation />
    }
    @if (CurrentMode == DesignerState.Connecting)
    {
        foreach (var direction in Enum.GetValues<AnchorDirection>())
        {
            var anchor = GetLocalAnchorPosition(Node, direction);
            <circle cx="@anchor.X" cy="@anchor.Y" r="4" fill="#0d6efd" style="cursor:crosshair"
                    @onpointerdown="e => OnAnchorDown.InvokeAsync((e, Node, direction))"
                    @onpointerdown:stopPropagation />
        }
    }
</g>

@code {
    [Parameter] public DesignerNode Node { get; set; } = default!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public DesignerState CurrentMode { get; set; }
    [Parameter] public EventCallback<(PointerEventArgs, DesignerNode)> OnPointerDown { get; set; }
    [Parameter] public EventCallback<(PointerEventArgs, DesignerNode, ResizeDirection)> OnResize { get; set; }
    [Parameter] public EventCallback<(PointerEventArgs, DesignerNode, AnchorDirection)> OnAnchorDown { get; set; }
    [Parameter] public EventCallback OnDoubleClick { get; set; }

    private (double X, double Y) GetLocalAnchorPosition(DesignerNode node, AnchorDirection direction) => direction switch
    {
        AnchorDirection.Right => (node.Width, node.Height / 2),
        AnchorDirection.Left => (0, node.Height / 2),
        AnchorDirection.Bottom => (node.Width / 2, node.Height),
        _ => (node.Width / 2, 0)
    };

    public enum ResizeDirection
    {
        None = 0, Top = 1, Bottom = 2, Left = 4, Right = 8,
        TopLeft = Top | Left, TopRight = Top | Right,
        BottomLeft = Bottom | Left, BottomRight = Bottom | Right
    }
}
