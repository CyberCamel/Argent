@using Argent.Runtime.Workflows.Modeling
@using Argent.Runtime.Workflows.Modeling.Routing

<g @onclick="() => State.Select(Connection)" @onclick:stopPropagation
   @onpointerenter="HandlePointerEnter" @onpointerleave="HandlePointerLeave">
    @{
        var pathData = RoutingService.WaypointsToSvgPath(Connection.Waypoints);
        var isSelected = State.SelectedConnection == Connection;
        var wps = Connection.Waypoints;
    }

    <path d="@pathData" stroke="transparent" stroke-width="20" fill="none"
          style="cursor: pointer"
          @onpointerdown="e => OnPointerDown.InvokeAsync((e, Connection))"
          @onpointerdown:stopPropagation />

    <path d="@pathData" fill="none"
          class="connection-path @(isSelected ? "connection-selected" : "") @(_isHovered ? "connection-hover" : "")" />

    @if (isSelected)
    {
        @for (int i = 1; i < wps.Count - 1; i++)
        {
            var wp = wps[i];
            var wpIdx = i;
            <circle cx="@wp.X" cy="@wp.Y" r="5" class="conn-waypoint"
                    @onpointerdown="e => OnStartWaypointDrag.InvokeAsync((e, Connection, wpIdx))"
                    @onpointerdown:stopPropagation />
        }

        @for (int i = 0; i < wps.Count - 1; i++)
        {
            var a = wps[i];
            var b = wps[i + 1];
            double midX = (a.X + b.X) / 2;
            double midY = (a.Y + b.Y) / 2;
            var segIdx = i;
            <circle cx="@midX" cy="@midY" r="5" class="conn-midpoint"
                    @onpointerdown="e => OnInsertWaypoint.InvokeAsync((e, Connection, segIdx))"
                    @onpointerdown:stopPropagation />
        }

        <circle cx="@wps[0].X" cy="@wps[0].Y" r="7" class="conn-reroute"
                @onpointerdown="e => OnStartReRoute.InvokeAsync((e, Connection, true))"
                @onpointerdown:stopPropagation />

        <circle cx="@wps[wps.Count - 1].X" cy="@wps[wps.Count - 1].Y" r="7" class="conn-reroute"
                @onpointerdown="e => OnStartReRoute.InvokeAsync((e, Connection, false))"
                @onpointerdown:stopPropagation />
    }
</g>

@code {
    [Parameter]
    public DesignerConnection Connection { get; set; } = default!;

    [Parameter]
    public DesignerService State { get; set; } = default!;

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerConnection, bool)> OnStartReRoute { get; set; }

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerConnection)> OnPointerDown { get; set; }

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerConnection, int)> OnStartWaypointDrag { get; set; }

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerConnection, int)> OnInsertWaypoint { get; set; }

    private bool _isHovered;

    private void HandlePointerEnter(PointerEventArgs e)
    {
        _isHovered = true;
    }

    private void HandlePointerLeave(PointerEventArgs e)
    {
        _isHovered = false;
    }
}
