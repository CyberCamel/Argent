    // ======================== ANCHOR / CONNECTION ========================

    private async Task OnAnchorPointerDown(PointerEventArgs e, DesignerNode node, AnchorDirection dir)
    {
        if (EffectiveReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var (wx, wy) = await ToWorldAsync(e.ClientX, e.ClientY);

        _mode = Mode.Connecting;
        _activeNode = node;
        _draftConnection = new ConnectionDraft
        {
            FixedNode = node,
            FixedDir = dir,
            MouseX = wx,
            MouseY = wy
        };
        State.Notify();
    }

    private async Task TryFinalizeConnection(double clientX, double clientY)
    {
        if (_draftConnection == null || _activeNode == null) return;

        var (wx, wy) = await ToWorldAsync(clientX, clientY);

        var dropNode = State.Nodes.LastOrDefault(n =>
            n != _activeNode &&
            wx >= n.X && wx <= n.X + n.Width &&
            wy >= n.Y && wy <= n.Y + n.Height);

        if (dropNode == null)
        {
            // Dropped on empty canvas: put a rerouted connection back, or just clear the draft
            if (_rerouteOriginal != null)
            {
                State.Connections.Add(_rerouteOriginal);
                _rerouteOriginal = null;
            }
            _draftConnection = null;
            State.Notify();
            return;
        }

        var fixedNode = _draftConnection.FixedNode;
        var fixedDir = _draftConnection.FixedDir;

        DesignerConnection conn;
        if (_draftConnection.FixedEndIsTarget)
        {
            // Source endpoint re-drag: the dropped node becomes the new source,
            // the fixed node keeps its target role and anchor.
            var (_, _, sourceDir) = AnchorService.GetClosestAnchor(dropNode, (wx, wy));
            conn = new DesignerConnection
            {
                Source = dropNode,
                SourceDir = sourceDir,
                Target = fixedNode,
                TargetDir = fixedDir,
                EngineConnection = new Connection { From = dropNode.NodeData, To = fixedNode.NodeData },
            };
        }
        else
        {
            var (_, _, targetDir) = AnchorService.GetBestTargetAnchor(dropNode, (wx, wy), fixedDir);
            conn = new DesignerConnection
            {
                Source = fixedNode,
                SourceDir = fixedDir,
                Target = dropNode,
                TargetDir = targetDir,
                EngineConnection = new Connection { From = fixedNode.NodeData, To = dropNode.NodeData },
            };
        }

        conn.Waypoints = RoutingService.AutoRoute(conn.Source, conn.SourceDir, conn.Target, conn.TargetDir);
        State.Connections.Add(conn);
        _rerouteOriginal = null;
        _draftConnection = null;
        State.MarkDirty();
    }

    // ======================== CONNECTION INTERACTIONS ========================

    private async Task OnConnectionPointerDown(PointerEventArgs e, DesignerConnection conn)
    {
        if (EffectiveReadOnly) return;
        if (_pendingNodeDesc != null) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var (wx, wy) = await ToWorldAsync(e.ClientX, e.ClientY);

        int segIdx = RoutingService.FindNearestSegment(conn.Waypoints, wx, wy);
        State.Select(conn);

        if (segIdx >= 0)
        {
            _mode = Mode.SegmentDrag;
            _segmentIdx = segIdx;
            _dragStartX = wx;
            _dragStartY = wy;
            _activeConnection = conn;
        }

        State.Notify();
    }

    private async Task OnConnectionDoubleClick(MouseEventArgs e, DesignerConnection conn)
    {
        if (EffectiveReadOnly) return;

        var (wx, wy) = await ToWorldAsync(e.ClientX, e.ClientY);

        int segIdx = RoutingService.FindNearestSegment(conn.Waypoints, wx, wy);
        if (segIdx >= 0)
        {
            RoutingService.InsertWaypointAtMidpoint(conn.Waypoints, segIdx);
            State.MarkDirty();
        }
    }

    private async Task OnWaypointPointerDown(PointerEventArgs e, DesignerConnection conn, int idx)
    {
        if (EffectiveReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var (wx, wy) = await ToWorldAsync(e.ClientX, e.ClientY);

        // Endpoint re-drag: detach this end and continue as a connection draft.
        // The other end stays fixed and keeps its role, so re-dragging the source
        // endpoint produces (new node) → (old target), not the reverse.
        if (idx == 0 || idx == conn.Waypoints.Count - 1)
        {
            bool draggingSourceEnd = idx == 0;
            var draft = new ConnectionDraft
            {
                FixedNode = draggingSourceEnd ? conn.Target : conn.Source,
                FixedDir = draggingSourceEnd ? conn.TargetDir : conn.SourceDir,
                FixedEndIsTarget = draggingSourceEnd,
                MouseX = wx,
                MouseY = wy
            };

            State.Connections.Remove(conn);
            _rerouteOriginal = conn; // restored if the drag ends on empty canvas or is cancelled
            _mode = Mode.Connecting;
            _activeNode = draft.FixedNode;
            _draftConnection = draft;
            State.Notify();
            return;
        }

        _mode = Mode.WaypointDrag;
        _activeConnection = conn;
        _draggedWpIdx = idx;
        State.Notify();
    }

    // ======================== KEYBOARD ========================

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (EffectiveReadOnly) return;
        if (_editingNode != null) return;
        if (e.Key == "Shift") return;

        if (e.Key == "Escape")
        {
            _pendingNodeDesc = null;
            if (_rerouteOriginal != null)
            {
                State.Connections.Add(_rerouteOriginal);
                _rerouteOriginal = null;
            }
            _draftConnection = null;
            _editingNode = null;
            _mode = Mode.Idle;
            _snapResult = null;
            _selectedNodes.Clear();
            State.DeselectAll();
            State.Notify();
        }
        else if ((e.CtrlKey || e.MetaKey) && e.Key is "s" or "S")
        {
            _ = HandleSave();
        }
        else if (e.Key == "Delete" || e.Key == "Backspace")
        {
            DeleteSelection();
        }
    }

    private void DeleteSelection()
    {
        if (_selectedNodes.Count > 0)
        {
            foreach (var n in _selectedNodes)
            {
                State.Connections.RemoveAll(c => c.Source == n || c.Target == n);
                State.Nodes.Remove(n);
            }
            _selectedNodes.Clear();
            State.DeselectAll();
            State.MarkDirty();
        }
        else
        {
            // A connection may be selected without any nodes
            State.DeleteSelected();
        }
    }

    // ======================== MOUSE WHEEL ========================

    private async Task OnMouseWheel(WheelEventArgs e)
    {
        var dims = await GetCanvasRect();
        var (beforeX, beforeY) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        double factor = Math.Pow(1.001, -e.DeltaY);
        Session.Zoom = Math.Clamp(Session.Zoom * factor, 0.1, 3.0);

        var (afterX, afterY) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);
        Session.PanX += beforeX - afterX;
        Session.PanY += beforeY - afterY;

        State.Notify();
    }

    // ======================== PLACEMENT ========================

    private void PlaceNodeFromToolbox(double wx, double wy)
    {
        if (_pendingNodeDesc == null) return;

        var instance = Activator.CreateInstance(_pendingNodeDesc.NodeType) as NodeBase;
        if (instance == null) return;

        var node = new DesignerNode
        {
            NodeData = instance,
            Title = _pendingNodeDesc.DisplayName,
            Description = _pendingNodeDesc.Description,
            Icon = _pendingNodeDesc.Icon,
            CssClass = _pendingNodeDesc.CssClass,
            Shape = _pendingNodeDesc.Shape,
            Width = _pendingNodeW,
            Height = _pendingNodeH,
            X = wx - _pendingNodeW / 2,
            Y = wy - _pendingNodeH / 2,
        };

        State.Nodes.Add(node);
        State.Select(node);
        _pendingNodeDesc = null;
        TrySplitConnectionForNode(node);
        State.MarkDirty();
    }

    // ======================== RESIZE ========================

    private void OnResizeStart(PointerEventArgs e, DesignerNode node, ResizeDir dir)
    {
        if (EffectiveReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        _mode = Mode.Resizing;
        _activeNode = node;
        _resizeDir = dir;
        _startNodeX = node.X;
        _startNodeY = node.Y;
        _startNodeW = node.Width;
        _startNodeH = node.Height;
    }

    private void ApplyResize(double dx, double dy)
    {
        if (_activeNode == null) return;
        var n = _activeNode;

        if (_resizeDir.HasFlag(ResizeDir.Right))
            n.Width = Math.Max(ResizeMinW, _startNodeW + dx);

        if (_resizeDir.HasFlag(ResizeDir.Bottom))
            n.Height = Math.Max(ResizeMinH, _startNodeH + dy);

        if (_resizeDir.HasFlag(ResizeDir.Left))
        {
            double newW = Math.Max(ResizeMinW, _startNodeW - dx);
            if (newW > ResizeMinW || dx < 0)
            {
                n.X = _startNodeX + (_startNodeW - newW);
                n.Width = newW;
            }
        }

        if (_resizeDir.HasFlag(ResizeDir.Top))
        {
            double newH = Math.Max(ResizeMinH, _startNodeH - dy);
            if (newH > ResizeMinH || dy < 0)
            {
                n.Y = _startNodeY + (_startNodeH - newH);
                n.Height = newH;
            }
        }

        State.MarkDirty();
    }

    // ======================== ROUTING UPDATES ========================

    private void UpdateNodeConnections(DesignerNode node, double dx, double dy)
    {
        foreach (var conn in State.Connections)
        {
            if (conn.Source == node || conn.Target == node)
            {
                var (srcDir, tgtDir) = RoutingService.GetBestDirections(conn.Source, conn.Target);
                conn.SourceDir = srcDir;
                conn.TargetDir = tgtDir;
                conn.Waypoints = RoutingService.AutoRoute(
                    conn.Source, conn.SourceDir,
                    conn.Target, conn.TargetDir);
            }
        }
    }

    private bool TrySplitConnectionForNode(DesignerNode node)
    {
        double cx = node.X + node.Width / 2;
        double cy = node.Y + node.Height / 2;

        DesignerConnection? targetConn = null;
        foreach (var conn in State.Connections)
        {
            // Never split a connection the node is already part of
            if (conn.Source == node || conn.Target == node) continue;

            if (RoutingService.FindNearestSegment(conn.Waypoints, cx, cy, threshold: 15) >= 0)
            {
                targetConn = conn;
                break;
            }
        }

        if (targetConn == null) return false;

        var conn1 = new DesignerConnection
        {
            Source = targetConn.Source,
            SourceDir = targetConn.SourceDir,
            Target = node,
            TargetDir = AnchorDirection.None,
            EngineConnection = new Connection { From = targetConn.Source.NodeData, To = node.NodeData },
        };

        var conn2 = new DesignerConnection
        {
            Source = node,
            SourceDir = AnchorDirection.None,
            Target = targetConn.Target,
            TargetDir = targetConn.TargetDir,
            EngineConnection = new Connection { From = node.NodeData, To = targetConn.Target.NodeData },
        };

        var (srcDir1, tgtDir1) = RoutingService.GetBestDirections(conn1.Source, conn1.Target);
        conn1.SourceDir = srcDir1;
        conn1.TargetDir = tgtDir1;
        conn1.Waypoints = RoutingService.AutoRoute(conn1.Source, conn1.SourceDir, conn1.Target, conn1.TargetDir);

        var (srcDir2, tgtDir2) = RoutingService.GetBestDirections(conn2.Source, conn2.Target);
        conn2.SourceDir = srcDir2;
        conn2.TargetDir = tgtDir2;
        conn2.Waypoints = RoutingService.AutoRoute(conn2.Source, conn2.SourceDir, conn2.Target, conn2.TargetDir);

        State.Connections.Remove(targetConn);
        State.Connections.Add(conn1);
        State.Connections.Add(conn2);
        return true;
    }

    // ======================== SAVE / COMPILE / PUBLISH ========================

    private async Task HandleSave()
    {
        var wasNew = !State.CurrentWorkflowId.HasValue;
        State.Compile();
        State.SaveDraft();
        State.Notify();

        if (wasNew && State.CurrentWorkflowId.HasValue)
        {
            var userId = User?.FindFirstValue(ClaimTypes.NameIdentifier);
            if (!string.IsNullOrEmpty(userId))
                await OwnershipService.GrantOwnershipAsync("Workflow", State.CurrentWorkflowId.Value, userId);

            Nav.NavigateTo($"/Workflows/Edit/{State.CurrentWorkflowId}", forceLoad: true);
        }
    }

    private void HandleCompile()
    {
        State.Compile();
        State.Notify();
    }

    private void HandleTestRun()
    {
        State.Compile();
        State.Notify();
    }

    // ======================== FIT TO SCREEN ========================

    private void FitToScreen()
    {
        if (State.Nodes.Count == 0) return;

        double minX = State.Nodes.Min(n => n.X);
        double minY = State.Nodes.Min(n => n.Y);
        double maxX = State.Nodes.Max(n => n.X + n.Width);
        double maxY = State.Nodes.Max(n => n.Y + n.Height);

        double pad = 40;
        double cw = maxX - minX + pad * 2;
        double ch = maxY - minY + pad * 2;
        if (cw < 1 || ch < 1) return;

        Session.Zoom = Math.Min(Session.CanvasWidth / cw, Session.CanvasHeight / ch);
        Session.Zoom = Math.Clamp(Session.Zoom, 0.1, 3.0);

        Session.PanX = minX - pad - (Session.CanvasWidth / Session.Zoom - cw) / 2;
        Session.PanY = minY - pad - (Session.CanvasHeight / Session.Zoom - ch) / 2;

        State.Notify();
    }

    // ======================== SNAPPING ========================

    public static SnapResult GetSnappedPosition(
        DesignerNode draggingNode,
        List<DesignerNode> allNodes,
        double rawX,
        double rawY,
        double threshold = 10)
    {
        var result = new SnapResult
        {
            SnappedX = rawX,
            SnappedY = rawY
        };

        foreach (var otherNode in allNodes.Where(n => n != draggingNode))
        {
            // X axis snapping
            if (Math.Abs((rawX + draggingNode.Width / 2) - (otherNode.X + otherNode.Width / 2)) < threshold)
            {
                result.SnappedX = (otherNode.X + otherNode.Width / 2) - (draggingNode.Width / 2);
                result.XSnapAxis = SnapAxis.Center;
                result.TargetNode = otherNode;
            }
            else if (Math.Abs(rawX - otherNode.X) < threshold)
            {
                result.SnappedX = otherNode.X;
                result.XSnapAxis = SnapAxis.Start;
                result.TargetNode = otherNode;
            }
            else if (Math.Abs((rawX + draggingNode.Width) - (otherNode.X + otherNode.Width)) < threshold)
            {
                result.SnappedX = otherNode.X + otherNode.Width - draggingNode.Width;
                result.XSnapAxis = SnapAxis.End;
                result.TargetNode = otherNode;
            }

            // Y axis snapping
            if (Math.Abs((rawY + draggingNode.Height / 2) - (otherNode.Y + otherNode.Height / 2)) < threshold)
            {
                result.SnappedY = (otherNode.Y + otherNode.Height / 2) - (draggingNode.Height / 2);
                result.YSnapAxis = SnapAxis.Center;
                result.TargetNode = otherNode;
            }
            else if (Math.Abs(rawY - otherNode.Y) < threshold)
            {
                result.SnappedY = otherNode.Y;
                result.YSnapAxis = SnapAxis.Start;
                result.TargetNode = otherNode;
            }
            else if (Math.Abs((rawY + draggingNode.Height) - (otherNode.Y + otherNode.Height)) < threshold)
            {
                result.SnappedY = otherNode.Y + otherNode.Height - draggingNode.Height;
                result.YSnapAxis = SnapAxis.End;
                result.TargetNode = otherNode;
            }
        }

        return result;
    }

    public sealed class BoundingRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }
