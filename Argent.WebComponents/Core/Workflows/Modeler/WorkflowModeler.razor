@using Argent.Core.Attributes
@using Argent.Core.Workflows
@using Argent.Logic.Workflows.Modeling
@using System.Globalization
@using Argent.WebComponents.Core.Workflows.Enum
@using Microsoft.JSInterop
@inject DesignerService State
@inject IJSRuntime JS

<div class="d-flex flex-grow-1 h-100 w-80">
    <DesignerToolbox CssClass="w-20" State="@State" />
    <div class="d-flex flex-column">
        <DesignerToolbar State="@State" />
        <div class="vh-100 overflow-hidden bg-dark">
        <div @ref="_canvasContainer" class="w-100 h-100 position-relative" tabindex="0"
             style="cursor: @(_currentMode == DesignerState.Panning ? "grabbing" : "default")"
             @onpointermove="HandlePointerMove"
             @onpointerup="HandlePointerUp"
             @onwheel="HandleMouseWheel"
             @onkeydown="HandleKeyDown">

                <svg viewBox="@State.Session.ViewBox" width="100%" height="100%" @oncontextmenu:preventDefault class=@(_currentMode ==DesignerState.Resizing ? "is-interacting" : "")>
                <defs>
                    <pattern id="gridPattern" width="50" height="50" patternUnits="userSpaceOnUse">
                        <circle cx="2" cy="2" r="1" fill="#444" />
                    </pattern>
                </defs>

                <rect x="@State.Session.PanX" y="@State.Session.PanY"
                      width="@(State.Session.ViewportWidth / State.Session.Zoom)"
                      height="@(State.Session.ViewportHeight / State.Session.Zoom)"
                      fill="url(#gridPattern)"
                      @onpointerdown="HandleBackgroundPointerDown" />

                @foreach (var connection in State.Connections)
                {
                    var start = State.GetAnchorWorldPos(connection.Source, connection.SourceDir, connection);
                    var end = State.GetAnchorWorldPos(connection.Target, connection.TargetDir, connection);
                    var pathData = GetOrthogonalPath(start, end, connection.SourceDir, connection.TargetDir);

                    <g @onclick="() => State.Select(connection)" @onclick:stopPropagation>
                        <path d="@pathData" stroke="transparent" stroke-width="15" fill="none" />
                        <path d="@pathData" stroke="@(State.SelectedConnection == connection ? "#0d6efd" : "#888")" stroke-width="2" fill="none" />

                        @if (State.SelectedConnection == connection)
                        {
                            @* Source Handle *@
                            <circle cx="@start.X" cy="@start.Y" r="7" fill="white" stroke="#0d6efd" stroke-width="2"
                                    @onpointerdown="e => StartReRoute(e, connection, isSource: true)" @onpointerdown:stopPropagation />

                            @* Target Handle *@
                            <circle cx="@end.X" cy="@end.Y" r="7" fill="white" stroke="#0d6efd" stroke-width="2"
                                    @onpointerdown="e => StartReRoute(e, connection, isSource: false)" @onpointerdown:stopPropagation />
                        }
                    </g>
                }
                @if (State.PendingNewNode != null)
                {
                    <g transform="translate(@State.PendingNewNode.X.ToString(CultureInfo.InvariantCulture), @State.PendingNewNode.Y.ToString(CultureInfo.InvariantCulture))"
                           style="opacity: 0.6; pointer-events: none;">
                        <rect width="@State.PendingNewNode.Width" height="@State.PendingNewNode.Height"
                              rx="6" fill="#0d6efd" stroke="#0d6efd" stroke-width="2" stroke-dasharray="4" />
                        <text x="12" y="30" fill="white" style="font-weight:bold">@State.PendingNewNode.Title</text>
                    </g>
                }

                @if (State.ActiveDraft != null)
                {
                    var startPoint = State.GetAnchorWorldPos(State.ActiveDraft.Source, State.ActiveDraft.SourceDir);
                    var mousePoint = (State.ActiveDraft.MouseX, State.ActiveDraft.MouseY);
                    var adaptiveTargetDir = GetOppositeDirection(State.ActiveDraft.SourceDir);

                    <path d="@GetOrthogonalPath(startPoint, mousePoint, State.ActiveDraft.SourceDir, adaptiveTargetDir)"
                          stroke="#0d6efd" stroke-width="2" fill="none" stroke-dasharray="4" />
                }

                @foreach (var node in State.Nodes)
                {
                        <g transform="translate(@(node.X), @(node.Y))" class="node @(node.IsSelected ? "node-selected" : "")">
    
                            @* The dynamic shape *@
                            @switch (node.Shape)
                            {
                                case NodeShape.Circle:
                                    <ellipse cx="@(node.Width / 2)" cy="@(node.Height / 2)"
                                             rx="@(node.Width / 2)" ry="@(node.Height / 2)"
                                             fill="#ffffff" stroke="@(node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                                             @onpointerdown="e => HandleNodePointerDown(e, node)" />
                                    break;

                                case NodeShape.Diamond:
                                    // Calculated as a polygon path: Top, Right, Bottom, Left
                                    var points = $"{node.Width / 2},0 {node.Width},{node.Height / 2} {node.Width / 2},{node.Height} 0,{node.Height / 2}";
                                    <polygon points="@points"
                                             fill="#ffffff" stroke="@(node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                                             @onpointerdown="e => HandleNodePointerDown(e, node)" />
                                    break;

                                default: // Rectangle
                                         @* Main Body *@
                                         <rect width="@(node.Width)" height="@(node.Height)" rx="6"
                                               fill="#ffffff" stroke="@(node.IsSelected ? "#0d6efd" : "#555")" stroke-width="2"
                                               @onpointerdown="e => HandleNodePointerDown(e, node)" />

                                    @if (node.IsSelected)
                                    {
                                        @* Edge Handles (Invisible) *@
                                        <rect x="0" y="-4" width="@(node.Width)" height="8" style="cursor:ns-resize" fill="transparent" @onpointerdown="e => StartResize(e, node, ResizeDirection.Top)" @onpointerdown:stopPropagation />
                                        <rect x="@(node.Width - 4)" y="0" width="8" height="@(node.Height)" style="cursor:ew-resize" fill="transparent" @onpointerdown="e => StartResize(e, node, ResizeDirection.Right)" @onpointerdown:stopPropagation />
                                        <rect x="0" y="@(node.Height - 4)" width="@(node.Width)" height="8" style="cursor:ns-resize" fill="transparent" @onpointerdown="e => StartResize(e, node, ResizeDirection.Bottom)" @onpointerdown:stopPropagation />
                                        <rect x="-4" y="0" width="8" height="@(node.Height)" style="cursor:ew-resize" fill="transparent" @onpointerdown="e => StartResize(e, node, ResizeDirection.Left)" @onpointerdown:stopPropagation />

                                        @* Corner Handles (Small visible dots) *@
                                        <rect x="-4" y="-4" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nwse-resize" @onpointerdown="e => StartResize(e, node, ResizeDirection.TopLeft)" @onpointerdown:stopPropagation />
                                        <rect x="@(node.Width - 4)" y="-4" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nesw-resize" @onpointerdown="e => StartResize(e, node, ResizeDirection.TopRight)" @onpointerdown:stopPropagation />
                                        <rect x="-4" y="@(node.Height - 4)" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nesw-resize" @onpointerdown="e => StartResize(e, node, ResizeDirection.BottomLeft)" @onpointerdown:stopPropagation />
                                        <rect x="@(node.Width - 4)" y="@(node.Height - 4)" width="8" height="8" fill="white" stroke="#0d6efd" style="cursor:nwse-resize" @onpointerdown="e => StartResize(e, node, ResizeDirection.BottomRight)" @onpointerdown:stopPropagation />
                                    }
                                    break;
                            }

                            @* Center the text based on the shape *@
                            <text x="@(node.Width / 2)" y="@(node.Height / 2 + 5)"
                                  fill="white" text-anchor="middle" style="pointer-events:none; font-weight:bold">
                                @node.Title
                            </text>
                        

                        @foreach (var direction in Enum.GetValues<AnchorDirection>())
                        {
                            var anchor = GetLocalAnchorPosition(node, direction);
                            <circle cx="@anchor.X" cy="@anchor.Y" r="6" fill="#0d6efd" style="cursor:crosshair"
                                    @onpointerdown="e => StartInteraction(e, node, DesignerState.Connecting, direction)"
                                    @onpointerdown:stopPropagation />
                        }

                        @if (_currentMode == DesignerState.Connecting)
                        {
                            @foreach (var direction in Enum.GetValues<AnchorDirection>())
                            {
                                var anchor = GetLocalAnchorPosition(node, direction);
                                <circle cx="@anchor.X" cy="@anchor.Y" r="4" fill="#0d6efd" style="cursor:crosshair"
                                        @onpointerdown="e => StartInteraction(e, node, DesignerState.Connecting, direction)"
                                        @onpointerdown:stopPropagation />
                            }
                        }
                    </g>
                }
            </svg>
        </div>
    </div>
    </div>
    <JsonViewer State="@State" />
</div>

@code {
    private ElementReference _canvasContainer;
    private DesignerState _currentMode = DesignerState.None;
    private DesignerNode? _activeNode;
    private AnchorDirection _activeAnchorDirection;

    private double _startMouseX, _startMouseY;
    private double _startNodeX, _startNodeY;
    private double _startNodeWidth, _startNodeHeight;

    [Flags]
    private enum ResizeDirection
    {
        None = 0, Top = 1, Bottom = 2, Left = 4, Right = 8,
        TopLeft = Top | Left, TopRight = Top | Right,
        BottomLeft = Bottom | Left, BottomRight = Bottom | Right
    }

    private ResizeDirection _currentResizeDir = ResizeDirection.None;
    private string _activeEdge = "";

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    private async Task HandleBackgroundPointerDown(PointerEventArgs e)
    {
        State.DeselectAll();
        await StartInteraction(e, null, DesignerState.Panning);
    }

    private async Task HandleNodePointerDown(PointerEventArgs e, DesignerNode node)
    {
        State.Select(node);
        await StartInteraction(e, node, DesignerState.Dragging);
    }

    private async Task StartInteraction(PointerEventArgs e, DesignerNode? node, DesignerState mode, AnchorDirection direction = AnchorDirection.Left)
    {
        _currentMode = mode;
        _activeNode = node;
        _activeAnchorDirection = direction;

        var dimensions = await JS.InvokeAsync<BoundingRect>("getDimensions", _canvasContainer);
        State.Session.ViewportWidth = dimensions.Width;
        State.Session.ViewportHeight = dimensions.Height;

        var (worldX, worldY) = State.Session.ScreenToWorld(e.ClientX, e.ClientY, dimensions.Left, dimensions.Top);
        _startMouseX = worldX;
        _startMouseY = worldY;

        if (node != null)
        {
            _startNodeX = node.X;
            _startNodeY = node.Y;
            _startNodeWidth = node.Width;
            _startNodeHeight = node.Height;

            if (mode == DesignerState.Connecting)
            {
                State.ActiveDraft = new ConnectionDraft { Source = node, SourceDir = direction, MouseX = worldX, MouseY = worldY };
            }
        }
        State.Notify();
    }

    private async Task HandlePointerMove(PointerEventArgs e)
    {
        var dimensions = await JS.InvokeAsync<BoundingRect>("getDimensions", _canvasContainer);
        var (worldX, worldY) = State.Session.ScreenToWorld(e.ClientX, e.ClientY, dimensions.Left, dimensions.Top);

        if (State.PendingNewNode != null)
        {
            UpdatePendingNodePosition(worldX, worldY);
            return;
        }

        if (_currentMode == DesignerState.None) return;

        UpdateActiveInteraction(worldX, worldY);
        State.Notify();
    }

    private void UpdatePendingNodePosition(double worldX, double worldY)
    {
        State.PendingNewNode!.X = worldX - (State.PendingNewNode.Width / 2);
        State.PendingNewNode.Y = worldY - (State.PendingNewNode.Height / 2);
        State.Notify();
    }

    private void UpdateActiveInteraction(double worldX, double worldY)
    {
        double deltaX = worldX - _startMouseX;
        double deltaY = worldY - _startMouseY;

        switch (_currentMode)
        {
            case DesignerState.Dragging:
                _activeNode!.X = _startNodeX + deltaX;
                _activeNode!.Y = _startNodeY + deltaY;
                break;
            case DesignerState.Resizing:
                if (_activeEdge == "right")
                    _activeNode!.Width = Math.Max(100, _startNodeWidth + deltaX);
    
                if (_activeEdge == "bottom")
                    _activeNode!.Height = Math.Max(50, _startNodeHeight + deltaY);
    
                if (_activeEdge == "left")
                {
                    var newWidth = Math.Max(100, _startNodeWidth - deltaX);
                    if (newWidth > 100)
                    {
                        _activeNode!.X = _startNodeX + deltaX;
                        _activeNode!.Width = newWidth;
                    }
                }
    
                if (_activeEdge == "top")
                {
                    var newHeight = Math.Max(50, _startNodeHeight - deltaY);
                    if (newHeight > 50)
                    {
                        _activeNode!.Y = _startNodeY + deltaY;
                        _activeNode!.Height = newHeight;
                    }
                }
                State.Notify();
                break;
            case DesignerState.Panning:
                State.Session.PanX -= deltaX;
                State.Session.PanY -= deltaY;
                break;
            case DesignerState.Connecting:
                State.ActiveDraft!.MouseX = worldX;
                State.ActiveDraft!.MouseY = worldY;

                // RE-SNAP LOGIC:
                // If the mouse moves significantly away from the original anchor,
                // switch the SourceDir to the one currently "facing" the mouse.
                var currentBestDir = GetBestDirectionFromPoint(worldX, worldY, _activeNode!);
    
                if (State.ActiveDraft.SourceDir != currentBestDir)
                {
                    State.ActiveDraft.SourceDir = currentBestDir;
                    // Update _activeAnchorDirection so the FinalizeConnection
                    // uses the new direction too.
                    _activeAnchorDirection = currentBestDir;
                }
                break;
        }
    }

    private void HandlePointerUp(PointerEventArgs e)
    {
        if (State.PendingNewNode != null)
        {
            State.Nodes.Add(State.PendingNewNode);
            State.PendingNewNode = null;
        }
        else if (_currentMode == DesignerState.Connecting && State.ActiveDraft != null)
        {
            TryFinalizeConnection();
        }

        _currentMode = DesignerState.None;
        State.ActiveDraft = null;
        State.Notify();
    }

    private void TryFinalizeConnection()
    {
        var targetNode = State.Nodes.FirstOrDefault(n => n != _activeNode && IsPointInsideNode(State.ActiveDraft!.MouseX, State.ActiveDraft.MouseY, n));

        if (targetNode != null)
        {
            var targetDir = GetClosestAnchorDirection(State.ActiveDraft!.MouseX, State.ActiveDraft.MouseY, targetNode);
            State.Connections.Add(new DesignerConnection
            {
                Source = _activeNode!,
                SourceDir = _activeAnchorDirection,
                Target = targetNode,
                TargetDir = targetDir,
                EngineConnection = new Connection { From = _activeNode!.NodeData, To = targetNode.NodeData }
            });
        }
    }

    private AnchorDirection GetBestDirectionFromPoint(double mouseX, double mouseY, DesignerNode node)
    {
        double centerX = node.X + (node.Width / 2);
        double centerY = node.Y + (node.Height / 2);

        double dx = mouseX - centerX;
        double dy = mouseY - centerY;

        // Use the aspect ratio to normalize the vector (important for wide/tall nodes)
        double absX = Math.Abs(dx) / node.Width;
        double absY = Math.Abs(dy) / node.Height;

        if (absX > absY)
        {
            return dx > 0 ? AnchorDirection.Right : AnchorDirection.Left;
        }
        else
        {
            return dy > 0 ? AnchorDirection.Bottom : AnchorDirection.Top;
        }
    }


    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Delete" || e.Key == "Backspace") State.DeleteSelected();
    }

    private void HandleMouseWheel(WheelEventArgs e)
    {
        State.Session.Zoom = Math.Clamp(State.Session.Zoom * (e.DeltaY > 0 ? 0.9 : 1.1), 0.1, 3.0);
        State.Notify();
    }

    private (double X, double Y) GetLocalAnchorPosition(DesignerNode node, AnchorDirection direction) => direction switch
    {
        AnchorDirection.Right => (node.Width, node.Height / 2),
        AnchorDirection.Left => (0, node.Height / 2),
        AnchorDirection.Bottom => (node.Width / 2, node.Height),
        _ => (node.Width / 2, 0)
    };

    private string GetBezierCurvePath((double X, double Y) start, (double X, double Y) end, AnchorDirection startDir, AnchorDirection endDir)
    {
        const double intensity = 50;

        double control1X = start.X + (startDir == AnchorDirection.Right ? intensity : startDir == AnchorDirection.Left ? -intensity : 0);
        double control1Y = start.Y + (startDir == AnchorDirection.Bottom ? intensity : startDir == AnchorDirection.Top ? -intensity : 0);

        double control2X = end.X + (endDir == AnchorDirection.Right ? intensity : endDir == AnchorDirection.Left ? -intensity : 0);
        double control2Y = end.Y + (endDir == AnchorDirection.Bottom ? intensity : endDir == AnchorDirection.Top ? -intensity : 0);

        return string.Create(CultureInfo.InvariantCulture, $"M {start.X} {start.Y} C {control1X} {control1Y}, {control2X} {control2Y}, {end.X} {end.Y}");
    }

    private string GetOrthogonalPath((double X, double Y) start, (double X, double Y) end, AnchorDirection startDir, AnchorDirection endDir)
    {
        const double exitBuffer = 30;
    
        // 1. Calculate the initial exit point and final entry point
        var p1 = (X: start.X + GetDirectionX(startDir) * exitBuffer, Y: start.Y + GetDirectionY(startDir) * exitBuffer);
        var p4 = (X: end.X + GetDirectionX(endDir) * exitBuffer, Y: end.Y + GetDirectionY(endDir) * exitBuffer);

        // 2. Calculate midpoints (the "elbows")
        // We try to split the distance to create a clean 'Z' or 'U' shape
        var p2 = (X: 0.0, Y: 0.0);
        var p3 = (X: 0.0, Y: 0.0);

        if (startDir == AnchorDirection.Left || startDir == AnchorDirection.Right)
        {
            p2 = (X: p1.X + (p4.X - p1.X) / 2, Y: p1.Y);
            p3 = (X: p2.X, Y: p4.Y);
        }
        else // Top or Bottom
        {
            p2 = (X: p1.X, Y: p1.Y + (p4.Y - p1.Y) / 2);
            p3 = (X: p4.X, Y: p2.Y);
        }

        return string.Create(CultureInfo.InvariantCulture,
            $"M {start.X} {start.Y} L {p1.X} {p1.Y} L {p2.X} {p2.Y} L {p3.X} {p3.Y} L {p4.X} {p4.Y} L {end.X} {end.Y}");
    }

    private double GetDirectionX(AnchorDirection dir) => dir switch { AnchorDirection.Left => -1, AnchorDirection.Right => 1, _ => 0 };
    private double GetDirectionY(AnchorDirection dir) => dir switch { AnchorDirection.Top => -1, AnchorDirection.Bottom => 1, _ => 0 };


    private AnchorDirection GetOppositeDirection(AnchorDirection dir) => dir switch
    {
        AnchorDirection.Left => AnchorDirection.Right,
        AnchorDirection.Right => AnchorDirection.Left,
        AnchorDirection.Top => AnchorDirection.Bottom,
        _ => AnchorDirection.Top
    };

    private bool IsPointInsideNode(double x, double y, DesignerNode n) => x >= n.X && x <= n.X + n.Width && y >= n.Y && y <= n.Y + n.Height;

    private AnchorDirection GetClosestAnchorDirection(double x, double y, DesignerNode n)
    {
        var distances = new Dictionary<AnchorDirection, double> {
            { AnchorDirection.Left, Math.Abs(x - n.X) },
            { AnchorDirection.Right, Math.Abs(x - (n.X + n.Width)) },
            { AnchorDirection.Top, Math.Abs(y - n.Y) },
            { AnchorDirection.Bottom, Math.Abs(y - (n.Y + n.Height)) }
        };
        return distances.MinBy(kvp => kvp.Value).Key;
    }

    private void StartReRoute(PointerEventArgs e, DesignerConnection connection, bool isSource)
    {
        // 1. Create a draft based on the 'stationary' end
        if (isSource)
        {
            // We are moving the Source, so the Target is the stationary anchor
            State.ActiveDraft = new ConnectionDraft
            {
                Source = connection.Target,
                SourceDir = connection.TargetDir
            };
        }
        else
        {
            // We are moving the Target, so Source is the stationary anchor
            State.ActiveDraft = new ConnectionDraft
            {
                Source = connection.Source,
                SourceDir = connection.SourceDir
            };
        }

        // 2. Remove the old connection
        State.Connections.Remove(connection);
    
        // 3. Kick off the standard Connection interaction
        // This re-uses all your existing logic for snapping and ortho-pathing!
        _currentMode = DesignerState.Connecting;
        _activeNode = State.ActiveDraft.Source;
        _activeAnchorDirection = State.ActiveDraft.SourceDir;
    
        State.Notify();
    }

    private async Task StartResize(PointerEventArgs e, DesignerNode n, ResizeDirection edge)
    {
        _currentResizeDir = edge;
        await StartInteraction(e, n, DesignerState.Resizing);
    }

    public class BoundingRect { public double Left { get; set; } public double Top { get; set; } public double Width { get; set; } public double Height { get; set; } }


}