@using System.Security.Claims
@using System.Globalization
@using Argent.Contracts.Workflows
@using Argent.Runtime.Workflows
@using Argent.Runtime.Workflows.Modeling
@using Argent.Runtime.Workflows.Modeling.Routing
@using Argent.Models.Workflows
@using Microsoft.JSInterop
@using Argent.WebComponents.Core.Workflows.Modeler.Utils
@implements IAsyncDisposable
@inject DesignerService State
@inject IWorkflowNodeRegistry Registry
@inject IJSRuntime JS

<div class="modeler2-layout">
    @if (EffectiveReadOnly)
    {
        <div class="modeler2-toolbox modeler2-toolbox-readonly">
            <div class="modeler2-toolbox-header">
                <span class="modeler2-toolbox-title">Viewing old version</span>
            </div>
            <div class="modeler2-toolbox-list">
                <p class="modeler2-toolbox-readonly-msg">
                    <i class="bi bi-eye-fill"></i> This version is read-only.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="modeler2-toolbox">
            <div class="modeler2-toolbox-header">
                <span class="modeler2-toolbox-title">Components</span>
            </div>
            <div class="modeler2-toolbox-list">
                @foreach (var desc in Registry.GetRegisteredTypes().OrderBy(d => d.Category).ThenBy(d => d.DisplayName))
                {
                    <div class="modeler2-toolbox-item @desc.CssClass"
                         @onpointerdown="(e) => OnToolboxPointerDown(e, desc)">
                        <span class="modeler2-toolbox-icon material-symbols-outlined">@desc.Icon</span>
                        <span class="modeler2-toolbox-label">@desc.DisplayName</span>
                    </div>
                }
            </div>
        </div>
    }
    <div class="modeler2-main">
        <div class="modeler2-toolbar">
            <div class="modeler2-toolbar-left">
                <div class="modeler2-tool-group">
                    <button class="modeler2-tool-btn @(_activeTool == ActiveTool.Select ? "modeler2-tool-btn-active" : "")"
                            @onclick="() => _activeTool = ActiveTool.Select" title="Select (V)">
                        <i class="bi bi-hand-index-thumb"></i> Select
                    </button>
                    <button class="modeler2-tool-btn @(_activeTool == ActiveTool.AddSpace ? "modeler2-tool-btn-active" : "")"
                            @onclick="() => _activeTool = ActiveTool.AddSpace" title="Add/Remove Space">
                        <i class="bi bi-arrows-expand"></i> Space
                    </button>
                </div>
                <span class="modeler2-toolbar-sep"></span>
                <span class="modeler2-toolbar-title">@State.CurrentWorkflowName</span>
                @if (!string.IsNullOrEmpty(State.CurrentWorkflowDescription))
                {
                    <span class="modeler2-toolbar-sep">—</span>
                    <span class="modeler2-toolbar-subtitle">@State.CurrentWorkflowDescription</span>
                }
            </div>
            <div class="modeler2-toolbar-right">
                @if (!EffectiveReadOnly)
                {
                    <button class="modeler2-btn-icon" title="Save" @onclick="HandleSave">
                        <i class="bi bi-save-fill"></i>
                    </button>
                    <button class="modeler2-btn-icon" title="Compile" @onclick="HandleCompile">
                        <i class="bi bi-gear-fill"></i>
                    </button>
                    <button class="modeler2-btn-icon" title="Publish"
                            disabled="@(!(State.CompiledDefinition is not null && State.ValidationResult?.Errors.Count == 0))"
                            @onclick="HandlePublish">
                        <i class="bi bi-cloud-arrow-up-fill"></i>
                    </button>
                    @if (State.CompiledDefinition != null)
                    {
                        <button class="modeler2-btn-icon" title="Test Run" @onclick="HandleTestRun">
                            <i class="bi bi-play-fill"></i>
                        </button>
                    }
                    <span class="modeler2-toolbar-sep"></span>
                }
                <button class="modeler2-btn-icon" title="Fit to screen" @onclick="FitToScreen">
                    <i class="bi bi-arrows-angle-contract"></i>
                </button>
                <span class="modeler2-zoom-label">@(Math.Round(Session.Zoom * 100))%</span>
            </div>
        </div>
        <div class="modeler2-body">
            <div @ref="_canvasContainer" class="modeler2-canvas @(_activeTool == ActiveTool.AddSpace ? "modeler2-cursor-space" : "")"
                 tabindex="0"
                 @onpointerdown="OnPointerDown"
                 @onpointermove="OnPointerMove"
                 @onpointerup="OnPointerUp"
                 @onpointerleave="OnPointerUp"
                 @onpointercancel="OnPointerUp"
                 @onwheel="OnMouseWheel"
                 @onwheel:preventDefault
                  @onkeydown="OnKeyDown"
                  @onkeyup="OnKeyUp"
                  @oncontextmenu:preventDefault>

                <svg viewBox="@Session.ViewBox" width="100%" height="100%" style="display: block;">
                    <defs>
                        <pattern id="g2-grid" width="50" height="50" patternUnits="userSpaceOnUse">
                            <circle cx="2" cy="2" r="1" fill="#444" />
                        </pattern>
                        <marker id="g2-arrowhead" markerWidth="6" markerHeight="4.5" refX="5" refY="2.25" orient="auto">
                            <polygon points="0 0, 6 2.25, 0 4.5" fill="currentColor" />
                        </marker>
                    </defs>

                    <rect x="@Session.PanX" y="@Session.PanY"
                          width="@(Session.CanvasWidth / Session.Zoom)"
                          height="@(Session.CanvasHeight / Session.Zoom)"
                          fill="url(#g2-grid)" />

                    @* Connections *@
                    @foreach (var conn in State.Connections)
                    {
                        var wps = conn.Waypoints;
                        if (wps.Count < 2) continue;
                        var isSel = State.SelectedConnection == conn;
                        var path = RoutingService.WaypointsToSvgPath(wps);

                        <g class="modeler2-conn @(isSel ? "modeler2-conn-selected" : "")"
                           @onpointerdown:stopPropagation
                           @ondblclick="(e) => OnConnectionDoubleClick(e, conn)">

                            <path d="@path" stroke="transparent" stroke-width="14" fill="none"
                                  style="cursor: pointer;"
                                  @onpointerdown="(e) => OnConnectionPointerDown(e, conn)" />

                            <path d="@path" class="modeler2-conn-path" fill="none"
                                  marker-end="url(#g2-arrowhead)" />

                            @if (isSel)
                            {
                                for (int i = 1; i < wps.Count - 1; i++)
                                {
                                    <circle cx="@wps[i].X" cy="@wps[i].Y" r="5"
                                            class="modeler2-waypoint"
                                            @onpointerdown:stopPropagation
                                            @onpointerdown="(e) => OnWaypointPointerDown(e, conn, i)" />
                                }
                            }
                        </g>
                    }

                    @* Draft connection *@
                    @if (_draftConnection != null)
                    {
                        var draftPath = RoutingService.DraftPath(
                            _draftConnection.Source, _draftConnection.SourceDir,
                            _draftConnection.MouseX, _draftConnection.MouseY,
                            _draftConnection.TargetHint);
                        <path d="@draftPath" class="modeler2-draft-path" marker-end="url(#g2-arrowhead)" />
                    }

                    @* Pending node preview *@
                    @if (_pendingNodeDesc != null)
                    {
                        <g transform="translate(@_pendingNodeX, @_pendingNodeY)" class="modeler2-pending-node">
                            @switch (_pendingNodeShape)
                            {
                                case NodeShape.Circle:
                                    <ellipse cx="@(_pendingNodeW / 2)" cy="@(_pendingNodeH / 2)"
                                             rx="@(_pendingNodeW / 2)" ry="@(_pendingNodeH / 2)"
                                             class="modeler2-node-shape @_pendingNodeCss" />
                                    break;
                                case NodeShape.Diamond:
                                    <polygon points="@($"{_pendingNodeW / 2},0 {_pendingNodeW},{_pendingNodeH / 2} {_pendingNodeW / 2},{_pendingNodeH} 0,{_pendingNodeH / 2}")"
                                             class="modeler2-node-shape @_pendingNodeCss" />
                                    break;
                                default:
                                    <rect x="0" y="0" width="@_pendingNodeW" height="@_pendingNodeH" rx="6"
                                          class="modeler2-node-shape @_pendingNodeCss" />
                                    break;
                            }
                            <text x="@(_pendingNodeW / 2)" y="@(_pendingNodeH / 2 + 4)" text-anchor="middle"
                                  class="modeler2-node-label" dominant-baseline="middle">@_pendingNodeTitle</text>
                        </g>
                    }

                    @* Snap guides *@
                    @if (_snapResult?.TargetNode != null)
                    {
                        <g class="modeler2-snap-guides">
                            <rect x="@(_snapResult.TargetNode.X - _snapHighlightPadding)"
                                  y="@(_snapResult.TargetNode.Y - _snapHighlightPadding)"
                                  width="@(_snapResult.TargetNode.Width + _snapHighlightPadding * 2)"
                                  height="@(_snapResult.TargetNode.Height + _snapHighlightPadding * 2)"
                                  class="modeler2-snap-highlight" />

                            @if (_snapResult.XSnapAxis != null && _activeNode != null)
                            {
                                double x = _snapResult.XSnapAxis switch
                                {
                                    SnapAxis.Start => _snapResult.SnappedX,
                                    SnapAxis.Center => _snapResult.SnappedX + _activeNode.Width / 2,
                                    SnapAxis.End => _snapResult.SnappedX + _activeNode.Width,
                                    _ => _snapResult.SnappedX
                                };

                                double top = Math.Min(_snapResult.SnappedY, _snapResult.TargetNode.Y) - 1000;
                                double bottom = Math.Max(_snapResult.SnappedY + _activeNode.Height, _snapResult.TargetNode.Y + _snapResult.TargetNode.Height) + 1000;

                                <line x1="@x" y1="@top" x2="@x" y2="@bottom" class="modeler2-snap-line" />
                            }

                            @if (_snapResult.YSnapAxis != null && _activeNode != null)
                            {
                                double y = _snapResult.YSnapAxis switch
                                {
                                    SnapAxis.Start => _snapResult.SnappedY,
                                    SnapAxis.Center => _snapResult.SnappedY + _activeNode.Height / 2,
                                    SnapAxis.End => _snapResult.SnappedY + _activeNode.Height,
                                    _ => _snapResult.SnappedY
                                };

                                double left = Math.Min(_snapResult.SnappedX, _snapResult.TargetNode.X) - 20;
                                double right = Math.Max(_snapResult.SnappedX + _activeNode.Width, _snapResult.TargetNode.X + _snapResult.TargetNode.Width) + 20;

                                <line x1="@left" y1="@y" x2="@right" y2="@y" class="modeler2-snap-line" />
                            }
                        </g>
                    }

                    @* Rubber band selection *@
                    @if (_mode == Mode.Selecting)
                    {
                        double rx = Math.Min(_selStartX, _selEndX);
                        double ry = Math.Min(_selStartY, _selEndY);
                        double rw = Math.Abs(_selEndX - _selStartX);
                        double rh = Math.Abs(_selEndY - _selStartY);
                        <rect x="@rx" y="@ry" width="@rw" height="@rh"
                              class="modeler2-rubber-band" />
                    }

                    @* Space tool guide *@
                    @if (_mode == Mode.SpaceTool && _spaceDirectionLocked)
                    {
                        var vpTop = Session.PanY;
                        var vpBottom = Session.PanY + Session.CanvasHeight / Session.Zoom;
                        var vpLeft = Session.PanX;
                        var vpRight = Session.PanX + Session.CanvasWidth / Session.Zoom;

                        @if (_spaceIsHorizontal)
                        {
                            @* horizontal drag → vertical cut line *@
                            <line class="modeler2-space-guide"
                                  x1="@_spaceStartX" y1="@vpTop"
                                  x2="@_spaceStartX" y2="@vpBottom" />
                        }
                        else
                        {
                            @* vertical drag → horizontal cut line *@
                            <line class="modeler2-space-guide"
                                  x1="@vpLeft" y1="@_spaceStartY"
                                  x2="@vpRight" y2="@_spaceStartY" />
                        }
                    }

                    @* Space tool crosshair *@
                    @if (_activeTool == ActiveTool.AddSpace && _mode == Mode.Idle)
                    {
                        var vpTop = Session.PanY;
                        var vpBottom = Session.PanY + Session.CanvasHeight / Session.Zoom;
                        var vpLeft = Session.PanX;
                        var vpRight = Session.PanX + Session.CanvasWidth / Session.Zoom;

                        <line class="modeler2-space-crosshair" x1="@vpLeft" y1="@_spaceCursorY"
                              x2="@vpRight" y2="@_spaceCursorY" />
                        <line class="modeler2-space-crosshair" x1="@_spaceCursorX" y1="@vpTop"
                              x2="@_spaceCursorX" y2="@vpBottom" />
                    }

                    @* Nodes *@
                    @foreach (var node in State.Nodes)
                    {
                        var isSel = _selectedNodes.Contains(node);

                        var isHighlighted = _highlightedNodeId.HasValue && node.NodeData.Id == _highlightedNodeId.Value;

                        <g class="modeler2-node @(isSel ? "modeler2-node-selected" : "") @(isHighlighted ? "modeler2-node-highlighted" : "")"
                           transform="translate(@node.X.ToString("F2", CultureInfo.InvariantCulture), @node.Y.ToString("F2", CultureInfo.InvariantCulture))"
                           @onpointerdown="(e) => OnNodePointerDown(e, node)"
                           @ondblclick="() => OnNodeDoubleClick(node)">

                            @switch (node.Shape)
                            {
                                case NodeShape.Circle:
                                    <ellipse cx="@(node.Width / 2)" cy="@(node.Height / 2)"
                                             rx="@(node.Width / 2)" ry="@(node.Height / 2)"
                                             class="modeler2-node-shape @node.CssClass" />
                                    break;
                                case NodeShape.Diamond:
                                    <polygon points="@($"{(node.Width / 2).ToString("F2", CultureInfo.InvariantCulture)},0 {node.Width.ToString("F2", CultureInfo.InvariantCulture)},{(node.Height / 2).ToString("F2", CultureInfo.InvariantCulture)} {(node.Width / 2).ToString("F2", CultureInfo.InvariantCulture)},{node.Height.ToString("F2", CultureInfo.InvariantCulture)} 0,{(node.Height / 2).ToString("F2", CultureInfo.InvariantCulture)}")"
                                             class="modeler2-node-shape @node.CssClass" />
                                    break;
                                default:
                                    <rect x="0" y="0" width="@node.Width" height="@node.Height" rx="6"
                                          class="modeler2-node-shape @node.CssClass" />
                                    break;
                            }

                            <text x="@(node.Width / 2)" y="@(node.Height / 2 + 4)"
                                  text-anchor="middle" class="modeler2-node-label"
                                  dominant-baseline="middle">@(node.Title ?? "")</text>

                            @* Anchors *@
                            @if (!IsReadOnly && isSel)
                            {
                                var anchors = AnchorService.GetAnchors(node);
                                foreach (var a in anchors)
                                {
                                    <circle cx="@(a.X - node.X)" cy="@(a.Y - node.Y)" r="6"
                                            class="modeler2-anchor"
                                            @onpointerdown:stopPropagation
                                            @onpointerdown="(e) => OnAnchorPointerDown(e, node, a.dir)" />
                                }
                            }

                            @* Resize handles *@
                            @if (!IsReadOnly && isSel && node.Shape != NodeShape.Circle)
                            {
                                <rect x="0" y="-4" width="@node.Width" height="8" fill="transparent"
                                      style="cursor: ns-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.Top)" />
                                <rect x="@(node.Width - 4)" y="0" width="8" height="@node.Height" fill="transparent"
                                      style="cursor: ew-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.Right)" />
                                <rect x="0" y="@(node.Height - 4)" width="@node.Width" height="8" fill="transparent"
                                      style="cursor: ns-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.Bottom)" />
                                <rect x="-4" y="0" width="8" height="@node.Height" fill="transparent"
                                      style="cursor: ew-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.Left)" />

                                <rect x="-5" y="-5" width="10" height="10" fill="transparent"
                                      style="cursor: nwse-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.TopLeft)" />
                                <rect x="@(node.Width - 5)" y="-5" width="10" height="10" fill="transparent"
                                      style="cursor: nesw-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.TopRight)" />
                                <rect x="-5" y="@(node.Height - 5)" width="10" height="10" fill="transparent"
                                      style="cursor: nesw-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.BottomLeft)" />
                                <rect x="@(node.Width - 5)" y="@(node.Height - 5)" width="10" height="10" fill="transparent"
                                      style="cursor: nwse-resize;"
                                      @onpointerdown:stopPropagation
                                      @onpointerdown="(e) => OnResizeStart(e, node, ResizeDir.BottomRight)" />
                            }
                        </g>
                    }
                </svg>

                @if (_editingNode != null)
                {
                    <div @onpointerdown:stopPropagation>
                        <ModelerPropertiesPanel Node="_editingNode"
                                                 State="@State"
                                                 Registry="@Registry"
                                                 OnClose="@ClosePropertiesPanel" />
                    </div>
                }
            </div>

            <ModelerSidebar State="@State" OnHoverNode="OnSidebarHoverNode" OnVersionLoaded="OnVersionLoaded" />
        </div>
    </div>
</div>

@code {
    [Parameter] public ClaimsPrincipal? User { get; set; }
    [Parameter] public Guid? WorkflowId { get; set; }
    [Parameter] public bool IsReadOnly { get; set; }

    private bool EffectiveReadOnly => IsReadOnly || State.IsReadOnlyVersion;

    private ElementReference _canvasContainer;
    private DotNetObjectReference<WorkflowModeler>? _dotNetRef;
    private ModelerSession Session { get; } = new();

    // Tools
    private enum ActiveTool { Select, AddSpace }
    private ActiveTool _activeTool = ActiveTool.Select;
    private HashSet<DesignerNode> _selectedNodes = new();
    private Guid? _highlightedNodeId;

    // Modes
    private enum Mode { Idle, Panning, Selecting, Dragging, Connecting, Resizing, WaypointDrag, SegmentDrag, SpaceTool }
    private Mode _mode = Mode.Idle;

    // Pending node from toolbox
    private NodeTypeDescriptor? _pendingNodeDesc;
    private double _pendingNodeX, _pendingNodeY;
    private double _pendingNodeW = 160, _pendingNodeH = 80;
    private NodeShape _pendingNodeShape;
    private string _pendingNodeCss = "";
    private string _pendingNodeTitle = "";

    // Drag / pan
    private DesignerNode? _activeNode;
    private DesignerNode? _editingNode;
    private DesignerConnection? _activeConnection;
    private double _startMouseX, _startMouseY;
    private double _startPanX, _startPanY;
    private double _startNodeX, _startNodeY;
    private double _startNodeW, _startNodeH;
    private double _prevNodeX, _prevNodeY;

    // Connection draft
    private ConnectionDraft? _draftConnection;

    // Waypoint drag
    private int _draggedWpIdx = -1;

    // Segment drag
    private int _segmentIdx = -1;
    private double _dragStartX, _dragStartY;

    // Space tool
    private double _spaceStartX, _spaceStartY;
    private double _spaceCursorX, _spaceCursorY;
    private bool _spaceIsHorizontal;
    private bool _spaceDirectionLocked;
    private Dictionary<DesignerNode, (double X, double Y)>? _nodeOrigins;

    // Rubber band selection
    private double _selStartX, _selStartY;
    private double _selEndX, _selEndY;

    // Resize
    [Flags] private enum ResizeDir
    {
        None = 0, Top = 1, Bottom = 2, Left = 4, Right = 8,
        TopLeft = Top | Left, TopRight = Top | Right,
        BottomLeft = Bottom | Left, BottomRight = Bottom | Right
    }
    private ResizeDir _resizeDir = ResizeDir.None;
    private const double ResizeMinW = 80;
    private const double ResizeMinH = 50;

    // Snap
    private SnapResult? _snapResult;
    private const double _snapHighlightPadding = 4;

    protected override void OnInitialized() => State.OnChange += StateHasChanged;

    protected override async Task OnInitializedAsync()
    {
        if (WorkflowId.HasValue)
            await State.LoadWorkflowAsync(WorkflowId.Value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("Modeler2.init", _canvasContainer, _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnCanvasResized(double width, double height)
    {
        Session.CanvasWidth = width;
        Session.CanvasHeight = height;
        State.Notify();
    }

    public async ValueTask DisposeAsync()
    {
        State.OnChange -= StateHasChanged;
        if (_dotNetRef != null)
        {
            await JS.InvokeVoidAsync("Modeler2.destroy", _canvasContainer);
            _dotNetRef.Dispose();
        }
    }

    private Task<BoundingRect> GetCanvasRect() =>
        JS.InvokeAsync<BoundingRect>("Modeler2.getDimensions", _canvasContainer).AsTask();

    // ======================== TOOLBOX ========================

    private void OnToolboxPointerDown(PointerEventArgs e, NodeTypeDescriptor desc)
    {
        if (IsReadOnly) return;
        _pendingNodeDesc = desc;
        _pendingNodeW = desc.DefaultWidth;
        _pendingNodeH = desc.DefaultHeight;
        _pendingNodeShape = desc.Shape;
        _pendingNodeCss = desc.CssClass;
        _pendingNodeTitle = desc.DisplayName;
    }

    // ======================== POINTER HANDLERS ========================

    private async Task OnPointerDown(PointerEventArgs e)
    {
        if (IsReadOnly) return;
        if (_mode != Mode.Idle) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        if (_pendingNodeDesc != null)
        {
            PlaceNodeFromToolbox(wx, wy);
            return;
        }

        if (_activeTool == ActiveTool.AddSpace)
        {
            _mode = Mode.SpaceTool;
            _spaceStartX = wx;
            _spaceStartY = wy;
            _spaceDirectionLocked = false;
            _nodeOrigins = State.Nodes.ToDictionary(n => n, n => (n.X, n.Y));
            State.DeselectAll();
            _editingNode = null;
            _snapResult = null;
            State.Notify();
            return;
        }

        var hitNode = State.Nodes.FirstOrDefault(n =>
            wx >= n.X && wx <= n.X + n.Width &&
            wy >= n.Y && wy <= n.Y + n.Height);

        if (hitNode != null)
        {
            if (e.ShiftKey)
            {
                if (_selectedNodes.Contains(hitNode))
                    _selectedNodes.Remove(hitNode);
                else
                    _selectedNodes.Add(hitNode);

                if (_selectedNodes.Count > 0)
                    State.Select(_selectedNodes.Last());
                else
                    State.DeselectAll();

                _activeNode = hitNode;
                _mode = Mode.Dragging;
                _startNodeX = hitNode.X;
                _startNodeY = hitNode.Y;
                _prevNodeX = hitNode.X;
                _prevNodeY = hitNode.Y;
                State.Notify();
                return;
            }

            _selectedNodes.Clear();
            _selectedNodes.Add(hitNode);

            if (_editingNode != null && _editingNode != hitNode)
                _editingNode = null;

            State.Select(hitNode);
            _activeNode = hitNode;
            _mode = Mode.Dragging;
            _startNodeX = hitNode.X;
            _startNodeY = hitNode.Y;
            _prevNodeX = hitNode.X;
            _prevNodeY = hitNode.Y;
        }
        else
        {
            _editingNode = null;
            _snapResult = null;

            if (e.Button == 1 || e.CtrlKey)
            {
                // Middle-click or Ctrl+click → pan
                _mode = Mode.Panning;
                _startPanX = Session.PanX;
                _startPanY = Session.PanY;
            }
            else
            {
                // Left click → rubber band selection
                _selectedNodes.Clear();
                _mode = Mode.Selecting;
                _selStartX = wx;
                _selStartY = wy;
                _selEndX = wx;
                _selEndY = wy;
                State.DeselectAll();
            }

            State.Notify();
        }
    }

    private async Task OnPointerMove(PointerEventArgs e)
    {
        if (IsReadOnly) return;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);
        var (sx, sy) = Session.ScreenToWorld(_startMouseX, _startMouseY, dims.Left, dims.Top);

        if (_pendingNodeDesc != null)
        {
            _pendingNodeX = wx - _pendingNodeW / 2;
            _pendingNodeY = wy - _pendingNodeH / 2;
            State.Notify();
            return;
        }

        // Track cursor for space tool crosshair in idle
        if (_mode == Mode.Idle && _activeTool == ActiveTool.AddSpace)
        {
            _spaceCursorX = wx;
            _spaceCursorY = wy;
            State.Notify();
        }

        switch (_mode)
        {
            case Mode.Panning:
                Session.PanX = _startPanX - (wx - sx);
                Session.PanY = _startPanY - (wy - sy);
                State.Notify();
                break;

            case Mode.Selecting:
                _selEndX = wx;
                _selEndY = wy;
                State.Notify();
                break;

            case Mode.SpaceTool:
                if (_nodeOrigins == null) break;
                double spaceDx = wx - _spaceStartX;
                double spaceDy = wy - _spaceStartY;

                // Lock direction on first significant move
                if (!_spaceDirectionLocked && (Math.Abs(spaceDx) > 5 || Math.Abs(spaceDy) > 5))
                {
                    _spaceDirectionLocked = true;
                    _spaceIsHorizontal = Math.Abs(spaceDx) > Math.Abs(spaceDy);
                }

                if (!_spaceDirectionLocked) break;

                foreach (var node in State.Nodes)
                {
                    var orig = _nodeOrigins[node];
                    node.X = orig.X;
                    node.Y = orig.Y;
                }

                if (_spaceIsHorizontal)
                {
                    foreach (var node in State.Nodes)
                    {
                        var orig = _nodeOrigins[node];
                        if (orig.X > _spaceStartX)
                            node.X = orig.X + spaceDx;
                    }
                }
                else
                {
                    foreach (var node in State.Nodes)
                    {
                        var orig = _nodeOrigins[node];
                        if (orig.Y > _spaceStartY)
                            node.Y = orig.Y + spaceDy;
                    }
                }

                foreach (var node in State.Nodes)
                {
                    var orig = _nodeOrigins[node];
                    double dx = node.X - orig.X;
                    double dy = node.Y - orig.Y;
                    if (dx != 0 || dy != 0)
                        UpdateNodeConnections(node, dx, dy);
                }

                State.Notify();
                break;

            case Mode.Dragging:
                if (_activeNode != null)
                {
                    double dx = wx - sx;
                    double dy = wy - sy;
                    double rawX = _startNodeX + dx;
                    double rawY = _startNodeY + dy;
                    var snap = GetSnappedPosition(_activeNode, State.Nodes, rawX, rawY);

                    double snappedX = snap.XSnapAxis != null ? snap.SnappedX : rawX;
                    double snappedY = snap.YSnapAxis != null ? snap.SnappedY : rawY;

                    _activeNode.X = snappedX;
                    _activeNode.Y = snappedY;
                    _snapResult = snap;

                    UpdateNodeConnections(_activeNode, snappedX - _prevNodeX, snappedY - _prevNodeY);
                    _prevNodeX = snappedX;
                    _prevNodeY = snappedY;
                    State.Notify();
                }
                break;

            case Mode.Connecting:
                if (_draftConnection != null)
                {
                    _draftConnection.MouseX = wx;
                    _draftConnection.MouseY = wy;

                    if (_activeNode != null)
                    {
                        var (_, _, bestDir) = AnchorService.GetClosestAnchor(_activeNode, (wx, wy));
                        _draftConnection.SourceDir = bestDir;
                    }

                    _draftConnection.TargetHint = State.Nodes.FirstOrDefault(n =>
                        n != _activeNode &&
                        wx >= n.X && wx <= n.X + n.Width &&
                        wy >= n.Y && wy <= n.Y + n.Height);

                    State.Notify();
                }
                break;

            case Mode.Resizing:
                if (_activeNode != null)
                    ApplyResize(wx - sx, wy - sy);
                break;

            case Mode.WaypointDrag:
                if (_activeConnection != null && _draggedWpIdx >= 0)
                {
                    RoutingService.DragWaypoint(_activeConnection.Waypoints, _draggedWpIdx, wx, wy);
                    State.Notify();
                }
                break;

            case Mode.SegmentDrag:
                if (_activeConnection != null && _segmentIdx >= 0)
                {
                    RoutingService.DragSegment(_activeConnection.Waypoints, _segmentIdx,
                        ref _dragStartX, ref _dragStartY, wx, wy);
                    State.Notify();
                }
                break;
        }
    }

    private async Task OnPointerUp(PointerEventArgs e)
    {
        if (_mode == Mode.Connecting && _draftConnection != null)
            await TryFinalizeConnection(e.ClientX, e.ClientY);

        if (_mode == Mode.Selecting)
        {
            double rx = Math.Min(_selStartX, _selEndX);
            double ry = Math.Min(_selStartY, _selEndY);
            double rw = Math.Abs(_selEndX - _selStartX);
            double rh = Math.Abs(_selEndY - _selStartY);

            if (rw > 3 || rh > 3)
            {
                foreach (var n in State.Nodes)
                {
                    if (n.X + n.Width >= rx && n.X <= rx + rw &&
                        n.Y + n.Height >= ry && n.Y <= ry + rh)
                    {
                        _selectedNodes.Add(n);
                    }
                }
                if (_selectedNodes.Count > 0)
                    State.Select(_selectedNodes.Last());
            }
            State.Notify();
        }

        _mode = Mode.Idle;
        _activeNode = null;
        _activeConnection = null;
        _draggedWpIdx = -1;
        _segmentIdx = -1;
        _resizeDir = ResizeDir.None;
        _nodeOrigins = null;
        if (_snapResult != null && _snapResult.TargetNode != null)
        {
            _snapResult = null;
            State.Notify();
        }
    }

    // ======================== NODE INTERACTIONS ========================

    private async Task OnNodePointerDown(PointerEventArgs e, DesignerNode node)
    {
        if (IsReadOnly) return;
        if (_activeTool == ActiveTool.AddSpace) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        if (_pendingNodeDesc != null)
        {
            PlaceNodeFromToolbox(wx, wy);
            return;
        }

        if (e.ShiftKey)
        {
            if (_selectedNodes.Contains(node))
                _selectedNodes.Remove(node);
            else
                _selectedNodes.Add(node);

            if (_selectedNodes.Count > 0)
                State.Select(_selectedNodes.Last());
            else
                State.DeselectAll();

            _activeNode = node;
            _mode = Mode.Dragging;
            _startNodeX = node.X;
            _startNodeY = node.Y;
            _prevNodeX = node.X;
            _prevNodeY = node.Y;
            State.Notify();
            return;
        }

        _selectedNodes.Clear();
        _selectedNodes.Add(node);

        if (_editingNode != null && _editingNode != node)
            _editingNode = null;

        State.Select(node);
        _activeNode = node;
        _mode = Mode.Dragging;
        _startNodeX = node.X;
        _startNodeY = node.Y;
        _prevNodeX = node.X;
        _prevNodeY = node.Y;
        State.Notify();
    }

    private async Task OnNodeDoubleClick(DesignerNode node)
    {
        State.Select(node);
        _editingNode = node;
        State.Notify();
    }

