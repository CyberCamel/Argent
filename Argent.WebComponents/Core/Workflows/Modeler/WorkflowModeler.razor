    // ======================== ANCHOR / CONNECTION ========================

    private async Task OnAnchorPointerDown(PointerEventArgs e, DesignerNode node, AnchorDirection dir)
    {
        if (IsReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        _mode = Mode.Connecting;
        _activeNode = node;
        _draftConnection = new ConnectionDraft
        {
            Source = node,
            SourceDir = dir,
            MouseX = wx,
            MouseY = wy
        };
        State.Notify();
    }

    private async Task TryFinalizeConnection(double clientX, double clientY)
    {
        if (_draftConnection == null || _activeNode == null) return;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(clientX, clientY, dims.Left, dims.Top);

        var targetNode = State.Nodes.FirstOrDefault(n =>
            n != _activeNode &&
            wx >= n.X && wx <= n.X + n.Width &&
            wy >= n.Y && wy <= n.Y + n.Height);

        if (targetNode != null)
        {
            var (_, _, targetDir) = AnchorService.GetBestTargetAnchor(
                targetNode, (wx, wy), _draftConnection.SourceDir);

            var conn = new DesignerConnection
            {
                Source = _activeNode,
                SourceDir = _draftConnection.SourceDir,
                Target = targetNode,
                TargetDir = targetDir,
                EngineConnection = new Connection { From = _activeNode.NodeData, To = targetNode.NodeData },
            };
            conn.Waypoints = RoutingService.AutoRoute(conn.Source, conn.SourceDir, conn.Target, conn.TargetDir);
            State.Connections.Add(conn);
        }

        _draftConnection = null;
        State.Notify();
    }

    // ======================== CONNECTION INTERACTIONS ========================

    private async Task OnConnectionPointerDown(PointerEventArgs e, DesignerConnection conn)
    {
        if (IsReadOnly) return;
        if (_pendingNodeDesc != null) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        int segIdx = RoutingService.FindNearestSegment(conn.Waypoints, wx, wy);
        State.Select(conn);

        if (segIdx >= 0)
        {
            _mode = Mode.SegmentDrag;
            _segmentIdx = segIdx;
            _dragStartX = wx;
            _dragStartY = wy;
            _activeConnection = conn;
        }

        State.Notify();
    }

    private async Task OnConnectionDoubleClick(MouseEventArgs e, DesignerConnection conn)
    {
        if (IsReadOnly) return;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        int segIdx = RoutingService.FindNearestSegment(conn.Waypoints, wx, wy);
        if (segIdx >= 0)
        {
            RoutingService.InsertWaypointAtMidpoint(conn.Waypoints, segIdx);
            State.Notify();
        }
    }

    private async Task OnWaypointPointerDown(PointerEventArgs e, DesignerConnection conn, int idx)
    {
        if (IsReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        // Reroute endpoints
        if (idx == 0 || idx == conn.Waypoints.Count - 1)
        {
            bool isSource = idx == 0;
            var draft = new ConnectionDraft
            {
                Source = isSource ? conn.Target : conn.Source,
                SourceDir = isSource ? conn.TargetDir : conn.SourceDir,
                MouseX = wx,
                MouseY = wy
            };

            State.Connections.Remove(conn);
            _mode = Mode.Connecting;
            _activeNode = draft.Source;
            _draftConnection = draft;
            State.Notify();
            return;
        }

        _mode = Mode.WaypointDrag;
        _activeConnection = conn;
        _draggedWpIdx = idx;
        State.Notify();
    }

    // ======================== KEYBOARD ========================

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (EffectiveReadOnly) return;
        if (_editingNode != null) return;
        if (e.Key == "Shift") return;

        if (e.Key == "Escape")
        {
            _pendingNodeDesc = null;
            _draftConnection = null;
            _editingNode = null;
            _mode = Mode.Idle;
            _snapResult = null;
            _selectedNodes.Clear();
            State.DeselectAll();
            State.Notify();
        }
        else if (e.Key == "Delete" || e.Key == "Backspace")
        {
            if (_selectedNodes.Count > 0)
            {
                foreach (var n in _selectedNodes.ToList())
                {
                    State.Connections.RemoveAll(c => c.Source == n || c.Target == n);
                    State.Nodes.Remove(n);
                }
                _selectedNodes.Clear();
                State.DeselectAll();
            }
            else
            {
                State.DeleteSelected();
            }
            State.Notify();
        }
    }

    private void OnKeyUp(KeyboardEventArgs e) { }

    // ======================== MOUSE WHEEL ========================

    private async Task OnMouseWheel(WheelEventArgs e)
    {
        var dims = await GetCanvasRect();
        var (beforeX, beforeY) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        double factor = Math.Pow(1.001, -e.DeltaY);
        Session.Zoom = Math.Clamp(Session.Zoom * factor, 0.1, 3.0);

        var (afterX, afterY) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);
        Session.PanX += beforeX - afterX;
        Session.PanY += beforeY - afterY;

        State.Notify();
    }

    // ======================== PLACEMENT ========================

    private void PlaceNodeFromToolbox(double wx, double wy)
    {
        if (_pendingNodeDesc == null) return;

        var instance = Activator.CreateInstance(_pendingNodeDesc.NodeType) as NodeBase;
        if (instance == null) return;

        var node = new DesignerNode
        {
            NodeData = instance,
            Title = _pendingNodeDesc.DisplayName,
            Description = _pendingNodeDesc.Description,
            Icon = _pendingNodeDesc.Icon,
            CssClass = _pendingNodeDesc.CssClass,
            Shape = _pendingNodeDesc.Shape,
            Width = _pendingNodeW,
            Height = _pendingNodeH,
            X = wx - _pendingNodeW / 2,
            Y = wy - _pendingNodeH / 2,
        };

        State.Nodes.Add(node);
        State.Select(node);
        _pendingNodeDesc = null;
        State.Notify();
    }

    // ======================== RESIZE ========================

    private async Task OnResizeStart(PointerEventArgs e, DesignerNode node, ResizeDir dir)
    {
        if (IsReadOnly) return;

        _startMouseX = e.ClientX;
        _startMouseY = e.ClientY;

        var dims = await GetCanvasRect();
        var (wx, wy) = Session.ScreenToWorld(e.ClientX, e.ClientY, dims.Left, dims.Top);

        _mode = Mode.Resizing;
        _activeNode = node;
        _resizeDir = dir;
        _startNodeX = node.X;
        _startNodeY = node.Y;
        _startNodeW = node.Width;
        _startNodeH = node.Height;
    }

    private void ApplyResize(double dx, double dy)
    {
        if (_activeNode == null) return;
        var n = _activeNode;

        if (_resizeDir.HasFlag(ResizeDir.Right))
            n.Width = Math.Max(ResizeMinW, _startNodeW + dx);

        if (_resizeDir.HasFlag(ResizeDir.Bottom))
            n.Height = Math.Max(ResizeMinH, _startNodeH + dy);

        if (_resizeDir.HasFlag(ResizeDir.Left))
        {
            double newW = Math.Max(ResizeMinW, _startNodeW - dx);
            if (newW > ResizeMinW || dx < 0)
            {
                n.X = _startNodeX + (_startNodeW - newW);
                n.Width = newW;
            }
        }

        if (_resizeDir.HasFlag(ResizeDir.Top))
        {
            double newH = Math.Max(ResizeMinH, _startNodeH - dy);
            if (newH > ResizeMinH || dy < 0)
            {
                n.Y = _startNodeY + (_startNodeH - newH);
                n.Height = newH;
            }
        }

        State.Notify();
    }

    // ======================== ROUTING UPDATES ========================

    private void UpdateNodeConnections(DesignerNode node, double dx, double dy)
    {
        foreach (var conn in State.Connections)
        {
            if (conn.Source == node || conn.Target == node)
            {
                var (srcDir, tgtDir) = RoutingService.GetBestDirections(conn.Source, conn.Target);
                conn.SourceDir = srcDir;
                conn.TargetDir = tgtDir;
                conn.Waypoints = RoutingService.AutoRoute(
                    conn.Source, conn.SourceDir,
                    conn.Target, conn.TargetDir);
            }
        }
    }

