@using Argent.Models.Workflows
@using Argent.Contracts.Workflows
@using Argent.Runtime.Workflows.Modeling
@using Argent.Runtime.Workflows.Modeling.Routing
@using Argent.WebComponents.Core.Workflows.Enum
@using System.Globalization

<g transform="translate(@(Node.X.ToString(CultureInfo.InvariantCulture)), @(Node.Y.ToString(CultureInfo.InvariantCulture)))"
    class="node @Node.CssClass @(Node.IsSelected ? "node-selected" : "") @(State.ActiveTokenNodeIds.Contains(Node.NodeData.Id) ? "node-active" : "") @(State.VisitedNodeIds.Contains(Node.NodeData.Id) ? "node-visited" : "")"
   @onpointerdown="e => OnNodePointerDown.InvokeAsync((e, Node))"
   @ondblclick="() => OnNodeDoubleClick.InvokeAsync(Node)"
   @onpointerdown:stopPropagation>

    @switch (Node.Shape)
    {
        case NodeShape.Circle:
            <ellipse cx="@(Node.Width / 2)" cy="@(Node.Height / 2)"
                     rx="@(Node.Width / 2)" ry="@(Node.Height / 2)"
                     @onpointerdown="e => OnNodePointerDown.InvokeAsync((e, Node))" />
            break;

        case NodeShape.Diamond:
            var points = $"{Node.Width / 2},0 {Node.Width},{Node.Height / 2} {Node.Width / 2},{Node.Height} 0,{Node.Height / 2}";
            <polygon points="@points"
                     @onpointerdown="e => OnNodePointerDown.InvokeAsync((e, Node))" />
            break;

        default:
            <rect width="@(Node.Width)" height="@(Node.Height)" rx="6"
                  @onpointerdown="e => OnNodePointerDown.InvokeAsync((e, Node))" />

            @if (Node.IsSelected)
            {
                <rect x="0" y="-4" width="@(Node.Width)" height="8" style="cursor:ns-resize" fill="transparent" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.Top))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="0" width="8" height="@(Node.Height)" style="cursor:ew-resize" fill="transparent" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.Right))" @onpointerdown:stopPropagation />
                <rect x="0" y="@(Node.Height - 4)" width="@(Node.Width)" height="8" style="cursor:ns-resize" fill="transparent" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.Bottom))" @onpointerdown:stopPropagation />
                <rect x="-4" y="0" width="8" height="@(Node.Height)" style="cursor:ew-resize" fill="transparent" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.Left))" @onpointerdown:stopPropagation />

                <rect x="-4" y="-4" width="8" height="8" fill="white" stroke="var(--primary)" stroke-width="1.5" style="cursor:nwse-resize" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.TopLeft))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="-4" width="8" height="8" fill="white" stroke="var(--primary)" stroke-width="1.5" style="cursor:nesw-resize" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.TopRight))" @onpointerdown:stopPropagation />
                <rect x="-4" y="@(Node.Height - 4)" width="8" height="8" fill="white" stroke="var(--primary)" stroke-width="1.5" style="cursor:nesw-resize" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.BottomLeft))" @onpointerdown:stopPropagation />
                <rect x="@(Node.Width - 4)" y="@(Node.Height - 4)" width="8" height="8" fill="white" stroke="var(--primary)" stroke-width="1.5" style="cursor:nwse-resize" 
                      @onpointerdown="e => OnStartResize.InvokeAsync((e, Node, NodeResizeDirection.BottomRight))" @onpointerdown:stopPropagation />
            }
            break;
    }

    <text x="@(Node.Width / 2)" y="@(Node.Height / 2 + 5)"
          class="node-text" text-anchor="middle">
        @Node.Title
    </text>

    @foreach (var direction in Enum.GetValues<AnchorDirection>())
    {
        if (direction == AnchorDirection.None) continue;

        var anchor = AnchorService.GetBaseAnchor(Node, direction);
        var relativeX = anchor.X - Node.X;
        var relativeY = anchor.Y - Node.Y;

        <circle cx="@relativeX" cy="@relativeY" r="6" class="node-anchor"
                @onpointerdown="e => OnStartConnection.InvokeAsync((e, Node, direction))"
                @onpointerdown:stopPropagation />
    }

    @if (CurrentMode == nameof(DesignerState.Connecting))
    {
        @foreach (var direction in Enum.GetValues<AnchorDirection>())
        {
            if (direction == AnchorDirection.None) continue;

            var anchor = AnchorService.GetBaseAnchor(Node, direction);
            var relativeX = anchor.X - Node.X;
            var relativeY = anchor.Y - Node.Y;

            <circle cx="@relativeX" cy="@relativeY" r="6" class="node-anchor"
                    @onpointerdown="e => OnStartConnection.InvokeAsync((e, Node, direction))"
                    @onpointerdown:stopPropagation />
        }
    }
</g>

@code {
    [Parameter]
    public DesignerNode Node { get; set; } = default!;

    [Parameter]
    public DesignerService State { get; set; } = default!;

    [Parameter]
    public string CurrentMode { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerNode)> OnNodePointerDown { get; set; }

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerNode, NodeResizeDirection)> OnStartResize { get; set; }

    [Parameter]
    public EventCallback<(PointerEventArgs, DesignerNode, AnchorDirection)> OnStartConnection { get; set; }

    [Parameter]
    public EventCallback<DesignerNode> OnNodeDoubleClick { get; set; }

    public enum NodeResizeDirection
    {
        None = 0, Top = 1, Bottom = 2, Left = 4, Right = 8,
        TopLeft = Top | Left, TopRight = Top | Right,
        BottomLeft = Bottom | Left, BottomRight = Bottom | Right
    }
}

<style>
    .node-active > :not(text) {
        filter: drop-shadow(0 0 6px #10b981) drop-shadow(0 0 14px #10b9814d);
        transition: filter 0.3s ease;
    }
    .node-active ellipse,
    .node-active rect,
    .node-active polygon {
        stroke: #34d399 !important;
        stroke-width: 2.5 !important;
    }
    .node-visited ellipse,
    .node-visited rect,
    .node-visited polygon {
        opacity: 0.5;
        transition: opacity 0.3s ease;
    }
</style>
