@using System.Reflection
@using Argent.Models.Attributes
@using Argent.Models.Workflows.Modeler.Enums
@using Argent.Runtime.Workflows.Modeling
@using System.Globalization


@if (Node != null)
{
    <div class="property-floating-card shadow-lg border rounded bg-white"
         style="@CalculatePositionStyle()"
         @onwheel:stopPropagation
         @onpointerdown:stopPropagation>
        <div class="card-header bg-light d-flex justify-content-between align-items-center py-1 px-2 border-bottom">
            <span class="small fw-bold text-uppercase text-muted">@Node.Title</span>
            <button type="button" class="btn-close" style="scale: 0.6;" @onclick="HandleClose"></button>
        </div>
        <div class="card-body p-0" style="width: 320px; max-height: 450px; overflow-y: auto;">

            <div class="p-3 border-bottom">
                <div class="mb-3">
                    <label class="form-label fw-bold">Name</label>
                    <input class="form-control form-control-sm"
                           value="@Node.Title"
                           @oninput="@(e => { Node.Title = e.Value?.ToString() ?? ""; State.Notify(); })" />
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Description</label>
                    <textarea class="form-control form-control-sm" rows="2"
                              value="@Node.Description"
                              @oninput="@(e => { Node.Description = e.Value?.ToString() ?? ""; State.Notify(); })"></textarea>
                </div>
            </div>

            <div class="p-3">
                @foreach (var prop in GetProperties())
                {
                    var metadata = prop.GetCustomAttribute<NodePropertyAttribute>();
                    if (metadata == null) continue;

                    <div class="mb-3">
                        <label class="form-label small fw-bold mb-0">@metadata.Name</label>
                        @if (!string.IsNullOrEmpty(metadata.Description))
                        {
                            <div class="form-text mt-0 mb-1" style="font-size: 0.75rem;">@metadata.Description</div>
                        }

                        @* Simple Type Switch *@
                        @if (metadata.DataType == PropertyDataType.Code)
                        {
                            <textarea class="form-control form-control-sm font-monospace" rows="6"
                                      spellcheck="false"
                                      value="@prop.GetValue(Node.NodeData)"
                                      @oninput="@(e => UpdateValue(prop, e.Value))" />
                        }
                        else if (metadata.DataType == PropertyDataType.KeyValuePairs)
                        {
                            @* You can drop a small Dictionary Editor component here later *@
                            <div class="alert alert-secondary py-1 px-2 small">Dictionary Editor (TBD)</div>
                        }
                        else if (metadata.DataType == PropertyDataType.Boolean)
                        {
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox"
                                       checked="@((bool)prop.GetValue(Node.NodeData)!)"
                                       @onchange="@(e => UpdateValue(prop, e.Value))" />
                            </div>
                        }
                        else
                        {
                            <input class="form-control form-control-sm"
                                   value="@prop.GetValue(Node.NodeData)"
                                   @oninput="@(e => UpdateValue(prop, e.Value))" />
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public required DesignerService State { get; set; }
    [Parameter] public required DesignerNode Node { get; set; }
    [Parameter] public required EventCallback OnClose { get; set; }

    private IEnumerable<PropertyInfo> GetProperties()
        => Node.NodeData.GetType().GetProperties()
            .Where(p => p.GetCustomAttribute<NodePropertyAttribute>() != null)
            .OrderBy(p => p.GetCustomAttribute<NodePropertyAttribute>()?.Order ?? 100)
            ?? Enumerable.Empty<PropertyInfo>();

    private void UpdateValue(PropertyInfo prop, object? val)
    {
        if (Node == null) return;

        // Basic conversion for numbers
        if (prop.PropertyType == typeof(int) && int.TryParse(val?.ToString(), out var i))
            prop.SetValue(Node.NodeData, i);
        else if (prop.PropertyType == typeof(double) && double.TryParse(val?.ToString(), out var d))
            prop.SetValue(Node.NodeData, d);
        else
            prop.SetValue(Node.NodeData, val);

        State.Notify(); // Refresh the canvas in case labels changed
    }

    private string CalculatePositionStyle()
    {
        if (Node == null) return "display: none;";

        // We calculate the screen pixels relative to the canvas origin
        double x = (Node.X + Node.Width - State.Session.PanX) * State.Session.Zoom;
        double y = (Node.Y - State.Session.PanY) * State.Session.Zoom;

        // Add a 15px gap
        x += 15;

        return $@"
        position: absolute;
        top: 0;
        width: 350px;
        z-index: 1000;
        /* translate3d uses the GPU and handles the actual positioning */
        transform: translate3d({x.ToString(CultureInfo.InvariantCulture)}px, {y.ToString(CultureInfo.InvariantCulture)}px, 0);
        pointer-events: all;
    ";
    }

    private void HandleClose()
    {
        OnClose.InvokeAsync();
    }

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    // Don't forget to implement IDisposable to unhook the event!
    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}