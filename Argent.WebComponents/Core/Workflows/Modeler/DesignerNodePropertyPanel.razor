@using System.Reflection
@using Argent.Contracts.Workflows
@using Argent.Runtime.Workflows.Modeling
@inject IWorkflowNodeRegistry Registry

@if (Node != null)
{
    var descriptor = Registry.GetDescriptor(Node.NodeData.GetType());

    <div class="properties-panel" @onwheel:stopPropagation @onpointerdown:stopPropagation>
        <div class="properties-panel-header">
            <span class="properties-panel-title">
                <i class="bi bi-gear"></i> Properties —
                <span class="properties-panel-type">@(descriptor?.DisplayName ?? "Node")</span>
                <span class="properties-panel-separator">—</span>
                <span class="properties-panel-name">@Node.Title</span>
            </span>
            <div class="properties-panel-actions">
                <button type="button" class="properties-panel-close" @onclick="HandleClose" title="Close properties panel">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>
        <div class="properties-panel-body">
            <div class="properties-panel-section">
                <div class="properties-panel-field">
                    <label class="properties-panel-label">Name</label>
                    <input class="properties-panel-input"
                           value="@Node.Title"
                           @oninput="@(e => { Node.Title = e.Value?.ToString() ?? ""; State.MarkDirty(); })" />
                </div>
                <div class="properties-panel-field">
                    <label class="properties-panel-label">Description</label>
                    <textarea class="properties-panel-input properties-panel-textarea" rows="2"
                              value="@Node.Description"
                              @oninput="@(e => { Node.Description = e.Value?.ToString() ?? ""; State.MarkDirty(); })"></textarea>
                </div>
            </div>

            @if (descriptor != null)
            {
                <div class="properties-panel-section properties-panel-section-dynamic">
                    @foreach (var prop in descriptor.Properties.OrderBy(p => p.Order))
                    {
                        var propInfo = Node.NodeData.GetType().GetProperty(prop.PropertyName);
                        if (propInfo == null) continue;

                        <div class="properties-panel-field">
                            <label class="properties-panel-label">
                                @prop.DisplayName
                                @if (!string.IsNullOrEmpty(prop.Description))
                                {
                                    <span class="properties-panel-tip" title="@prop.Description">
                                        <i class="bi bi-info-circle"></i>
                                    </span>
                                }
                            </label>

                            @if (prop.DataType == PropertyDataType.Code)
                            {
                                <textarea class="properties-panel-input properties-panel-code"
                                          spellcheck="false" rows="4"
                                          value="@propInfo.GetValue(Node.NodeData)"
                                          @oninput="@(e => UpdateValue(propInfo, e.Value))" />
                            }
                            else if (prop.DataType == PropertyDataType.KeyValuePairs)
                            {
                                <span class="properties-panel-placeholder">Dictionary editor (coming soon)</span>
                            }
                            else if (prop.DataType == PropertyDataType.Boolean)
                            {
                                <label class="properties-panel-switch">
                                    <input type="checkbox"
                                           checked="@((bool?)propInfo.GetValue(Node.NodeData) ?? false)"
                                           @onchange="@(e => UpdateValue(propInfo, e.Value))" />
                                    <span class="properties-panel-switch-slider"></span>
                                </label>
                            }
                            else
                            {
                                <input class="properties-panel-input"
                                       value="@propInfo.GetValue(Node.NodeData)"
                                       @oninput="@(e => UpdateValue(propInfo, e.Value))" />
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public required DesignerService State { get; set; }
    [Parameter] public required DesignerNode Node { get; set; }
    [Parameter] public required EventCallback OnClose { get; set; }

    private void UpdateValue(PropertyInfo prop, object? val)
    {
        if (Node == null) return;

        if (prop.PropertyType == typeof(int) && int.TryParse(val?.ToString(), out var i))
            prop.SetValue(Node.NodeData, i);
        else if (prop.PropertyType == typeof(double) && double.TryParse(val?.ToString(), out var d))
            prop.SetValue(Node.NodeData, d);
        else if (prop.PropertyType == typeof(TimeSpan) && int.TryParse(val?.ToString(), out var seconds))
            prop.SetValue(Node.NodeData, TimeSpan.FromSeconds(seconds));
        else
            prop.SetValue(Node.NodeData, val);

        State.MarkDirty();
    }

    private void HandleClose()
    {
        OnClose.InvokeAsync();
    }

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
