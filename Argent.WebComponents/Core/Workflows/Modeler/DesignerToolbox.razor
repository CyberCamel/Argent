@using Argent.Contracts.Workflows
@using Argent.Models.Workflows
@using Argent.Runtime.Workflows.Modeling
@inject IWorkflowNodeRegistry Registry

<div class="designer-toolbox p-0 border-end bg-light d-flex flex-column @CssClass" style="width: 280px; height: 100vh; z-index: 10;">
    <div class="p-3 border-bottom bg-white">
        <h6 class="text-uppercase fw-bold mb-0" style="font-size: 0.8rem; letter-spacing: 1px;">
            <i class="bi bi-box-seam me-2"></i>Components
        </h6>
    </div>

    <div class="accordion accordion-flush overflow-auto flex-grow-1" id="toolboxAccordion">
        @{
            var groupedNodes = Registry.GetRegisteredTypes()
                                       .GroupBy(x => x.Category)
                                       .OrderBy(g => g.Key);
        }

        @foreach (var group in groupedNodes)
        {
            var categoryId = $"cat-{group.Key.Replace(" ", "")}";

            <div class="accordion-item border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button py-2 px-3 bg-light fw-semibold text-secondary"
                            type="button" data-bs-toggle="collapse" data-bs-target="#@categoryId"
                            style="font-size: 0.75rem; text-transform: uppercase;">
                        @group.Key
                    </button>
                </h2>
                <div id="@categoryId" class="accordion-collapse collapse show">
                    <div class="accordion-body p-2">
                        @foreach (var descriptor in group)
                        {
                            var indicatorClass = descriptor.CssClass switch
                            {
                                string c when c.Contains("node-start") => "indicator-start",
                                string c when c.Contains("node-end") => "indicator-end",
                                string c when c.Contains("node-script") => "indicator-script",
                                string c when c.Contains("node-user") => "indicator-user",
                                string c when c.Contains("gw-inclusive") => "indicator-gw-incl",
                                string c when c.Contains("gw-exclusive") => "indicator-gw-excl",
                                _ => ""
                            };
                            <div class="node-item d-flex align-items-center p-2 mb-1 rounded draggable-node @indicatorClass"
                                 @onpointerdown="@(() => HandleDragStart(descriptor))">

                                <div class="node-icon-wrapper d-flex align-items-center justify-content-center rounded bg-white border shadow-sm me-3"
                                     style="width: 36px; height: 36px; min-width: 36px;">
                                    <span class="material-symbols-outlined fs-5">
                                        @descriptor.Icon
                                    </span>
                                </div>

                                <div class="overflow-hidden">
                                    <div class="fw-bold text-dark text-truncate" style="font-size: 0.85rem;">
                                        @descriptor.DisplayName
                                    </div>
                                    <div class="text-muted text-truncate" style="font-size: 0.7rem;">
                                        @descriptor.Description
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public required DesignerService State { get; set; }
    [Parameter] public string? CssClass { get; set; }

    private void HandleDragStart(NodeTypeDescriptor descriptor)
    {
        var instance = Activator.CreateInstance(descriptor.NodeType);

        if (instance is NodeBase coreData)
        {
            State.PendingNewNode = new DesignerNode
            {
                NodeData = coreData,
                Title = descriptor.DisplayName,
                Description = descriptor.Description,
                Icon = descriptor.Icon,
                CssClass = descriptor.CssClass,
                Shape = descriptor.Shape,
                Width = descriptor.DefaultWidth,
                Height = descriptor.DefaultHeight,
                X = -500,
                Y = -500
            };

            State.MarkDirty();
        }
    }
}
