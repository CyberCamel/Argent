@using Argent.Models.Workflows
@using Argent.Runtime.Workflows.Modeling
@using Argent.Runtime.Workflows.Modeling.Routing

@if (Draft is not null)
{
    var pathData = RoutingService.DraftPath(Draft.Source, Draft.SourceDir, Draft.MouseX, Draft.MouseY);
    <path d="@pathData"
          class="connection-draft" />
}

@code {
    [Parameter]
    public ConnectionDraft? Draft { get; set; }
}
