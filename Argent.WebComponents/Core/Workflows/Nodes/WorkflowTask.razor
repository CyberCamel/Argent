@using Argent.Logic.Workflows.Modeling
<g transform="translate(@Node.X, @Node.Y)" class="bpmn-shape">
    <rect width="@Node.Width" height="@Node.Height" rx="8"
          fill="#e3f2fd" stroke="#1976d2" stroke-width="2" />
    <text x="@(Node.Width / 2)" y="@(Node.Height / 2 + 5)"
          text-anchor="middle" class="bpmn-text" fill="#0d47a1">
        @Node.Title
    </text>
</g>

@code{
    [Parameter] public DesignerNode Node { get; set; } = default!;
}