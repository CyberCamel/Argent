@using Argent.Models.DomainObjects
@using Argent.Contracts.DataSources
@using Argent.Runtime.DomainObjects
@implements IDisposable
@inject DomainObjectDesignerService State
@inject NavigationManager Navigation

<style>
    .do-row { cursor: pointer; }
    .do-row.selected { background: rgba(99,102,241,0.08); }
    :where(.dark) .do-row.selected { background: rgba(99,102,241,0.15); }
    .do-key { font-family: 'Cascadia Code','Fira Code','Consolas',monospace; font-size: 0.8rem; }
    .property-label { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; color: #6b7280; margin-bottom: 0.35rem; letter-spacing: 0.04em; }
    :where(.dark) .property-label { color: #9ca3af; }
    .property-section { border-bottom: 1px solid #e5e7eb; padding-bottom: 0.75rem; margin-bottom: 0.75rem; }
    :where(.dark) .property-section { border-color: #374151; }
    .input-group { display: flex; gap: 0; }
    .input-group > .form-input:not(:first-child) { border-top-left-radius: 0; border-bottom-left-radius: 0; }
    .input-group > .form-input:not(:last-child) { border-top-right-radius: 0; border-bottom-right-radius: 0; }
    .input-group-text { display: flex; align-items: center; padding: 0 8px; background: #f3f4f6; color: #6b7280; font-size: 0.8rem; border: 1px solid #d1d5db; }
    :where(.dark) .input-group-text { background: #374151; color: #9ca3af; border-color: #4b5563; }
</style>

<div class="flex flex-col h-full">
    @* ── Toolbar ─────────────────────────────────────────────── *@
    <div class="flex items-center gap-2 p-2 border-b bg-white dark:bg-gray-900" style="min-height: 42px;">
        <a href="/DomainObjects" class="inline-flex items-center px-2 py-1 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors mr-1" title="Back to domain objects">
            <i class="bi bi-arrow-left"></i>
        </a>
        <input type="text" class="form-input form-input-sm" style="max-width: 220px;"
               value="@State.Name"
               @onchange="e => { State.Name = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }"
               placeholder="Display name" />
        <input type="text" class="form-input form-input-sm do-key" style="max-width: 180px;"
               value="@State.Key"
               disabled="@(!State.IsNew)"
               @onchange="e => { State.Key = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }"
               placeholder="system_key" title="Stable system key (immutable once saved)" />

        <button class="px-3 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" @onclick="HandleSave" disabled="@_isBusy">
            <i class="bi bi-save-fill"></i> Save
        </button>
        <button class="px-3 py-1.5 text-sm font-medium text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/30 hover:bg-green-100 dark:hover:bg-green-900/50 rounded-lg transition-colors" @onclick="HandlePublish" disabled="@_isBusy">
            <i class="bi bi-cloud-arrow-up-fill"></i> Publish
        </button>

        <span title="@(State.HasUnsavedChanges ? "Unsaved changes" : "Saved")"
              class="@(State.HasUnsavedChanges ? "text-yellow-600 dark:text-yellow-400" : "text-green-600 dark:text-green-400")">
            <i class="bi @(State.HasUnsavedChanges ? "bi-circle-fill" : "bi-check-circle-fill")"></i>
        </span>
        @if (!string.IsNullOrEmpty(State.PublishedVersion))
        {
            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700" title="Latest published version">v@(State.PublishedVersion)</span>
        }
        @if (!string.IsNullOrEmpty(_error))
        {
            <span class="text-red-600 dark:text-red-400 text-sm ml-2"><i class="bi bi-exclamation-triangle-fill"></i> @_error</span>
        }
    </div>

    <div class="flex flex-1 overflow-hidden">
        @* ── Property list ───────────────────────────────────── *@
        <div class="flex-1 overflow-auto p-3">
            <div class="flex items-center mb-2">
                <h6 class="text-gray-500 dark:text-gray-400 mb-0"><i class="bi bi-list-columns-reverse"></i> Properties</h6>
                <button class="ml-auto px-3 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" @onclick="() => State.AddProperty()">
                    <i class="bi bi-plus-lg"></i> Add Property
                </button>
            </div>

            @if (State.Definition.Properties.Count == 0)
            {
                <div class="text-gray-500 dark:text-gray-400 border rounded p-4 text-center" style="border-style: dashed !important;">
                    No properties yet. Click <strong>Add Property</strong> to model your first field.
                </div>
            }
            else
            {
                <div class="w-full overflow-x-auto border border-gray-200 dark:border-gray-700 rounded-lg">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50">
                            <th class="px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400" style="width: 28px;"></th>
                            <th class="px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400">Key</th>
                            <th class="px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400">Display Name</th>
                            <th class="px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400">Type</th>
                            <th class="px-3 py-2 text-left font-semibold text-gray-500 dark:text-gray-400">Flags</th>
                            <th class="px-3 py-2 text-right font-semibold text-gray-500 dark:text-gray-400" style="width: 110px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in State.Definition.Properties)
                        {
                            <tr class="do-row border-b border-gray-100 dark:border-gray-800 @(ReferenceEquals(row, State.SelectedProperty) ? "selected" : "")"
                                @onclick="() => State.SelectProperty(row)">
                                <td class="px-3 py-2 text-gray-500 dark:text-gray-400">
                                    @if (State.Definition.TitleProperty == row.Key)
                                    {
                                        <i class="bi bi-star-fill text-yellow-600 dark:text-yellow-400" title="Title property"></i>
                                    }
                                </td>
                                <td class="px-3 py-2 do-key">@row.Key</td>
                                <td class="px-3 py-2">@row.DisplayName</td>
                                <td class="px-3 py-2"><span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 border border-gray-200 dark:border-gray-700">@row.Type</span></td>
                                <td class="px-3 py-2 text-sm text-gray-500 dark:text-gray-400">
                                    @if (row.Required) { <span class="mr-1" title="Required">REQ</span> }
                                    @if (row.Unique) { <span class="mr-1" title="Unique">UNQ</span> }
                                    @if (row.Indexed) { <span class="mr-1" title="Indexed">IDX</span> }
                                    @if (row.IsCollection) { <span title="Collection">[]</span> }
                                </td>
                                <td class="px-3 py-2 text-right whitespace-nowrap" @onclick:stopPropagation>
                                    <button class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 p-0 bg-transparent border-none cursor-pointer mr-1" @onclick="() => State.MoveProperty(row, -1)" title="Move up"><i class="bi bi-arrow-up"></i></button>
                                    <button class="text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 p-0 bg-transparent border-none cursor-pointer mr-1" @onclick="() => State.MoveProperty(row, 1)" title="Move down"><i class="bi bi-arrow-down"></i></button>
                                    <button class="text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 p-0 bg-transparent border-none cursor-pointer" @onclick="() => State.RemoveProperty(row)" title="Delete"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                </div>
            }

            @* ── External data source bindings ─────────────────── *@
            <hr class="my-3" />
            <div class="flex items-center mb-2">
                <h6 class="text-gray-500 dark:text-gray-400 mb-0"><i class="bi bi-hdd-network"></i> External Data Sources</h6>
                <button class="ml-auto px-3 py-1.5 text-sm font-medium text-indigo-600 dark:text-indigo-400 bg-indigo-50 dark:bg-indigo-900/30 hover:bg-indigo-100 dark:hover:bg-indigo-900/50 rounded-lg transition-colors" @onclick="() => State.AddDataSource()">
                    <i class="bi bi-plus-lg"></i> Add Data Source
                </button>
            </div>
            <p class="text-gray-500 dark:text-gray-400 text-sm">Optional. Bind records to an external query; otherwise records come from managed storage. Referenced by index from a form dropdown's data provider.</p>

            @if (State.Definition.DataSources.Count == 0)
            {
                <div class="text-gray-500 dark:text-gray-400 border rounded p-3 text-center text-sm" style="border-style: dashed !important;">
                    No external bindings.
                </div>
            }
            else
            {
                @for (int dsI = 0; dsI < State.Definition.DataSources.Count; dsI++)
                {
                    var dsIndex = dsI;
                    var ds = State.Definition.DataSources[dsIndex];
                    <div class="border border-gray-200 dark:border-gray-700 rounded-lg mb-2 overflow-hidden">
                        <div class="flex items-center gap-2 py-1.5 px-3 bg-gray-50 dark:bg-gray-800/50 border-b border-gray-200 dark:border-gray-700">
                            <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded bg-gray-500 text-white" title="DataSourceIndex">#@dsIndex</span>
                            <input class="form-input text-sm" style="max-width: 220px;"
                                   placeholder="Binding name" @bind="ds.Name" @bind:after="State.MarkDirty" />
                            <button class="ml-auto text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 p-0 bg-transparent border-none cursor-pointer"
                                    @onclick="() => State.RemoveDataSource(ds)" title="Remove binding">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        <div class="p-3">
                            <label class="property-label">Connection</label>
                            <select class="form-input text-sm mb-2" @bind="ds.DataSourceKey" @bind:after="State.MarkDirty">
                                <option value="">— select connection —</option>
                                @foreach (var conn in State.DataSourceCatalog)
                                {
                                    <option value="@conn.Key">@conn.Name (@conn.Kind)</option>
                                }
                            </select>
                            @if (State.DataSourceCatalog.Count == 0)
                            {
                                <div class="text-gray-500 dark:text-gray-400 text-sm mb-2">No connections defined — create them under <a href="/DataSources" target="_blank">Data Sources</a>.</div>
                            }

                            <label class="property-label">Query</label>
                            <textarea class="form-input text-sm font-mono mb-2" rows="2"
                                      placeholder="SELECT id, name FROM Customer" @bind="ds.Query" @bind:after="State.MarkDirty"></textarea>

                            <div class="flex items-center mb-1">
                                <span class="property-label mb-0">Column mappings</span>
                                <button class="ml-auto text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 p-0 bg-transparent border-none cursor-pointer" @onclick="() => State.AddColumnMapping(ds)">
                                    <i class="bi bi-plus-lg"></i> Add
                                </button>
                            </div>
                            @foreach (var mapping in ds.ColumnMappings)
                            {
                                <div class="input-group mb-1">
                                    <input class="form-input rounded-r-none" placeholder="result column" @bind="mapping.Column" @bind:after="State.MarkDirty" />
                                    <span class="input-group-text border-l-0 border-r-0">→</span>
                                    <select class="form-input rounded-l-none" @bind="mapping.Property" @bind:after="State.MarkDirty">
                                        <option value="">— property —</option>
                                        @foreach (var target in State.Definition.Properties)
                                        {
                                            <option value="@target.Key">@target.Key</option>
                                        }
                                    </select>
                                    <button class="px-2 py-1 text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/50 rounded-r-lg border border-red-200 dark:border-red-800" @onclick="() => State.RemoveColumnMapping(ds, mapping)"><i class="bi bi-x"></i></button>
                                </div>
                            }
                            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1">Unmapped columns fall through to a property with the same name.</div>
                        </div>
                    </div>
                }
            }
        </div>

        @* ── Property panel ──────────────────────────────────── *@
        <div class="border-s bg-gray-100 dark:bg-gray-800 p-3" style="width: 360px; min-width: 360px; overflow-y: auto;">
            @if (State.SelectedProperty is { } prop)
            {
                <h6 class="text-gray-500 dark:text-gray-400 mb-3"><i class="bi bi-sliders"></i> Property</h6>

                <div class="property-section">
                    <div class="property-label">Key</div>
                    <input class="form-input form-input-sm do-key mb-2" value="@prop.Key"
                           @onchange="e => { prop.Key = e.Value?.ToString() ?? string.Empty; State.MarkDirty(); }" />
                    <div class="property-label">Display Name</div>
                    <input class="form-input form-input-sm mb-2" @bind="prop.DisplayName" @bind:after="State.MarkDirty" />
                    <div class="property-label">Description</div>
                    <input class="form-input form-input-sm" @bind="prop.Description" @bind:after="State.MarkDirty" />
                </div>

                <div class="property-section">
                    <div class="property-label">Type</div>
                    <select class="form-input text-sm mb-2" @bind="prop.Type" @bind:after="State.MarkDirty">
                        @foreach (var type in Enum.GetValues<DomainPropertyType>())
                        {
                            <option value="@type">@type</option>
                        }
                    </select>

                    @if (prop.Type == DomainPropertyType.Reference)
                    {
                        <div class="property-label">References</div>
                        <select class="form-input text-sm" @bind="prop.ReferenceTargetKey" @bind:after="State.MarkDirty">
                            <option value="">— select object —</option>
                            @foreach (var summary in State.Catalog.Where(s => s.Key != State.Key))
                            {
                                <option value="@summary.Key">@summary.Name (@summary.Key)</option>
                            }
                        </select>
                    }
                </div>

                <div class="property-section">
                    <div class="property-label">Constraints</div>
                    <div class="flex items-center">
                        <input class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-indigo-600 focus:ring-indigo-500" type="checkbox" id="p-req" @bind="prop.Required" @bind:after="State.MarkDirty" />
                        <label class="pl-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer" for="p-req">Required</label>
                    </div>
                    <div class="flex items-center">
                        <input class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-indigo-600 focus:ring-indigo-500" type="checkbox" id="p-unq" @bind="prop.Unique" @bind:after="State.MarkDirty" />
                        <label class="pl-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer" for="p-unq">Unique</label>
                    </div>
                    <div class="flex items-center">
                        <input class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-indigo-600 focus:ring-indigo-500" type="checkbox" id="p-idx" @bind="prop.Indexed" @bind:after="State.MarkDirty" />
                        <label class="pl-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer" for="p-idx">Indexed</label>
                    </div>
                    <div class="flex items-center">
                        <input class="h-4 w-4 rounded border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-indigo-600 focus:ring-indigo-500" type="checkbox" id="p-col" @bind="prop.IsCollection" @bind:after="State.MarkDirty" />
                        <label class="pl-2 text-sm text-gray-700 dark:text-gray-300 cursor-pointer" for="p-col">Collection (multi-value)</label>
                    </div>
                </div>

                @if (prop.Type == DomainPropertyType.Choice)
                {
                    <div class="property-section">
                        <div class="flex items-center mb-2">
                            <div class="property-label mb-0">Choices</div>
                            <button class="ml-auto text-sm text-indigo-600 dark:text-indigo-400 hover:text-indigo-800 dark:hover:text-indigo-300 p-0 bg-transparent border-none cursor-pointer" @onclick="() => AddChoice(prop)"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                        @foreach (var choice in prop.Choices)
                        {
                            <div class="input-group mb-1">
                                <input class="form-input rounded-r-none" placeholder="Label" @bind="choice.Label" @bind:after="State.MarkDirty" />
                                <input class="form-input rounded-none border-l-0" placeholder="Value"
                                       value="@choice.Value?.ToString()"
                                       @onchange="e => { choice.Value = e.Value?.ToString(); State.MarkDirty(); }" />
                                <button class="px-2 py-1 text-sm font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 hover:bg-red-100 dark:hover:bg-red-900/50 rounded-r-lg border border-red-200 dark:border-red-800" @onclick="() => RemoveChoice(prop, choice)"><i class="bi bi-x"></i></button>
                            </div>
                        }
                    </div>
                }

                <button class="w-full px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 rounded-lg transition-colors disabled:opacity-50"
                        @onclick="() => SetTitleProperty(prop)"
                        disabled="@(State.Definition.TitleProperty == prop.Key)">
                    <i class="bi bi-star"></i> Use as title property
                </button>
            }
            else
            {
                <div class="text-gray-500 dark:text-gray-400 text-sm">Select a property to edit its settings.</div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? ObjectId { get; set; }

    private bool _isBusy;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        await State.EnsureCatalogAsync();
        if (ObjectId.HasValue)
            await State.LoadAsync(ObjectId.Value);
    }

    public void Dispose() => State.OnChange -= StateHasChanged;

    private async Task HandleSave()
    {
        _isBusy = true; _error = null;
        try
        {
            var wasNew = State.IsNew;
            await State.SaveAsync();
            if (wasNew && State.StoredObjectId.HasValue)
                Navigation.NavigateTo($"/DomainObjects/Edit/{State.StoredObjectId}", forceLoad: true);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isBusy = false; }
    }

    private async Task HandlePublish()
    {
        _isBusy = true; _error = null;
        try
        {
            var wasNew = State.IsNew;
            await State.PublishAsync();
            if (wasNew && State.StoredObjectId.HasValue)
                Navigation.NavigateTo($"/DomainObjects/Edit/{State.StoredObjectId}", forceLoad: true);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _isBusy = false; }
    }

    private void AddChoice(DomainProperty prop) { prop.Choices.Add(new DomainChoiceOption()); State.MarkDirty(); }
    private void RemoveChoice(DomainProperty prop, DomainChoiceOption choice) { prop.Choices.Remove(choice); State.MarkDirty(); }
    private void SetTitleProperty(DomainProperty prop) { State.Definition.TitleProperty = prop.Key; State.MarkDirty(); }
}
