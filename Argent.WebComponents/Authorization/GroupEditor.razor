@using Argent.Contracts.Authorization
@using Argent.Models.Identity
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<Argent.Infrastructure.Data.ArgentDbContext> DbFactory
@inject IPolicyDecisionService PolicyService
@inject Microsoft.AspNetCore.Components.NavigationManager NavManager

<div class="card">
    <div class="card-body">
        <h5 class="fw-bold mb-3">@(GroupId == null ? "New Group" : "Edit Group")</h5>

        @if (_isSystem)
        {
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <i class="bi bi-shield-lock-fill"></i>
                <span>This is a system group and cannot be modified.</span>
            </div>
        }
        else
        {
            @if (!string.IsNullOrEmpty(_error))
            {
                <div class="alert alert-danger">@_error</div>
            }

            <div class="mb-3">
                <label class="form-label small fw-medium">Name</label>
                <input type="text" class="form-control" @bind="Name" placeholder="e.g. Finance" />
            </div>

            <div class="mb-3">
                <label class="form-label small fw-medium">Description</label>
                <textarea class="form-control" @bind="Description" rows="2"></textarea>
            </div>

            <MemberSelector Label="Members" EmptyText="No members yet."
                            Options="_userOptions" Selected="_selectedUsers"
                            Searchable="true" ItemUrl="@UserViewUrl" />

            <MemberSelector Label="Member groups" EmptyText="No nested groups."
                            Options="_groupOptions" Selected="_selectedGroups" />

            <div class="d-flex gap-2">
                <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                    @(_saving ? "Saving..." : "Save Group")
                </button>
                <a class="btn btn-outline-secondary" href="/Admin/Groups">Cancel</a>
            </div>
        }

        @if (_isSystem)
        {
            <a class="btn btn-outline-secondary" href="/Admin/Groups">Back</a>
        }
    </div>
</div>

@code {
    [Parameter] public Guid? GroupId { get; set; }

    private string Name = "";
    private string? Description;
    private bool _saving;
    private bool _isSystem;
    private string? _error;

    private List<MemberSelector.MemberOption> _userOptions = [];
    private List<MemberSelector.MemberOption> _groupOptions = [];
    private readonly HashSet<string> _selectedUsers = [];
    private readonly HashSet<string> _selectedGroups = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _userOptions = await db.Users
            .OrderBy(u => u.UserName)
            .Select(u => new MemberSelector.MemberOption(
                u.Id.ToString(),
                u.FirstName + " " + u.LastName + " (" + u.UserName + ")",
                "bi-person"))
            .ToListAsync();

        // A group cannot be a member of itself.
        _groupOptions = await db.Groups
            .Where(g => GroupId == null || g.Id != GroupId.Value)
            .OrderBy(g => g.Name)
            .Select(g => new MemberSelector.MemberOption(g.Id.ToString(), g.Name, "bi-people"))
            .ToListAsync();

        if (GroupId != null)
        {
            var group = await db.Groups.FindAsync([GroupId.Value]);
            if (group != null)
            {
                Name = group.Name;
                Description = group.Description;
                _isSystem = group.IsSystem;
            }

            var userMembers = await db.GroupMemberships
                .Where(m => m.GroupId == GroupId.Value)
                .Select(m => m.UserId.ToString())
                .ToListAsync();
            foreach (var m in userMembers) _selectedUsers.Add(m);

            var groupMembers = await db.GroupGroupMemberships
                .Where(m => m.GroupId == GroupId.Value)
                .Select(m => m.MemberGroupId.ToString())
                .ToListAsync();
            foreach (var m in groupMembers) _selectedGroups.Add(m);
        }
    }

    private static string? UserViewUrl(string id) => "/Users/View/" + id;

    private async Task Save()
    {
        if (_isSystem) return;

        _saving = true;
        _error = null;

        try
        {
            if (string.IsNullOrWhiteSpace(Name))
            {
                _error = "Name is required.";
                return;
            }

            await using var db = await DbFactory.CreateDbContextAsync();

            Group group;
            if (GroupId == null)
            {
                group = new Group { Id = Guid.NewGuid(), Name = Name, Description = Description };
                db.Groups.Add(group);
            }
            else
            {
                var existing = await db.Groups.FindAsync([GroupId.Value]);
                if (existing == null)
                {
                    _error = "Group no longer exists.";
                    return;
                }
                existing.Name = Name;
                existing.Description = Description;
                group = existing;

                db.GroupMemberships.RemoveRange(
                    await db.GroupMemberships.Where(m => m.GroupId == group.Id).ToListAsync());
                db.GroupGroupMemberships.RemoveRange(
                    await db.GroupGroupMemberships.Where(m => m.GroupId == group.Id).ToListAsync());
            }

            foreach (var uid in _selectedUsers)
            {
                if (Guid.TryParse(uid, out var userGuid))
                    db.GroupMemberships.Add(new GroupMembership { GroupId = group.Id, UserId = userGuid });
            }

            foreach (var gid in _selectedGroups)
            {
                if (Guid.TryParse(gid, out var childGuid) && childGuid != group.Id)
                    db.GroupGroupMemberships.Add(new GroupGroupMembership { GroupId = group.Id, MemberGroupId = childGuid });
            }

            await db.SaveChangesAsync();
            await PolicyService.InvalidateCacheAsync();
            NavManager.NavigateTo("/Admin/Groups");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }
}
