@using Argent.Models.Authorization
@using Argent.Models.Forms.Components.Configuration
@using Argent.WebComponents.Core.Forms.Designer
@using Argent.Contracts.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<Argent.Infrastructure.Data.ArgentDbContext> DbFactory
@inject IPolicyDecisionService PolicyService
@inject Microsoft.AspNetCore.Components.NavigationManager NavManager

<div class="card">
    <div class="card-body">
        <h5 class="fw-bold mb-3">@(Policy == null ? "New Policy" : "Edit Policy")</h5>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }

        <div class="mb-3">
            <label class="form-label small fw-medium">Name</label>
            <input type="text" class="form-control" @bind="Name" placeholder="e.g. Allow self-service edit" />
        </div>

        <div class="mb-3">
            <label class="form-label small fw-medium">Description</label>
            <textarea class="form-control" @bind="Description" rows="2"></textarea>
        </div>

        <div class="row mb-3">
            <div class="col">
                <label class="form-label small fw-medium">Effect</label>
                <select class="form-select" @bind="Effect">
                    <option value="@PolicyEffect.Allow">Allow</option>
                    <option value="@PolicyEffect.Deny">Deny</option>
                </select>
            </div>
            <div class="col">
                <label class="form-label small fw-medium">Resource Type</label>
                <select class="form-select" @bind="ResourceType">
                    @foreach (var rt in Enum.GetValues<ResourceType>())
                    {
                        <option value="@rt">@rt</option>
                    }
                </select>
            </div>
            <div class="col">
                <label class="form-label small fw-medium">Priority</label>
                <input type="number" class="form-control" @bind="Priority" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label small fw-medium">Actions</label>
            <input type="text" class="form-control" @bind="ActionsText" placeholder="e.g. read, write, *" />
            <small class="text-muted">Comma-separated. Use * for all actions.</small>
        </div>

        <p class="small text-muted mb-2">
            Subject — a policy applies to a user who matches <strong>any</strong> selected user,
            role, or group. Leave all three empty to apply to everyone.
        </p>

        <div class="row">
            <div class="col-md-4">
                <MemberSelector Label="Users" EmptyText="No users." Options="_userOptions" Selected="_selectedUsers"
                                ItemUrl="@UserViewUrl" Searchable="true" />
            </div>
            <div class="col-md-4">
                <MemberSelector Label="Roles" EmptyText="No roles." Options="_roleOptions" Selected="_selectedRoles" Searchable="true" />
            </div>
            <div class="col-md-4">
                <MemberSelector Label="Groups" EmptyText="No groups." Options="_groupOptions" Selected="_selectedGroups" Searchable="true" />
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label small fw-medium">Condition</label>
            <ConditionBuilder Condition="@Condition" ConditionChanged="@((c) => Condition = c)" />

            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="IsEnabled" id="enabledCheck" />
                <label class="form-check-label small" for="enabledCheck">Enabled</label>
            </div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                @(_saving ? "Saving..." : "Save Policy")
            </button>
            <button class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
        </div>
    </div>
</div>

@code {
    [Parameter] public PolicyDocument? Policy { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private string Name = "";
    private string? Description;
    private PolicyEffect Effect = PolicyEffect.Allow;
    private ResourceType ResourceType = ResourceType.DomainRecord;
    private int Priority;
    private string ActionsText = "";
    private Condition? Condition;
    private bool IsEnabled = true;
    private bool _saving;
    private string? _error;

    private List<MemberSelector.MemberOption> _userOptions = [];
    private List<MemberSelector.MemberOption> _roleOptions = [];
    private List<MemberSelector.MemberOption> _groupOptions = [];

    private readonly HashSet<string> _selectedUsers = [];
    private readonly HashSet<string> _selectedRoles = [];
    private readonly HashSet<string> _selectedGroups = [];

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _userOptions = await db.Users
            .OrderBy(u => u.UserName)
            .Select(u => new MemberSelector.MemberOption(
                u.Id.ToString(),
                u.FirstName + " " + u.LastName + " (" + u.UserName + ")",
                "bi-person"))
            .ToListAsync();
        _roleOptions = await db.Roles
            .Where(r => r.Name != null)
            .OrderBy(r => r.Name)
            .Select(r => new MemberSelector.MemberOption(r.Name!, r.Name!, "bi-shield"))
            .ToListAsync();
        _groupOptions = await db.Groups
            .OrderBy(g => g.Name)
            .Select(g => new MemberSelector.MemberOption(g.Id.ToString(), g.Name, "bi-people"))
            .ToListAsync();

        if (Policy != null)
        {
            Name = Policy.Name;
            Description = Policy.Description;
            Effect = Policy.Effect;
            ResourceType = Policy.ResourceType;
            Priority = Policy.Priority;
            IsEnabled = Policy.IsEnabled;
            Condition = Policy.Condition;

            ActionsText = string.Join(", ", ParseJsonList(Policy.ActionsJson));

            var subject = ParseSubjectJson(Policy.SubjectJson);
            foreach (var u in subject.users) _selectedUsers.Add(u);
            foreach (var r in subject.roles) _selectedRoles.Add(r);
            foreach (var g in subject.groups) _selectedGroups.Add(g);
        }
    }

    private static string? UserViewUrl(string id) => "/Users/View/" + id;

    private async Task Save()
    {
        _saving = true;
        _error = null;

        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();

            var actions = ActionsText
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

            var subject = new Dictionary<string, object?>();
            if (_selectedUsers.Count > 0) subject["users"] = _selectedUsers.ToList();
            if (_selectedRoles.Count > 0) subject["roles"] = _selectedRoles.ToList();
            if (_selectedGroups.Count > 0) subject["groups"] = _selectedGroups.ToList();

            var actionsJson = System.Text.Json.JsonSerializer.Serialize(actions);
            var subjectJson = System.Text.Json.JsonSerializer.Serialize(subject);

            if (Policy == null)
            {
                db.PolicyDocuments.Add(new PolicyDocument
                {
                    Id = Guid.NewGuid(),
                    Name = Name,
                    Description = Description,
                    Effect = Effect,
                    ResourceType = ResourceType,
                    Priority = Priority,
                    IsEnabled = IsEnabled,
                    Condition = Condition,
                    ActionsJson = actionsJson,
                    SubjectJson = subjectJson
                });
            }
            else
            {
                var existing = await db.PolicyDocuments.FindAsync([Policy.Id]);
                if (existing != null)
                {
                    existing.Name = Name;
                    existing.Description = Description;
                    existing.Effect = Effect;
                    existing.ResourceType = ResourceType;
                    existing.Priority = Priority;
                    existing.IsEnabled = IsEnabled;
                    existing.Condition = Condition;
                    existing.ActionsJson = actionsJson;
                    existing.SubjectJson = subjectJson;
                }
            }

            await db.SaveChangesAsync();
            await PolicyService.InvalidateCacheAsync();
            NavManager.NavigateTo("/Admin/Policies");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private static List<string> ParseJsonList(string json)
    {
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<List<string>>(json) ?? [];
        }
        catch { return []; }
    }

    private static (List<string> users, List<string> roles, List<string> groups) ParseSubjectJson(string json)
    {
        try
        {
            var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, System.Text.Json.JsonElement>>(json);
            if (dict == null) return ([], [], []);

            List<string> Read(string key) =>
                dict.TryGetValue(key, out var el) && el.ValueKind == System.Text.Json.JsonValueKind.Array
                    ? System.Text.Json.JsonSerializer.Deserialize<List<string>>(el.GetRawText()) ?? []
                    : [];

            return (Read("users"), Read("roles"), Read("groups"));
        }
        catch { return ([], [], []); }
    }
}
